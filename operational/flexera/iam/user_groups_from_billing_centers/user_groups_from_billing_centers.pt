name "Flexera User Groups from Billing Centers"
rs_pt_ver 20180301
type "policy"
short_description "Automatically creates and manages User Groups based on Billing Centers, granting each group access to its corresponding Billing Center. See the [README](https://github.com/flexera-public/policy_templates/tree/master/operational/flexera/iam/user_groups_from_billing_centers/) and [Flexera Automation docs](https://docs.flexera.com/flexera-one/automation/) to learn more."
long_description ""
doc_link "https://github.com/flexera-public/policy_templates/tree/master/operational/flexera/iam/user_groups_from_billing_centers/"
category "Operational"
severity "low"
default_frequency "daily"
info(
  version: "0.1.0",
  provider: "Flexera",
  service: "Identity & Access Management",
  policy_set: "Automation",
  hide_skip_approvals: "true"
)

###############################################################################
# Parameters
###############################################################################

parameter "param_email" do
  type "list"
  category "Policy Settings"
  label "Email Addresses"
  description "Email addresses of the recipients you wish to notify."
  default []
end

parameter "param_billing_center_scope" do
  type "string"
  category "Policy Settings"
  label "Billing Center Scope"
  description "Whether to create user groups for all Billing Centers, only top-level ones, or only those at a specific level. Specify a level with 'L1' through 'L9', 'Level 1' through 'Level 9', or 'Level1' through 'Level9'. Level 1 is equivalent to 'Top-Level Billing Centers Only'."
  allowed_values "All Billing Centers", "Top-Level Billing Centers Only", "Level 1", "Level 2", "Level 3", "Level 4", "Level 5", "Level 6", "Level 7", "Level 8", "Level 9"
  default "All Billing Centers"
end

parameter "param_billing_center_list" do
  type "list"
  category "Filters"
  label "Billing Center Names"
  description "Optional list of Billing Center names or IDs to include. If empty, all Billing Centers (per scope setting) are included."
  default []
end

parameter "param_billing_center_list_exclude" do
  type "list"
  category "Filters"
  label "Billing Center Names Exclude"
  description "Optional list of Billing Center names or IDs to exclude."
  default []
end

parameter "param_role" do
  type "string"
  category "Policy Settings"
  label "Billing Center Role"
  description "The role to grant to the User Group on the Billing Center."
  allowed_values "billing_center_viewer", "billing_center_admin"
  default "billing_center_viewer"
end

parameter "param_group_name_prefix" do
  type "string"
  category "Policy Settings"
  label "User Group Name Prefix"
  description "A prefix to prepend to the Billing Center name when creating the User Group name."
  default "BC:"
end

parameter "param_bc_name_strategy" do
  type "string"
  category "Policy Settings"
  label "Billing Center Name Collision Strategy"
  description "How to handle Billing Centers with the same name. 'Use Full Path' uses the full hierarchy path (e.g. 'North America / Engineering'). 'Include BC ID' appends the Billing Center ID. 'Allow Collisions' maps identically-named Billing Centers to a single User Group."
  allowed_values "Use Full Path", "Include BC ID", "Allow Collisions"
  default "Use Full Path"
end

parameter "param_automatic_action" do
  type "list"
  category "Actions"
  label "Automatic Actions"
  description "Actions to automatically take when the policy finds changes to make."
  allowed_values "Create User Groups", "Delete User Groups"
  default []
end

###############################################################################
# Authentication
###############################################################################

credentials "auth_flexera" do
  schemes "oauth2"
  label "Flexera"
  description "Select FlexeraOne OAuth2 credential."
  tags "provider=flexera"
end

###############################################################################
# Datasources & Scripts
###############################################################################

# Get region-specific Flexera API endpoints
datasource "ds_flexera_api_hosts" do
  run_script $js_flexera_api_hosts, rs_optima_host
end

script "js_flexera_api_hosts", type: "javascript" do
  parameters "rs_optima_host"
  result "result"
  code <<-'EOS'
  host_table = {
    "api.optima.flexeraeng.com": {
      api: "api.flexera.com",
      flexera: "api.flexera.com",
      fsm: "api.fsm.flexeraeng.com",
      grs: "grs-front.iam-us-east-1.flexeraeng.com",
      ui: "app.flexera.com",
      tld: "flexera.com"
    },
    "api.optima-eu.flexeraeng.com": {
      api: "api.flexera.eu",
      flexera: "api.flexera.eu",
      fsm: "api.fsm-eu.flexeraeng.com",
      grs: "grs-front.eu-central-1.iam-eu.flexeraeng.com",
      ui: "app.flexera.eu",
      tld: "flexera.eu"
    },
    "api.optima-apac.flexeraeng.com": {
      api: "api.flexera.au",
      flexera: "api.flexera.au",
      fsm: "api.fsm-apac.flexeraeng.com",
      grs: "grs-front.ap-southeast-2.iam-apac.flexeraeng.com",
      ui: "app.flexera.au",
      tld: "flexera.au"
    }
  }

  result = host_table[rs_optima_host]
EOS
end

# Get applied policy metadata
datasource "ds_applied_policy" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies", switch(policy_id, join(["/", policy_id]), "")])
  end
  result do
    encoding "json"
    field "id", switch(policy_id, jmes_path(response, "id"), "")
    field "name", switch(policy_id, jmes_path(response, "name"), "")
  end
end

# Get all Billing Centers
datasource "ds_billing_centers" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/analytics/orgs/", rs_org_id, "/billing_centers"])
    header "Api-Version", "1.0"
    header "User-Agent", "RS Policies"
  end
  result do
    encoding "json"
    collect jq(response, '.[]') do
      field "id", jq(col_item, ".id")
      field "name", jq(col_item, ".name")
      field "parent_id", jq(col_item, ".parent_id")
    end
  end
end

# Filter billing centers based on parameters
datasource "ds_billing_centers_filtered" do
  run_script $js_billing_centers_filtered, $ds_billing_centers, $param_billing_center_scope, $param_billing_center_list, $param_billing_center_list_exclude
end

script "js_billing_centers_filtered", type: "javascript" do
  parameters "ds_billing_centers", "param_billing_center_scope", "param_billing_center_list", "param_billing_center_list_exclude"
  result "result"
  code <<-'EOS'
  result = ds_billing_centers

  // Build lookup by ID for parent chain walking
  var bcById = {}

  _.each(ds_billing_centers, function(bc) { bcById[bc["id"]] = bc })

  // Parse scope parameter for level filtering
  var targetLevel = 0 // 0 means all levels

  if (param_billing_center_scope == "Top-Level Billing Centers Only") {
    targetLevel = 1
  } else if (param_billing_center_scope != "All Billing Centers") {
    // Match L1-L9, Level 1-Level 9, Level1-Level9
    var match = param_billing_center_scope.match(/^(?:L|Level ?)(\d)$/)

    if (match) { targetLevel = parseInt(match[1], 10) }
  }

  if (targetLevel > 0) {
    function getLevel(bc) {
      var level = 1
      var current = bc

      while (current["parent_id"] && bcById[current["parent_id"]]) {
        level++
        current = bcById[current["parent_id"]]
      }

      return level
    }

    result = _.filter(result, function(bc) {
      return getLevel(bc) == targetLevel
    })
  }

  // Exclude unallocated billing centers
  result = _.reject(result, function(bc) {
    return /^unallocated/i.test(bc["id"])
  })

  // Include filter
  if (param_billing_center_list.length > 0) {
    result = _.filter(result, function(bc) {
      return _.contains(param_billing_center_list, bc["name"]) ||
             _.contains(param_billing_center_list, bc["id"])
    })
  }

  // Exclude filter
  if (param_billing_center_list_exclude.length > 0) {
    result = _.reject(result, function(bc) {
      return _.contains(param_billing_center_list_exclude, bc["name"]) ||
             _.contains(param_billing_center_list_exclude, bc["id"])
    })
  }

  // Compute full path for each billing center by walking parent chain
  function getPath(bc) {
    var parts = [bc["name"]]
    var current = bc

    while (current["parent_id"] && bcById[current["parent_id"]]) {
      current = bcById[current["parent_id"]]
      parts.unshift(current["name"])
    }

    return parts.join(" / ")
  }

  result = _.map(result, function(bc) {
    return {
      id: bc["id"],
      name: bc["name"],
      parent_id: bc["parent_id"],
      path: getPath(bc)
    }
  })
EOS
end

# Get all IAM groups
datasource "ds_groups" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/iam/v1/orgs/", rs_org_id, "/groups"])
    header "User-Agent", "RS Policies"
  end
  result do
    encoding "json"
    collect jmes_path(response, "values[*]") do
      field "id", jmes_path(col_item, "id")
      field "name", jmes_path(col_item, "name")
      field "description", jmes_path(col_item, "description")
      field "ref", jmes_path(col_item, "ref")
      field "kind", jmes_path(col_item, "kind")
      field "createdAt", jmes_path(col_item, "createdAt")
      field "updatedAt", jmes_path(col_item, "updatedAt")
    end
  end
end

