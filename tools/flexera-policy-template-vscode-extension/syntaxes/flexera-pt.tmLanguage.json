{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flexera Policy Template",
  "scopeName": "source.flexera-pt",
  "patterns": [
    {
      "include": "#javascript-embedded"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#metadata-blocks"
    },
    {
      "include": "#dsl-string-heredoc"
    },
    {
      "include": "#template-expressions"
    },
    {
      "include": "#block-definitions"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#builtin-variables"
    },
    {
      "include": "#dsl-variables"
    },
    {
      "include": "#dsl-functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#constants"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.flexera-pt",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.flexera-pt",
          "match": "#.*$"
        }
      ]
    },
    "metadata-blocks": {
      "patterns": [
        {
          "name": "keyword.control.metadata.flexera-pt",
          "match": "\\b(name|rs_pt_ver|type|short_description|long_description|doc_link|category|severity|default_frequency|tenancy)\\b"
        },
        {
          "name": "entity.name.function.info.flexera-pt",
          "match": "\\binfo\\b"
        },
        {
          "name": "keyword.other.info-field.flexera-pt",
          "match": "\\b(version|provider|service|policy_set|recommendation_type|hide_skip_approvals|publish|tenancy)\\b(?=\\s*:)"
        }
      ]
    },
    "block-definitions": {
      "patterns": [
        {
          "name": "keyword.control.block.flexera-pt",
          "match": "\\b(parameter|credential|credentials|pagination|datasource|script|policy|escalation|resolution|define)(?=\\s)"
        },
        {
          "name": "keyword.control.subblock.flexera-pt",
          "match": "\\b(request|result|validate|validate_each|check|escalate|export|run|field|collect|encoding|header|query|body|body_field|auth|host|path|verb|scheme|ignore_status|email|label|description|automatic|summary_template|detail_template|hash_include|hash_exclude|resource_level|iterate|run_script|pagination|get_page_marker|set_page_marker|body_path|uri|no_echo|min_value|max_value|min_length|max_length|allowed_values|allowed_pattern|constraint_description|format|resolve_incident|attach_export_table|body_table_max_rows|aws_account_number|schemes|tags|parameters|type|category|default)(?=\\s)"
        },
        {
          "name": "keyword.control.flow.do.flexera-pt",
          "match": "\\bdo\\b(?!\\w)"
        },
        {
          "name": "keyword.control.flow.end.flexera-pt",
          "match": "\\bend\\b(?!\\w)"
        },
        {
          "name": "keyword.control.flow.flexera-pt",
          "match": "\\b(if|else|elsif|unless|case|when|then|foreach|concurrent|sub|on_error|on_timeout|timeout|return|raise|while|call|retrieve|sleep)\\b"
        }
      ]
    },
    "dsl-string-heredoc": {
      "patterns": [
        {
          "begin": "(?<!code )(<<-(?:'(?:EOS|EOF)'|(?:EOS|EOF)))",
          "beginCaptures": {
            "1": {
              "name": "string.unquoted.heredoc.delimiter.flexera-pt"
            }
          },
          "end": "^\\s*(EOS|EOF)\\s*$",
          "endCaptures": {
            "1": {
              "name": "string.unquoted.heredoc.delimiter.flexera-pt"
            }
          }
        }
      ]
    },
    "javascript-embedded": {
      "patterns": [
        {
          "begin": "\\b(code)\\b\\s+(<<-(?:'(?:EOS|EOF|JS)'|(?:EOS|EOF|JS)))",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.flexera-pt"
            },
            "2": {
              "name": "string.unquoted.heredoc.flexera-pt"
            }
          },
          "end": "^\\s*(EOS|EOF|JS)\\s*$",
          "endCaptures": {
            "1": {
              "name": "string.unquoted.heredoc.flexera-pt"
            }
          },
          "contentName": "meta.embedded.block.javascript",
          "patterns": [
            {
              "include": "source.js"
            }
          ]
        },
        {
          "begin": "\\b(code)\\b\\s+(')",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.flexera-pt"
            },
            "2": {
              "name": "punctuation.definition.string.begin.flexera-pt"
            }
          },
          "end": "(')",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.flexera-pt"
            }
          },
          "contentName": "meta.embedded.inline.javascript",
          "patterns": [
            {
              "include": "source.js"
            }
          ]
        }
      ]
    },
    "template-expressions": {
      "patterns": [
        {
          "name": "meta.template.expression.flexera-pt",
          "begin": "\\{\\{",
          "end": "\\}\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template.begin.flexera-pt"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template.end.flexera-pt"
            }
          },
          "patterns": [
            {
              "name": "keyword.control.template.flexera-pt",
              "match": "\\b(with|index|len|if|else|range)\\b"
            },
            {
              "name": "variable.other.template.flexera-pt",
              "match": "\\b(data|parameters|item|col_item)\\b"
            },
            {
              "name": "support.function.template.flexera-pt",
              "match": "\\.\\w+"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.flexera-pt",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.flexera-pt"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.flexera-pt"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.flexera-pt",
              "match": "\\\\."
            },
            {
              "include": "#template-expressions"
            }
          ]
        },
        {
          "name": "string.quoted.single.flexera-pt",
          "begin": "'",
          "end": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.flexera-pt"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.flexera-pt"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.flexera-pt",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.flexera-pt",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "builtin-variables": {
      "patterns": [
        {
          "name": "variable.language.runtime.flexera-pt",
          "match": "\\b(rs_optima_host|rs_org_id|rs_org_name|rs_project_id|rs_project_name|rs_governance_host|rs_ss_host|f1_app_host|meta_parent_policy_id|policy_id)\\b"
        },
        {
          "name": "variable.language.implicit.flexera-pt",
          "match": "\\b(response|iter_item|col_item|item|data)\\b"
        }
      ]
    },
    "dsl-variables": {
      "patterns": [
        {
          "name": "variable.parameter.flexera-pt",
          "match": "\\$(param_|auth_|ds_|js_|pol_|esc_|res_|pagination_)[a-z0-9_]*"
        },
        {
          "name": "variable.language.special.flexera-pt",
          "match": "\\$_error(?:_behavior)?\\b|\\$data\\b"
        },
        {
          "name": "variable.language.global.flexera-pt",
          "match": "\\$\\$[a-z_][a-z0-9_]*"
        },
        {
          "name": "variable.other.flexera-pt",
          "match": "\\$[a-z_][a-z0-9_]*"
        }
      ]
    },
    "dsl-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.flexera-pt",
          "match": "\\b(jmes_path|xpath|join|val|eq|ne|lt|gt|gte|lte|ge|le|contains|size|split|first|last|get|switch|to_n|to_s|to_json|inspect|logic_and|logic_or|logic_not|type|run_script)\\b"
        },
        {
          "name": "entity.name.function.flexera-pt",
          "match": "\\b[a-z_][a-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.flexera-pt",
          "match": "(=>|=~|!~|<<|\\$|@|\\|\\||&&|==|!=|<=|>=|<|>|\\+|-|\\*|/|%|=)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.flexera-pt",
          "match": "\\b(true|false|null|nil)\\b"
        }
      ]
    }
  }
}
