name "Kubernetes - Rightsizing Recommendations"
rs_pt_ver 20180301
type "policy"
short_description "Get rightsizing recommendations for Kubernetes clusters. See the [README](https://github.com/flexera-public/policy_templates/tree/master/cost/flexera/spot/ocean_recommendations/) and [docs.flexera.com/flexera/EN/Automation](https://docs.flexera.com/flexera/EN/Automation/AutomationGS.htm) to learn more."
long_description ""
doc_link "https://github.com/flexera-public/policy_templates/tree/master/cost/flexera/spot/ocean_recommendations/"
category "Operational"
severity "low"
default_frequency "daily"
info(
  version: "0.3.0",
  provider: "Flexera",
  service: "Container Cost Visibility",
  policy_set: "Rightsize Containers",
  recommendation_type: "Usage Reduction",
  hide_skip_approvals: "true"
)

###############################################################################
# Parameters
###############################################################################

parameter "param_email" do
  type "list"
  category "Policy Settings"
  label "Email Addresses"
  description "Email addresses of the recipients you wish to notify when new incidents are created"
  default []
end

# Optional include recommendations because request and cpu memory are not defined
parameter "param_include_recommendations_request_undefined" do
  type "string"
  category "Recommendations"
  label "Include Recommendations with Request Undefined"
  description "Include recommendations where the requested CPU and Memory are not defined."
  allowed_values "Yes", "No"
  default "No"
end

parameter "param_min_savings" do
  type "number"
  category "Policy Settings"
  label "Minimum Savings Threshold"
  description "Minimum potential savings required to generate a recommendation. This is based on the value of the 'Estimated Monthly Savings' field."
  min_value 0
  default 0
end

parameter "param_spotinst_accounts_allow_or_deny" do
  type "string"
  category "Filters"
  label "Allow/Deny Spot Accounts"
  description "Allow or Deny entered Spot Accounts. See the README for more details"
  allowed_values "Allow", "Deny"
  default "Allow"
end

parameter "param_spotinst_accounts_list" do
  type "list"
  category "Filters"
  label "Allow/Deny Spot Accounts List"
  description "A list of allowed or denied Spot Accounts. See the README for more details"
  default []
end

###############################################################################
# Authentication
###############################################################################

credentials "auth_flexera" do
  schemes "oauth2"
  label "Flexera"
  description "Select Flexera One OAuth2 credentials"
  tags "provider=flexera"
end

credentials "auth_spotinst" do
  schemes "api_key"
  label "SpotInst"
  description "Select the SpotInst Credential from the list."
  tags "provider=spotinst"
end

###############################################################################
# Datasources & Scripts
###############################################################################

# Get region-specific Flexera API endpoints
datasource "ds_flexera_api_hosts" do
  run_script $js_flexera_api_hosts, rs_optima_host
end

script "js_flexera_api_hosts", type: "javascript" do
  parameters "rs_optima_host"
  result "result"
  code <<-'EOS'
  host_table = {
    "api.optima.flexeraeng.com": {
      api: "api.flexera.com",
      flexera: "api.flexera.com",
      fsm: "api.fsm.flexeraeng.com",
      grs: "grs-front.iam-us-east-1.flexeraeng.com",
      ui: "app.flexera.com",
      tld: "flexera.com"
    },
    "api.optima-eu.flexeraeng.com": {
      api: "api.flexera.eu",
      flexera: "api.flexera.eu",
      fsm: "api.fsm-eu.flexeraeng.com",
      grs: "grs-front.eu-central-1.iam-eu.flexeraeng.com",
      ui: "app.flexera.eu",
      tld: "flexera.eu"
    },
    "api.optima-apac.flexeraeng.com": {
      api: "api.flexera.au",
      flexera: "api.flexera.au",
      fsm: "api.fsm-apac.flexeraeng.com",
      grs: "grs-front.ap-southeast-2.iam-apac.flexeraeng.com",
      ui: "app.flexera.au",
      tld: "flexera.au"
    }
  }

  result = host_table[rs_optima_host]
EOS
end

# Get applied policy metadata for use later
datasource "ds_applied_policy" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies", switch(policy_id, join(["/", policy_id]), "")])
  end
end

datasource "ds_currency_reference" do
  request do
    host "raw.githubusercontent.com"
    path "/flexera-public/policy_templates/master/data/currency/currency_reference.json"
    header "User-Agent", "RS Policies"
  end
end

datasource "ds_currency_code" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/bill-analysis/orgs/", rs_org_id, "/settings/currency_code"])
    header "Api-Version", "0.1"
    header "User-Agent", "RS Policies"
    ignore_status [403]
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
    field "value", jmes_path(response, "value")
  end
end

datasource "ds_currency" do
  run_script $js_currency, $ds_currency_reference, $ds_currency_code
end

script "js_currency", type:"javascript" do
  parameters "ds_currency_reference", "ds_currency_code"
  result "result"
  code <<-'EOS'
  symbol = "$"
  separator = ","

  if (ds_currency_code['value'] != undefined) {
    if (ds_currency_reference[ds_currency_code['value']] != undefined) {
      symbol = ds_currency_reference[ds_currency_code['value']]['symbol']

      if (ds_currency_reference[ds_currency_code['value']]['t_separator'] != undefined) {
        separator = ds_currency_reference[ds_currency_code['value']]['t_separator']
      } else {
        separator = ""
      }
    }
  }

  result = {
    symbol: symbol,
    separator: separator
  }
EOS
end

# https://api.spotinst.io/setup/account
# Docs: https://docs.spot.io/api/#tag/Accounts/operation/OrganizationsAndAccountsGetAccounts
datasource "ds_spotinst_accounts" do
  request do
    auth $auth_spotinst
    host "api.spotinst.io"
    path "/setup/account"
  end
  result do
    encoding "json"
    collect jq(response, ".response.items[]") do
      # response field
      field "account", jq(col_item, ".")
    end
  end
end

datasource "ds_spotinst_accounts_filtered" do
  run_script $js_spotinst_accounts_filtered, $ds_spotinst_accounts, $param_spotinst_accounts_allow_or_deny, $param_spotinst_accounts_list
end

script "js_spotinst_accounts_filtered", type: "javascript" do
  parameters "ds_spotinst_accounts", "param_spotinst_accounts_allow_or_deny", "param_spotinst_accounts_list"
  result "result"
  code <<-'EOS'
  if (param_spotinst_accounts_list.length > 0) {
    result = _.filter(ds_spotinst_accounts, function(subscription) {
      include = _.contains(param_spotinst_accounts_list, subscription['account']['accountId']) || _.contains(param_spotinst_accounts_list, subscription['account']['name'])

      if (param_spotinst_accounts_allow_or_deny == "Deny") {
        include = include
      }

      return include
    })
  } else {
    result = ds_spotinst_accounts
  }
EOS
end

datasource "ds_spotinst_clusters" do
  iterate $ds_spotinst_accounts_filtered
  request do
    run_script $js_spotinst_clusters, val(iter_item, "account")
  end
  result do
    encoding "json"
    collect jq(response, ".response.items[]") do
      # iteration fields
      field "account", jq(iter_item, ".account")
      # response field
      field "cluster", jq(col_item, ".")
    end
  end
end

script "js_spotinst_clusters", type: "javascript" do
  parameters "spot_inst_account"
  result "request"
  code <<-'EOS'
    host = "api.spotinst.io"
    path = "/ocean/aws/k8s/cluster"

    if (spot_inst_account.cloudProvider == "AZURE") {
      path = "/ocean/azure/np/cluster"
    } else if (spot_inst_account.cloudProvider == "GCP") {
      path = "/ocean/gcp/k8s/cluster"
    }

    request = {
      auth: "auth_spotinst",
      host: host,
      path: path,
      query_params: {
        'accountId': spot_inst_account.accountId
      }
    }
  EOS
end

datasource "ds_spotinst_clusters_rightsizing_suggestions" do
  iterate $ds_spotinst_clusters
  request do
    run_script $js_spotinst_clusters_rightsizing_suggestions, val(iter_item, "cluster"), val(iter_item, "account")
  end
  result do
    encoding "json"
    collect jmes_path(response, "response.items[*].recommendations[*]") do
      # iteration fields
      field "account", jq(iter_item, ".account")
      field "cluster", jq(iter_item, ".cluster")
      # response field
      field "suggestions", jq(col_item, ".")
    end
  end
end

script "js_spotinst_clusters_rightsizing_suggestions", type: "javascript" do
  parameters "spotinst_cluster", "spotinst_account"
  result "request"
  code <<-'EOS'
    host = "api.spotinst.io"
    path = (["/ocean/", spotinst_cluster.id, "/rightSizing/recommendations"]).join("")

    request = {
      verb: "POST",
      auth: "auth_spotinst",
      host: host,
      path: path,
      query_params: {
        'accountId': spotinst_account.accountId
      },
      body_fields: {
        "clusterResources": {} // Empty object to get all resources in the cluster
      }
    }
  EOS
end

# Filter out suggestions based on used input parameters
datasource "ds_spotinst_clusters_rightsizing_suggestions_filtered" do
  run_script $js_spotinst_clusters_rightsizing_suggestions_filtered, $ds_spotinst_clusters_rightsizing_suggestions, $param_include_recommendations_request_undefined, $param_min_savings
end

script "js_spotinst_clusters_rightsizing_suggestions_filtered", type: "javascript" do
  parameters "ds_spotinst_clusters_rightsizing_suggestions", "param_include_recommendations_request_undefined", "param_min_savings"
  result "result"
  code <<-'EOS'
  suggestions = []
  _.each(ds_spotinst_clusters_rightsizing_suggestions, function(suggestion_list) {
    // Check if we have at least one suggestion in the list for this cluster
    if (suggestion_list.suggestions && _.isArray(suggestion_list.suggestions) && (suggestion_list.suggestions.length > 0)) {
      // Iterate through suggestions
      _.each(suggestion_list.suggestions, function(suggestion) {
        // Add each suggestion to suggestions list
        suggestions.push({
          account: suggestion_list.account,
          cluster: suggestion_list.cluster,
          suggestion: suggestion
        })
      })
    }
  })
  result = _.filter(suggestions, function(suggestion) {
    // Should include if:
    // param_include_recommendations_request_undefined == "Yes"
    // OR
    // requestedCpu > 0
    // OR
    // requestedMemory > 0
    return (param_include_recommendations_request_undefined == "Yes" || suggestion.suggestion.requestedCpu > 0 || suggestion.suggestion.requestedMemory > 0) && (suggestion.suggestion.monthlyMaxSavings >= param_min_savings);
  })
EOS
end

datasource "ds_date_periods" do
  run_script $js_date_periods
end

script "js_date_periods", type: "javascript" do
  result "result"
  code <<-'EOS'
  var result = []

  // Get all the day periods for today to 30 days ago
  // End date is 1 day after the start date
  var today = new Date();
  today.setHours(0, 0, 0, 0);
  for (var i = 0; i < 30; i++) {
    var start_date = new Date(today)
    start_date.setDate(today.getDate() - i)
    var end_date = new Date(start_date)
    end_date.setDate(start_date.getDate() + 1)
    // 2024-12-02 00:00:00.000

    result.push({
      // ISO Date String Example: 2024-12-02T00:00:00.000Z
      start_date: start_date.toISOString().replace("T"," ").replace("Z",""),
      end_date: end_date.toISOString().replace("T"," ").replace("Z",""),
    });
  }
EOS
end

# Add this new datasource before the policy block
datasource "ds_report" do
  run_script $js_report, $ds_spotinst_clusters_rightsizing_suggestions_filtered, $ds_applied_policy, $ds_currency, $param_min_savings
end

script "js_report", type: "javascript" do
  parameters "ds_spotinst_clusters_rightsizing_suggestions_filtered", "ds_applied_policy", "ds_currency", "param_min_savings"
  result "result"
  code <<-'EOS'
  function properCase(value) {
    if (!value || !_.isString(value)) {
      return "";
    }
    // Capitalize the first letter of each word
    var words = value.split(" ");
    var properWords = [];
    _.each(words, function(word) {
      if (!word) {
        return;
      }
      properWords.push(word.charAt(0).toUpperCase() + word.slice(1));
    });
    return properWords.join(" ");
  }

  function getNumber(value, defaultValue) {
    if (_.isNumber(value) && !isNaN(value)) {
      return value;
    }

    // Attempt basic number parsing when schema changes send strings
    if (_.isString(value)) {
      var parsed = parseFloat(value);
      if (!isNaN(parsed)) {
        return parsed;
      }
    }

    return _.isNumber(defaultValue) ? defaultValue : 0;
  }

  function getCurrencySettings(ds_currency) {
    var currency = ds_currency;
    if (!currency || !_.isObject(currency)) {
      currency = {};
    }

    // `ds_currency` returns { symbol: "£", separator: "," } (separator is thousands separator)
    if (!currency.symbol || !_.isString(currency.symbol)) {
      currency.symbol = "$";
    }
    if (currency.separator == null || !_.isString(currency.separator)) {
      currency.separator = ",";
    }

    return currency;
  }

  function formatCurrency(value, currency) {
    var number = getNumber(value, 0);
    var negative = number < 0;
    var abs = Math.abs(number);

    // Keep a consistent 2-decimal currency format for readability.
    var fixed = abs.toFixed(2);
    var parts = fixed.split(".");
    var intPart = parts[0] || "0";
    var decPart = parts[1] || "00";

    var separator = (currency && _.isString(currency.separator)) ? currency.separator : ",";
    if (separator && separator.length > 0) {
      var formattedInt = "";
      var digitsProcessed = 0;
      for (var i = intPart.length - 1; i >= 0; i--) {
        formattedInt = intPart.charAt(i) + formattedInt;
        digitsProcessed += 1;
        if ((digitsProcessed % 3) === 0 && i !== 0) {
          formattedInt = separator + formattedInt;
        }
      }
      intPart = formattedInt;
    }

    var symbol = (currency && _.isString(currency.symbol)) ? currency.symbol : "$";
    var formatted = symbol + intPart + "." + decPart;
    if (negative) {
      formatted = "-" + formatted;
    }
    return formatted;
  }

  function getClusterRegion(cluster) {
    if (!cluster) {
      return "";
    }

    // Some providers return region at the top-level, others nest it.
    if (cluster.region) {
      return cluster.region;
    }
    if (cluster.aks && cluster.aks.region) {
      return cluster.aks.region;
    }
    if (cluster.aws && cluster.aws.region) {
      return cluster.aws.region;
    }
    if (cluster.gke && (cluster.gke.region || cluster.gke.location)) {
      return cluster.gke.region || cluster.gke.location;
    }
    if (cluster.gcp && (cluster.gcp.region || cluster.gcp.location)) {
      return cluster.gcp.region || cluster.gcp.location;
    }

    return "";
  }

  // Spot schema can change; support several known/likely paths.
  // The policy exports `estimatedSavings` which should represent the estimated *monthly* savings.
  function getMonthlyMaxSavings(item) {
    if (!item) {
      return 0;
    }

    // Current/expected schema: item.suggestion.monthlyMaxSavings
    if (item.suggestion && item.suggestion.monthlyMaxSavings != null) {
      return getNumber(item.suggestion.monthlyMaxSavings, 0);
    }

    // Possible schema variant: item.monthlyMaxSavings
    if (item.monthlyMaxSavings != null) {
      return getNumber(item.monthlyMaxSavings, 0);
    }

    // Legacy-ish variant: item.suggestion.estimatedSavings
    if (item.suggestion && item.suggestion.estimatedSavings != null) {
      return getNumber(item.suggestion.estimatedSavings, 0);
    }

    return 0;
  }

  function normalizeContainers(containers) {
    var list = [];
    _.each(containers || [], function(container) {
      if (!container) {
        return;
      }

      list.push({
        name: container.name || container.containerName || "",
        requestedCpu: getNumber(container.requestedCpu, 0),
        suggestedCpu: getNumber(container.suggestedCpu, 0),
        requestedMemory: getNumber(container.requestedMemory, 0),
        suggestedMemory: getNumber(container.suggestedMemory, 0)
      });
    });
    return list;
  }

  function roundNumber(value, decimals) {
    var number = getNumber(value, 0);
    var places = _.isNumber(decimals) ? decimals : 2;
    var factor = Math.pow(10, places);
    return Math.round(number * factor) / factor;
  }

  function cpuToK8sString(cpuCores) {
    var cpu = getNumber(cpuCores, 0);
    if (cpu <= 0) {
      return "<cpu>";
    }

    // Prefer millicores for fractional CPUs.
    if (cpu < 1) {
      return Math.round(cpu * 1000) + "m";
    }

    // Keep integer CPUs clean; otherwise keep as-is.
    if ((cpu % 1) === 0) {
      return "" + cpu;
    }

    return "" + cpu;
  }

  function memoryMiToK8sString(memoryMi) {
    var memory = getNumber(memoryMi, 0);
    if (memory <= 0) {
      return "<memoryMi>Mi";
    }
    if ((memory % 1) === 0) {
      return "" + memory + "Mi";
    }
    return roundNumber(memory, 2) + "Mi";
  }

  function getDimensionStatus(requested, suggested) {
    var req = getNumber(requested, 0);
    var sug = getNumber(suggested, 0);

    if (req <= 0 && sug <= 0) {
      return "Unknown";
    }
    if (sug > req) {
      return "Underprovisioned";
    }
    if (sug < req) {
      return "Overprovisioned";
    }
    return "Right-sized";
  }

  function getOverallRightsizingStatus(cpuStatus, memoryStatus) {
    // Requirement: clearly state Underprovisioned, Overprovisioned, or Needs Rightsizing.
    // Map anything mixed/unknown into "Needs Rightsizing".
    if (cpuStatus === "Underprovisioned" && memoryStatus === "Underprovisioned") {
      return "Underprovisioned";
    }
    if (cpuStatus === "Overprovisioned" && memoryStatus === "Overprovisioned") {
      return "Overprovisioned";
    }
    if (cpuStatus === "Right-sized" && memoryStatus === "Right-sized") {
      // Still a rightsizing recommendation entry, but no net change; treat as mixed.
      return "Needs Rightsizing";
    }
    return "Needs Rightsizing";
  }

  function buildRequestsYamlSnippet(containerName, cpuRequest, memoryRequestMi) {
    var safeName = containerName || "<container-name>";
    var cpu = cpuToK8sString(cpuRequest);
    var mem = memoryMiToK8sString(memoryRequestMi);

    return [
      "```yaml",
      "# Example: update the Container resource requests",
      "containers:",
      "  - name: " + safeName,
      "    resources:",
      "      requests:",
      "        cpu: \"" + cpu + "\"",
      "        memory: \"" + mem + "\"",
      "```"
    ].join("\n");
  }

  function buildBeforeAfterTable(requestedCpu, suggestedCpu, requestedMemory, suggestedMemory) {
    var cpuBefore = getNumber(requestedCpu, 0);
    var cpuAfter = getNumber(suggestedCpu, 0);
    var memBefore = getNumber(requestedMemory, 0);
    var memAfter = getNumber(suggestedMemory, 0);

    var cpuBeforeStr = cpuToK8sString(roundNumber(cpuBefore, 3));
    var cpuAfterStr = cpuToK8sString(roundNumber(cpuAfter, 3));
    var memBeforeStr = memoryMiToK8sString(roundNumber(memBefore, 2));
    var memAfterStr = memoryMiToK8sString(roundNumber(memAfter, 2));

    function padRight(str, len) {
      var s = (str == null) ? "" : ("" + str);
      while (s.length < len) {
        s = s + " ";
      }
      return s;
    }

    function repeat(ch, count) {
      var s = "";
      for (var i = 0; i < count; i++) {
        s = s + ch;
      }
      return s;
    }

    function buildAsciiTable(rows) {
      // rows: array of { spec: string, current: string, suggested: string }
      var headers = { spec: "Spec", current: "Current", suggested: "Suggested" };
      var all = [headers].concat(rows);

      var specW = 0;
      var curW = 0;
      var sugW = 0;

      _.each(all, function(r) {
        specW = Math.max(specW, (r.spec || "").length);
        curW = Math.max(curW, (r.current || "").length);
        sugW = Math.max(sugW, (r.suggested || "").length);
      });

      var line = "+" + repeat("-", specW + 2) + "+" + repeat("-", curW + 2) + "+" + repeat("-", sugW + 2) + "+";
      var out = [];
      out.push(line);
      out.push("| " + padRight(headers.spec, specW) + " | " + padRight(headers.current, curW) + " | " + padRight(headers.suggested, sugW) + " |");
      out.push(line);
      _.each(rows, function(r) {
        out.push("| " + padRight(r.spec, specW) + " | " + padRight(r.current, curW) + " | " + padRight(r.suggested, sugW) + " |");
      });
      out.push(line);
      return out.join("\n");
    }

    var markdownTable = [
      "| Spec | Current | Suggested |",
      "|------|---------|-----------|",
      "| CPU request | `" + cpuBeforeStr + "` | `" + cpuAfterStr + "` |",
      "| Memory request | `" + memBeforeStr + "` | `" + memAfterStr + "` |"
    ].join("\n");

    var asciiTable = buildAsciiTable([
      { spec: "CPU request", current: cpuBeforeStr, suggested: cpuAfterStr },
      { spec: "Memory request", current: memBeforeStr, suggested: memAfterStr }
    ]);

    return [
      // "**Markdown table**",
      // "",
      // markdownTable,
      // "",
      // "**Monospace (ASCII) table**",
      // "",
      "```text",
      asciiTable,
      "```"
    ].join("\n\n");
  }

  function buildContainersTable(containers) {
    function padRight(str, len) {
      var s = (str == null) ? "" : ("" + str);
      while (s.length < len) {
        s = s + " ";
      }
      return s;
    }

    function repeat(ch, count) {
      var s = "";
      for (var i = 0; i < count; i++) {
        s = s + ch;
      }
      return s;
    }

    function buildAsciiTable(rows) {
      // rows: array of { container: string, cpu: string, memory: string }
      var headers = {
        container: "Container",
        cpu: "CPU request",
        memory: "Memory request"
      };
      var all = [headers].concat(rows);

      var containerW = 0;
      var cpuW = 0;
      var memW = 0;

      _.each(all, function(r) {
        containerW = Math.max(containerW, (r.container || "").length);
        cpuW = Math.max(cpuW, (r.cpu || "").length);
        memW = Math.max(memW, (r.memory || "").length);
      });

      var line = "+" + repeat("-", containerW + 2) + "+" + repeat("-", cpuW + 2) + "+" + repeat("-", memW + 2) + "+";
      var out = [];
      out.push(line);
      out.push("| " + padRight(headers.container, containerW) + " | " + padRight(headers.cpu, cpuW) + " | " + padRight(headers.memory, memW) + " |");
      out.push(line);
      _.each(rows, function(r) {
        out.push("| " + padRight(r.container, containerW) + " | " + padRight(r.cpu, cpuW) + " | " + padRight(r.memory, memW) + " |");
      });
      out.push(line);
      return out.join("\n");
    }

    var markdownLines = [];
    markdownLines.push("| Container | CPU request | Memory request |");
    markdownLines.push("|-----------|-------------|----------------|");

    var asciiRows = [];

    _.each(containers || [], function(container) {
      var name = container.name || "";
      var cpuBeforeStr = cpuToK8sString(roundNumber(container.requestedCpu, 3));
      var cpuAfterStr = cpuToK8sString(roundNumber(container.suggestedCpu, 3));
      var memBeforeStr = memoryMiToK8sString(roundNumber(container.requestedMemory, 2));
      var memAfterStr = memoryMiToK8sString(roundNumber(container.suggestedMemory, 2));

      markdownLines.push("| " + name + " | `" + cpuBeforeStr + "` → `" + cpuAfterStr + "` | `" + memBeforeStr + "` → `" + memAfterStr + "` |");

      asciiRows.push({
        container: name,
        cpu: cpuBeforeStr + " -> " + cpuAfterStr,
        memory: memBeforeStr + " -> " + memAfterStr
      });
    });

    var markdownTable = markdownLines.join("\n");
    var asciiTable = buildAsciiTable(asciiRows);

    return [
      // "**Markdown table**",
      // "",
      // markdownTable,
      // "",
      // "**Monospace (ASCII) table**",
      // "",
      "```text",
      asciiTable,
      "```"
    ].join("\n\n");
  }

  function enrichSuggestions(rawSuggestions) {
    var result = [];

    _.each(rawSuggestions || [], function(item) {
      var account = item.account || {};
      var cluster = item.cluster || {};
      var suggestion = item.suggestion || {};

      var region = getClusterRegion(cluster);
      if (!cluster.region && region) {
        // Backfill a normalized region field for export paths like `cluster.region`
        cluster.region = region;
      }

      var clusterName = cluster.name || cluster.id || "unknown-cluster";
      var resourceId = _.compact([
        account.providerExternalId || account.accountId || "",
        region || "",
        clusterName || "",
        suggestion.namespace || "",
        suggestion.workloadType || "",
        suggestion.workloadName || ""
      ]).join("/").toLowerCase();

      if (!resourceId) {
        resourceId = _.compact([account.accountId || "unknown-account", cluster.id || clusterName]).join("/").toLowerCase();
      }

      var requestedCpu = getNumber(suggestion.requestedCpu, 0);
      var suggestedCpu = getNumber(suggestion.suggestedCpu, 0);
      var requestedMemory = getNumber(suggestion.requestedMemory, 0);
      var suggestedMemory = getNumber(suggestion.suggestedMemory, 0);

      var estimatedSavings = getMonthlyMaxSavings(item);
      var cpuPercentChange = requestedCpu > 0 ? ((requestedCpu - suggestedCpu) / requestedCpu) : 0;
      var memoryPercentChange = requestedMemory > 0 ? ((requestedMemory - suggestedMemory) / requestedMemory) : 0;

      // Keep the existing approach: split the estimated savings proportionally between CPU and Memory,
      // then divide by 2 so CPU+Memory approximately equals the total monthly savings.
      var estimatedCpuSavings = (estimatedSavings * cpuPercentChange) / 2;
      var estimatedMemorySavings = (estimatedSavings * memoryPercentChange) / 2;

      var containers = suggestion.containers || [];

      var enriched = {
        account: account,
        cluster: cluster,
        suggestion: suggestion,
        service: "Kubernetes",
        resourceId: resourceId,
        workloadRef: _.compact([suggestion.workloadType, suggestion.workloadName]).join("/"), // Provide a WorkloadType/WorkloadName reference
        estimatedSavings: estimatedSavings,
        estimatedCpuSavings: estimatedCpuSavings,
        estimatedMemorySavings: estimatedMemorySavings,
        suggestion_containers: _.map(containers, function(container) {
          return JSON.stringify(container);
        }),
        tags: [],
        normalizedContainers: normalizeContainers(containers)
      };

      var cpuStatus = getDimensionStatus(requestedCpu, suggestedCpu);
      var memoryStatus = getDimensionStatus(requestedMemory, suggestedMemory);
      var overallStatus = getOverallRightsizingStatus(cpuStatus, memoryStatus);

      var workloadLabel = properCase(suggestion.workloadType || "") + "/" + (suggestion.workloadName || "");
      var clusterLabel = (cluster.name || cluster.id || "");
      var namespaceLabel = (suggestion.namespace || "");
      var docsUrl = "https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/";

      var normalizedContainers = normalizeContainers(containers);
      var yamlContainerName = (normalizedContainers.length === 1 && normalizedContainers[0].name) ? normalizedContainers[0].name : "<container-name>";
      var yamlCpu = (normalizedContainers.length === 1) ? normalizedContainers[0].suggestedCpu : suggestedCpu;
      var yamlMemory = (normalizedContainers.length === 1) ? normalizedContainers[0].suggestedMemory : suggestedMemory;

      var details = [];
      details.push("**Update the " + workloadLabel + " container `resources.requests` specification to the suggested values. This helps requests better match actual usage and can reduce waste in the cluster by requesting only what is needed.**");
      details.push("");
      details.push("**Workload:** `" + workloadLabel + "`");
      details.push("**Namespace:** `" + namespaceLabel + "`");
      details.push("**Cluster:** `" + clusterLabel + "`" + (cluster.region ? " (" + cluster.region + ")" : ""));
      details.push("");
      details.push("**Rightsizing status:** **" + overallStatus + "**  ");
      details.push("CPU: " + cpuStatus + " · Memory: " + memoryStatus);
      details.push("");

      details.push("");
      details.push("Docs: [Kubernetes - Resource requests and limits](" + docsUrl + ")");
      details.push("");
      details.push("#### Before → After (workload-level)");
      details.push("");
      details.push(buildBeforeAfterTable(requestedCpu, suggestedCpu, requestedMemory, suggestedMemory));
      details.push("");

      if (normalizedContainers.length > 0) {
        details.push("#### Before → After (container-level)");
        details.push("");
        details.push(buildContainersTable(normalizedContainers));
        details.push("");
      }

      details.push("#### Example YAML snippet");
      details.push("");
      details.push(buildRequestsYamlSnippet(yamlContainerName, yamlCpu, yamlMemory));

      if ((requestedCpu <= 0 && suggestedCpu > 0) || (requestedMemory <= 0 && suggestedMemory > 0)) {
        details.push("");
        details.push("_Note: the current request spec for CPU and/or Memory is missing or reported as `0`. In that case, apply the suggested values and verify them against workload behavior and SLOs._");
      }

      enriched.recommendationDetails = details.join("\n\n");

      // Also attach to the nested suggestion object for convenience (some older code expects these there).
      suggestion.estimatedSavings = estimatedSavings;
      suggestion.estimatedCpuSavings = estimatedCpuSavings;
      suggestion.estimatedMemorySavings = estimatedMemorySavings;

      result.push(enriched);
    });

    return result;
  }

  // Calculate all metrics and organize data
  function calculateMetrics(suggestions) {
    var metrics = {
      clusters: {},
      globalCpuSavings: 0,
      globalCpuCostSavings: 0,
      globalMemorySavings: 0,
      globalMemoryCostSavings: 0,
      globalEstimatedSavings: 0,
      globalUnderprovisioned: 0,
      globalOverprovisioned: 0
    };

    _.each(suggestions || [], function(item) {
      var clusterName = (item.cluster && item.cluster.name) ? item.cluster.name : ((item.cluster && item.cluster.id) ? item.cluster.id : "unknown-cluster");
      var region = (item.cluster && item.cluster.region) ? item.cluster.region : "";

      var clusterKey = clusterName;
      if (region) {
        clusterKey = clusterName + " (" + region + ")";
      }

      if (!metrics.clusters[clusterKey]) {
        metrics.clusters[clusterKey] = {
          items: [],
          cpuSavings: 0,
          cpuCostSavings: 0,
          memorySavings: 0,
          memoryCostSavings: 0,
          estimatedSavings: 0,
          underprovisioned: 0,
          overprovisioned: 0,
          account: item.account,
          cluster: item.cluster,
          namespaces: {}
        };
      }

      metrics.clusters[clusterKey].items.push(item);

      var requestedCpu = getNumber(item.suggestion && item.suggestion.requestedCpu, 0);
      var suggestedCpu = getNumber(item.suggestion && item.suggestion.suggestedCpu, 0);
      var requestedMemory = getNumber(item.suggestion && item.suggestion.requestedMemory, 0);
      var suggestedMemory = getNumber(item.suggestion && item.suggestion.suggestedMemory, 0);

      var cpuSavings = requestedCpu - suggestedCpu;
      var memorySavings = requestedMemory - suggestedMemory;

      metrics.clusters[clusterKey].cpuSavings += cpuSavings;
      metrics.clusters[clusterKey].memorySavings += memorySavings;
      metrics.globalCpuSavings += cpuSavings;
      metrics.globalMemorySavings += memorySavings;

      metrics.clusters[clusterKey].cpuCostSavings += getNumber(item.estimatedCpuSavings, 0);
      metrics.clusters[clusterKey].memoryCostSavings += getNumber(item.estimatedMemorySavings, 0);
      metrics.globalCpuCostSavings += getNumber(item.estimatedCpuSavings, 0);
      metrics.globalMemoryCostSavings += getNumber(item.estimatedMemorySavings, 0);

      metrics.clusters[clusterKey].estimatedSavings += getNumber(item.estimatedSavings, 0);
      metrics.globalEstimatedSavings += getNumber(item.estimatedSavings, 0);

      // Classify under/over-provisioned based on whether requested is below/above suggested.
      // We use the sign of (cpuSavings + memorySavings) to preserve previous behavior.
      if ((cpuSavings + memorySavings) < 0) {
        metrics.globalUnderprovisioned += 1;
        metrics.clusters[clusterKey].underprovisioned += 1;
      } else if ((cpuSavings + memorySavings) > 0) {
        metrics.globalOverprovisioned += 1;
        metrics.clusters[clusterKey].overprovisioned += 1;
      }

      // Group by namespace
      var ns = (item.suggestion && item.suggestion.namespace) ? item.suggestion.namespace : "unknown";
      if (!metrics.clusters[clusterKey].namespaces[ns]) {
        metrics.clusters[clusterKey].namespaces[ns] = [];
      }
      metrics.clusters[clusterKey].namespaces[ns].push(item);
    });

    return metrics;
  }

  function generateReport(metrics, currency) {
    var report = [];

    report.push("# Kubernetes Rightsizing Recommendations Report\n");
    report.push("## Global Summary");
    report.push("* Total Estimated Monthly Savings: " + formatCurrency(metrics.globalEstimatedSavings || 0, currency) + "\n");

    report.push("* Minimum Savings Threshold: " + formatCurrency(getNumber(param_min_savings, 0), currency));

    report.push("* Total CPU Savings: " + (Math.round((metrics.globalCpuSavings || 0) * 100) / 100) + " cores");
    report.push("* Estimated CPU Savings Portion: " + formatCurrency(metrics.globalCpuCostSavings || 0, currency));
    report.push("* Total Memory Savings: " + (Math.round((metrics.globalMemorySavings || 0) * 100) / 100) + " Mi");
    report.push("* Estimated Memory Savings Portion: " + formatCurrency(metrics.globalMemoryCostSavings || 0, currency));
    report.push("* Total Underprovisioned: " + metrics.globalUnderprovisioned);
    report.push("* Total Overprovisioned: " + metrics.globalOverprovisioned + "\n");

    report.push("\n_Report generated at: " + new Date().toISOString() + "_");

    return report.join("\n");
  }

  // Main execution
  var appliedPolicy = ds_applied_policy;
  if (_.isString(appliedPolicy)) {
    // `fpt script` callers sometimes pass a string; keep the output stable.
    appliedPolicy = { name: appliedPolicy };
  }
  if (!appliedPolicy || !appliedPolicy.name) {
    appliedPolicy = { name: "Kubernetes - Rightsizing Recommendations" };
  }

  var currency = getCurrencySettings(ds_currency);

  var minSavings = getNumber(param_min_savings, 0);
  var enrichedSuggestions = enrichSuggestions(ds_spotinst_clusters_rightsizing_suggestions_filtered);
  var suggestions = _.filter(enrichedSuggestions, function(item) {
    return getNumber(item.estimatedSavings, 0) >= minSavings;
  });
  var metrics = calculateMetrics(suggestions);
  var markdown = generateReport(metrics, currency);

  result = {
    "markdown": markdown,
    "suggestions": suggestions,
    "ds_applied_policy": appliedPolicy,
    "currency": currency
  };
EOS
end

###############################################################################
# Policy
###############################################################################

policy "pol_spot_ocean_recommendation_report" do
  validate $ds_report do
    summary_template '{{ data.ds_applied_policy.name }}'
    detail_template "{{ data.markdown }}"
    check eq(size(val(data, "suggestions")), 0)
    escalate $esc_email
    export "suggestions" do
      resource_level true
      field "savings" do
        label "Estimated Monthly Savings"
        path "estimatedSavings"
      end
      field "vendor" do
        label "Vendor"
        path "account.cloudProvider"
      end
      field "accountID" do
        label "Account ID"
        path "account.providerExternalId"
      end
      field "accountName" do
        label "Account Name"
        path "account.providerExternalId" # TODO Map account name from flexera bill data
      end
      field "region" do
        label "Region"
        path "cluster.region"
      end
      field "service" do
        label "Service"
        path "service"
      end
      field "resourceID" do
        label "Resource ID"
        path "resourceId"
      end
      field "id" do
        label "ID"
        path "resourceId"
      end
      field "recommendationDetails" do
        label "Recommendation"
        path "recommendationDetails"
      end
      field "cluster_cluster_name" do
        label "Cluster Name"
        path "cluster.name"
      end
      field "suggestion_containers" do
        label "Containers"
        path "suggestion_containers"
      end
      field "suggestion_namespace" do
        label "Kubernetes Namespace"
        path "suggestion.namespace"
      end
      field "suggestion_requestedCPU" do
        label "Current Requested CPU Spec"
        path "suggestion.requestedCpu"
      end
      field "suggestion_requestedMemory" do
        label "Current Requested Memory Spec"
        path "suggestion.requestedMemory"
      end
      field "resourceType" do
        label "Resource Type"
        path "suggestion.workloadType"
      end
      field "suggestion_suggestedCPU" do
        label "Suggested CPU Spec"
        path "suggestion.suggestedCpu"
      end
      field "suggestion_suggestedMemory" do
        label "Suggested Memory Spec"
        path "suggestion.suggestedMemory"
      end
      field "resourceName" do
        label "Resource Name"
        path "suggestion.workloadName"
      end
      field "workloadRef" do
        label "Workload Reference"
        path "suggestion.workloadRef"
      end
      field "tags" do
        label "Resource Tags"
        path "tags"
      end
      field "cpuMaximum" do
        label "CPU Maximum %"
        path "suggestion.requestedCpu" # Using requested spec for maximum usage field as that is what is required for k8s scheduler to provision the container
      end
      field "cpuMinimum" do
        label "CPU Minimum %"
        path "suggestion.suggestedCpu"
      end
      field "cpuAverage" do
        label "CPU Average %"
        path "suggestion.suggestedCpu"
      end
      field "cpuP99" do
        label "CPU p99"
        path "suggestion.suggestedCpu"
      end
      field "cpuP95" do
        label "CPU p95"
        path "suggestion.suggestedCpu"
      end
      field "cpuP90" do
        label "CPU p90"
        path "suggestion.suggestedCpu"
      end
      field "memMaximum" do
        label "Memory Maximum %"
        path "suggestion.requestedMemory" # Using requested spec for maximum usage field as that is what is required for k8s scheduler to provision the container
      end
      field "memMinimum" do
        label "Memory Minimum %"
        path "suggestion.suggestedMemory"
      end
      field "memAverage" do
        label "Memory Average %"
        path "suggestion.suggestedMemory"
      end
      field "memP99" do
        label "Memory p99"
        path "suggestion.suggestedMemory"
      end
      field "memP95" do
        label "Memory p95"
        path "suggestion.suggestedMemory"
      end
      field "memP90" do
        label "Memory p90"
        path "suggestion.suggestedMemory"
      end
    end
  end
end

###############################################################################
# Escalations
###############################################################################

escalation "esc_email" do
  automatic true
  label "Send Email"
  description "Send incident email"
  email $param_email
end
