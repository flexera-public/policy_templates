datasource "ds_region_table" do
  run_script $js_region_table, $ds_azure_regions
end

script "js_region_table", type: "javascript" do
  parameters "ds_azure_regions"
  result "result"
  code <<-'EOS'
  result = {}

  // Maps regions.json "name" values to azure_vm_pricing.json region keys
  var name_to_pricing_key = {
    "UAE Central": "AE Central",
    "UAE North": "AE North",
    "East Asia": "AP East",
    "Southeast Asia": "AP Southeast",
    "Australia Central": "AU Central",
    "Australia Central 2": "AU Central 2",
    "Australia East": "AU East",
    "Australia Southeast": "AU Southeast",
    "Brazil South": "BR South",
    "Brazil Southeast": "BR Southeast",
    "Canada Central": "CA Central",
    "Canada East": "CA East",
    "Switzerland North": "CH North",
    "Switzerland West": "CH West",
    "Germany North": "DE North",
    "Germany West Central": "DE West Central",
    "Spain Central": "ES Central",
    "North Europe": "EU North",
    "West Europe": "EU West",
    "France Central": "FR Central",
    "France South": "FR South",
    "Israel Central": "IL Central",
    "Central India": "IN Central",
    "Jio India Central": "IN Central Jio",
    "South India": "IN South",
    "West India": "IN West",
    "Jio India West": "IN West Jio",
    "Italy North": "IT North",
    "Japan East": "JA East",
    "Japan West": "JA West",
    "Korea Central": "KR Central",
    "Korea South": "KR South",
    "Mexico Central": "MX Central",
    "New Zealand North": "NZ North",
    "Norway East": "NO East",
    "Norway West": "NO West",
    "Poland Central": "PL Central",
    "Qatar Central": "QA Central",
    "Sweden Central": "SE Central",
    "South Africa North": "ZA North",
    "South Africa West": "ZA West",
    "UK South": "UK South",
    "UK West": "UK West",
    "Central US": "US Central",
    "East US": "US East",
    "East US 2": "US East 2",
    "North Central US": "US North Central",
    "South Central US": "US South Central",
    "West US": "US West",
    "West US 2": "US West 2",
    "West US 3": "US West 3",
    "West Central US": "US West Central",
    "Austria East": "AT East",
    "Belgium Central": "BE Central",
    "Chile Central": "CL Central",
    "Denmark East": "DK East",
    "Indonesia Central": "ID Central",
    "Malaysia West": "MY West",
    "Sweden South": "SE South",
    "US Gov Arizona": "US Gov AZ",
    "US Gov Iowa": "US Gov Iowa",
    "US Gov Texas": "US Gov TX",
    "US Gov Virginia": "US Gov Virginia"
  }

  _.each(ds_azure_regions, function(item) {
    var pricing_key = name_to_pricing_key[item["name"]]
    if (pricing_key) { result[item["region"]] = pricing_key }
  })
EOS
end

# Main recommendation logic: idle detection and cross-family rightsizing
datasource "ds_idle_and_rightsize_instances" do
  run_script $js_idle_and_rightsize_instances, $ds_azure_instances_metrics_organized, $ds_instance_costs_grouped, $ds_azure_compute_instance_types, $ds_azure_vm_pricing, $ds_azure_available_sizes, $ds_applied_policy, $ds_currency, $ds_flexera_api_hosts, $ds_region_table, $param_stats_lookback, $param_stats_safety_factor, $param_allow_mixed_x86_vendors, $param_min_savings, rs_org_id, rs_project_id
end

script "js_idle_and_rightsize_instances", type: "javascript" do
  parameters "ds_azure_instances_metrics_organized", "ds_instance_costs_grouped", "ds_azure_compute_instance_types", "ds_azure_vm_pricing", "ds_azure_available_sizes", "ds_applied_policy", "ds_currency", "ds_flexera_api_hosts", "ds_region_table", "param_stats_lookback", "param_stats_safety_factor", "param_allow_mixed_x86_vendors", "param_min_savings", "rs_org_id", "rs_project_id"
  result "result"
  code <<-'EOS'
  function formatNumber(number, separator) {
    var formatted_number = "0"

    if (number) {
      formatted_number = (Math.round(number * 100) / 100).toString().split(".")[0]

      if (separator) {
        var withSeparator = ""
        for (var i = 0; i < formatted_number.length; i++) {
          if (i > 0 && (formatted_number.length - i) % 3 == 0) { withSeparator += separator }
          withSeparator += formatted_number[i]
        }
        formatted_number = withSeparator
      }

      var decimal = (Math.round(number * 100) / 100).toString().split(".")[1]
      if (decimal) { formatted_number += "." + decimal }
    }

    return formatted_number
  }

  // Detect AMD instances by checking for 'a' as first letter after the size digits.
  // HB and HC series are AMD EPYC HPC instances and must be detected explicitly because
  // their naming convention (e.g., Standard_HB120rs_v3) does not use the 'a' suffix.
  // Some GPU AMD families (e.g., Standard_NVads_A10_v5, Standard_NGads_V620_v1) have no
  // size digits before the AMD 'a' suffix; the /_[A-Z]+ads_/ pattern covers these.
  function isAMD(instanceName) {
    if (/Standard_H[BC]/i.test(instanceName)) { return true }
    if (/_[A-Z]+ads_/.test(instanceName)) { return true }
    var match = instanceName.match(/_[A-Z]+\d+([a-z])/i)
    if (match && match[1]) { return match[1].toLowerCase() === 'a' }
    return false
  }

  // Tiered idle CPU threshold based on vCPU count — larger instances need less % utilization
  // to constitute "real" usage, so the threshold scales down as core count grows.
  function getIdleCpuThreshold(vcpus) {
    if (vcpus <= 2) { return 5 }
    if (vcpus <= 4) { return 4 }
    if (vcpus <= 8) { return 3 }
    if (vcpus <= 16) { return 2 }
    return 1
  }

  // Build instance type lookup by name
  var instance_type_map = {}
  _.each(ds_azure_compute_instance_types, function(inst) {
    if (inst['name'] != undefined) { instance_type_map[inst['name']] = inst }
  })

  var currency = ds_currency['symbol'] || '$'
  var currency_sep = ds_currency['separator'] || ','

  var rightsize_list = []
  var idle_list = []
  var rightsize_no_memory_count = 0
  var rightsize_total_savings = 0.0
  var idle_total_savings = 0.0

  _.each(ds_azure_instances_metrics_organized, function(vm) {
    var instance_type = vm['resourceType']
    var inst_info = instance_type_map[instance_type]
    if (!inst_info) { return }

    var region = vm['region']
    var subscription_id = vm['accountID']
    var cco_cost = ds_instance_costs_grouped[vm['resourceID'].toLowerCase()] || 0

    // p95 CPU and memory
    var cpu_p95 = vm['cpu_p95'] || 0
    var cpu_average = vm['cpu_average'] || 0
    var mem_p95 = vm['mem_p95'] || 0
    var has_mem_data = vm['has_mem_data'] === true
    var has_cpu_data = vm['has_cpu_data'] === true

    // Disk and network metrics
    var disk_peak_bps = vm['disk_peak_bps'] || 0
    var disk_peak_iops = vm['disk_peak_iops'] || 0
    var net_total_bytes = vm['net_total_bytes'] || 0
    var has_net_data = vm['has_net_data'] === true
    var network_idle_threshold_bytes = 524288000  // 500 MiB/day
    var net_avg_bytes_per_day = (param_stats_lookback > 0) ? (net_total_bytes / param_stats_lookback) : 0
    var is_net_idle = !has_net_data || (net_avg_bytes_per_day < network_idle_threshold_bytes)

    // Skip VMs with no CPU metrics — we cannot determine idle state or rightsizing requirements
    if (!has_cpu_data) { return }

    // Tags
    var vm_tags = []
    if (typeof(vm['tags']) == 'object') {
      _.each(Object.keys(vm['tags']), function(key) {
        vm_tags.push(key + '=' + vm['tags'][key])
      })
    }

    // Power state
    var state = vm['state'] || 'unknown'

    // === IDLE DETECTION (average CPU + network, tiered CPU threshold by vCPU count) ===
    var cpu_spec_for_idle = parseInt(inst_info['specs']['vCPUs'])
    var idle_cpu_threshold = getIdleCpuThreshold(cpu_spec_for_idle)
    if (cpu_average < idle_cpu_threshold && is_net_idle) {
      var idle_savings = parseFloat(parseFloat(cco_cost).toFixed(3))

      var rec_details_idle = [
        "Delete or power off Azure virtual machine ", vm['resourceName'],
        " in Azure Subscription ", vm['accountName'],
        " (", vm['accountID'], ")"
      ].join('')

      if (vm['chartUrl']) {
        rec_details_idle += "\n\n![Utilization Chart](" + vm['chartUrl'] + "&from_pt=true)"
      }

      if (idle_savings >= param_min_savings) {
        idle_total_savings += cco_cost
        idle_list.push({
          accountID: vm['accountID'],
          accountName: vm['accountName'],
          resourceGroup: vm['resourceGroup'],
          resourceID: vm['resourceID'],
          resourceName: vm['resourceName'],
          resourceType: vm['resourceType'],
          newResourceType: "Delete/Power Off Virtual Machine",
          region: region,
          osType: vm['osType'],
          tags: vm_tags.join(', '),
          state: state,
          dataDiskCount: vm['dataDiskCount'],
          imagePublisher: vm['imagePublisher'],
          imageOffer: vm['imageOffer'],
          imageSKU: vm['imageSKU'],
          recommendationDetails: rec_details_idle,
          lookbackPeriod: param_stats_lookback,
          cpuAverage: Math.round(cpu_average * 100) / 100,
          cpuP95: Math.round(cpu_p95 * 100) / 100,
          networkAvgMbPerDay: Math.round(net_avg_bytes_per_day / 1048576 * 100) / 100,
          savings: idle_savings,
          savingsCurrency: currency,
          service: "Microsoft.Compute",
          chartUrlField: vm['chartUrlField'],
          recommendedAction: "idle",
          policy_name: ds_applied_policy['name'],
          idle_message: "",
          idle_total_savings: ""
        })
      }
      return
    }

    // === CROSS-FAMILY RIGHTSIZING ===

    // Get current instance specs
    var cpu_spec = parseInt(inst_info['specs']['vCPUs'])
    var mem_spec_gb = parseFloat(inst_info['specs']['MemoryGB'])
    var current_arch = inst_info['specs']['CpuArchitectureType']
    var current_hyper_v = inst_info['specs']['HyperVGenerations'] || 'V1,V2'
    var current_premium_io = inst_info['specs']['PremiumIO'] === true
    var current_local_disk = inst_info['localDisk'] === true
    // Check whether any attached NIC actually has AcceleratedNetworking enabled.
    // The VM list API does not return enableAcceleratedNetworking inline in networkProfile
    // NIC references, so this will typically be false unless the API starts returning it.
    // This avoids over-restricting recommendations for VMs whose instance type supports
    // AccelNet but whose NICs do not actually have it enabled.
    var current_accel_net = _.any(vm['networkInterfaces'] || [], function(nic) {
      return nic['properties'] && nic['properties']['enableAcceleratedNetworking'] === true
    })
    var current_is_amd = (current_arch === 'x64') && isAMD(instance_type)
    var current_hyper_v_gens = current_hyper_v.split(',')

    // Current VM's observed usage
    var data_disk_count = vm['dataDiskCount'] || 0
    var nic_count = vm['nicCount'] || 1

    // Compute required resources
    var safety = param_stats_safety_factor
    var required_vcpus = Math.ceil((cpu_p95 / 100) * cpu_spec * safety)
    if (required_vcpus < 1) { required_vcpus = 1 }

    var required_mem_gb
    if (has_mem_data) {
      required_mem_gb = (mem_p95 / 100) * mem_spec_gb * safety
      if (required_mem_gb < 1.0) { required_mem_gb = 1.0 }
    } else {
      required_mem_gb = mem_spec_gb
    }

    // Get pricing for current instance
    var os_type = (vm['osType'] && vm['osType'].toLowerCase().indexOf('windows') !== -1) ? 'Windows' : 'Linux'
    var pretty_region = ds_region_table[region]
    if (!pretty_region) { return }

    var current_price = null
    if (ds_azure_vm_pricing[pretty_region] &&
        ds_azure_vm_pricing[pretty_region][instance_type] &&
        ds_azure_vm_pricing[pretty_region][instance_type][os_type]) {
      current_price = ds_azure_vm_pricing[pretty_region][instance_type][os_type]['pricePerUnit']
    }
    if (!current_price) { return }

    // Get available sizes for this subscription+region
    var available_for_sub_region = {}
    if (ds_azure_available_sizes[subscription_id] && ds_azure_available_sizes[subscription_id][region]) {
      available_for_sub_region = ds_azure_available_sizes[subscription_id][region]
    }

    var best_candidate_name = null
    var best_price = current_price

    _.each(ds_azure_compute_instance_types, function(candidate) {
      var cand_name = candidate['name']
      if (!cand_name || cand_name === instance_type) { return }
      if (candidate['superseded']) { return }

      var cand_specs = candidate['specs']

      // Gate 1: Not restricted/unavailable in this subscription+region
      if (!available_for_sub_region[cand_name]) { return }

      // Gate 2: Same CPU architecture
      if (cand_specs['CpuArchitectureType'] !== current_arch) { return }

      // Gate 3: Intel/AMD vendor gate (for x64 only)
      if (current_arch === 'x64' && param_allow_mixed_x86_vendors !== 'Yes') {
        var cand_is_amd = isAMD(cand_name)
        if (cand_is_amd !== current_is_amd) { return }
      }

      // Gate 4: vCPU requirement
      if (parseInt(cand_specs['vCPUs']) < required_vcpus) { return }

      // Gate 5: Memory requirement
      if (parseFloat(cand_specs['MemoryGB']) < required_mem_gb) { return }

      // Gate 6: HyperV generation -- candidate must support all generations the current type does
      var cand_hyper_v = cand_specs['HyperVGenerations'] || 'V1,V2'
      var cand_hyper_v_gens = cand_hyper_v.split(',')
      var gen_ok = _.every(current_hyper_v_gens, function(g) {
        return _.contains(cand_hyper_v_gens, g.trim())
      })
      if (!gen_ok) { return }

      // Gate 7: Premium storage
      if (current_premium_io && cand_specs['PremiumIO'] !== true) { return }

      // Gate 8: Local/temp disk
      if (current_local_disk && candidate['localDisk'] !== true) { return }

      // Gate 9: Data disk count
      if (parseInt(cand_specs['MaxDataDiskCount']) < data_disk_count) { return }

      // Gate 10: NIC count
      if (parseInt(cand_specs['MaxNetworkInterfaces']) < nic_count) { return }

      // Gate 11: Accelerated networking
      if (current_accel_net && cand_specs['AcceleratedNetworkingEnabled'] !== true) { return }

      // Gate 12: Disk throughput (only applied when peak throughput data is available)
      if (disk_peak_bps > 0) {
        var cand_disk_bps = parseInt(cand_specs['UncachedDiskBytesPerSecond']) || 0
        if (cand_disk_bps > 0 && cand_disk_bps < (disk_peak_bps * safety)) { return }
      }

      // Gate 13: Disk IOPS (only applied when peak IOPS data is available)
      if (disk_peak_iops > 0) {
        var cand_disk_iops = parseInt(cand_specs['UncachedDiskIOPS']) || 0
        if (cand_disk_iops > 0 && cand_disk_iops < (disk_peak_iops * safety)) { return }
      }

      // Pricing check
      var cand_price = null
      if (ds_azure_vm_pricing[pretty_region] &&
          ds_azure_vm_pricing[pretty_region][cand_name] &&
          ds_azure_vm_pricing[pretty_region][cand_name][os_type]) {
        cand_price = ds_azure_vm_pricing[pretty_region][cand_name][os_type]['pricePerUnit']
      }
      if (!cand_price) { return }
      if (cand_price >= best_price) { return }

      best_price = cand_price
      best_candidate_name = cand_name
    })

    if (best_candidate_name) {
      var cand_info = instance_type_map[best_candidate_name]
      var savings_ratio = (current_price - best_price) / current_price
      var monthly_savings = cco_cost * savings_ratio

      if (monthly_savings >= param_min_savings) {
        var rec_details = [
          "Resize Azure virtual machine ", vm['resourceName'],
          " in Azure Subscription ", vm['accountName'],
          " (", vm['accountID'], ") ",
          "from ", instance_type, " to ", best_candidate_name
        ].join('')

        if (vm['chartUrl']) {
          rec_details += "\n\n![Utilization Chart](" + vm['chartUrl'] + "&from_pt=true)"
        }

        rightsize_total_savings += monthly_savings
        if (!has_mem_data) { rightsize_no_memory_count++ }

        rightsize_list.push({
          accountID: vm['accountID'],
          accountName: vm['accountName'],
          resourceGroup: vm['resourceGroup'],
          resourceID: vm['resourceID'],
          resourceName: vm['resourceName'],
          resourceType: instance_type,
          newResourceType: best_candidate_name,
          region: region,
          osType: vm['osType'],
          tags: vm_tags.join(', '),
          state: state,
          dataDiskCount: vm['dataDiskCount'],
          nicCount: nic_count,
          imagePublisher: vm['imagePublisher'],
          imageOffer: vm['imageOffer'],
          imageSKU: vm['imageSKU'],
          currentLocalDisk: current_local_disk ? "Yes" : "No",
          recommendedLocalDisk: cand_info ? (cand_info['localDisk'] ? "Yes" : "No") : "Unknown",
          hasMemoryData: has_mem_data ? "Yes" : "No",
          cpuP95: Math.round(cpu_p95 * 100) / 100,
          memP95: has_mem_data ? Math.round(mem_p95 * 100) / 100 : null,
          diskPeakMbps: Math.round(disk_peak_bps / 1048576 * 100) / 100,
          diskPeakIops: Math.round(disk_peak_iops * 100) / 100,
          networkAvgMbPerDay: Math.round(net_avg_bytes_per_day / 1048576 * 100) / 100,
          requiredVcpus: required_vcpus,
          requiredMemGB: Math.round(required_mem_gb * 100) / 100,
          currentVcpus: cpu_spec,
          currentMemGB: mem_spec_gb,
          currentListPrice: Math.round(current_price * 730 * 100) / 100,
          recommendedListPrice: Math.round(best_price * 730 * 100) / 100,
          recommendationDetails: rec_details,
          lookbackPeriod: param_stats_lookback,
          savings: parseFloat(monthly_savings.toFixed(3)),
          savingsCurrency: currency,
          service: "Microsoft.Compute",
          chartUrlField: vm['chartUrlField'],
          recommendedAction: "resize",
          policy_name: ds_applied_policy['name'],
          rightsize_message: "",
          rightsize_total_savings: ""
        })
      }
    }
  })

  // Sort by savings descending
  rightsize_list = _.sortBy(rightsize_list, function(item) { return item['savings'] * -1 })
  idle_list = _.sortBy(idle_list, function(item) { return item['savings'] * -1 })

  var instances_total = ds_azure_instances_metrics_organized.length.toString()

  // Build messages
  var idle_total_savings_str = currency + ' ' + formatNumber(parseFloat(idle_total_savings).toFixed(2), currency_sep)
  var rightsize_total_savings_str = currency + ' ' + formatNumber(parseFloat(rightsize_total_savings).toFixed(2), currency_sep)

  var applied_policy_url = "https://" + ds_flexera_api_hosts["ui"]
  if (typeof(ds_applied_policy['policyAggregateId']) == 'string') {
    applied_policy_url += "/orgs/" + rs_org_id + "/automation/applied-policies?policyId=" + ds_applied_policy['policyAggregateId']
  } else {
    applied_policy_url += "/orgs/" + rs_org_id + "/automation/applied-policies/projects/" + rs_project_id + "?policyId=" + ds_applied_policy['id']
  }
  var disclaimer = "The above settings can be modified by editing the [" + ds_applied_policy['name'] + "](" + applied_policy_url + ") applied policy.\n\n"

  var instances_total_num = parseInt(instances_total)
  var idle_pct = instances_total_num > 0 ? (idle_list.length / instances_total_num * 100).toFixed(2) : "0.00"
  var rightsize_pct = instances_total_num > 0 ? (rightsize_list.length / instances_total_num * 100).toFixed(2) : "0.00"

  var idle_message = [
    "Out of ", instances_total, " Azure virtual machines analyzed, ",
    idle_list.length.toString(), " (", idle_pct, "%) are idle and recommended for termination or power-off.\n\n",
    "An instance is considered idle when its average CPU utilization falls below a size-adjusted threshold ",
    "(\u22642 vCPUs: 5%, \u22644 vCPUs: 4%, \u22648 vCPUs: 3%, \u226416 vCPUs: 2%, >16 vCPUs: 1%) ",
    "AND its average network throughput is below 500 MiB/day. ",
    "CPU and network usage were analyzed over the last ", param_stats_lookback.toString(), " days ",
    "at a 15-minute metric granularity. If network data is unavailable, only the CPU threshold is applied.\n\n",
    disclaimer
  ].join('')

  var rightsize_message_parts = [
    "Out of ", instances_total, " Azure virtual machines analyzed, ",
    rightsize_list.length.toString(), " (", rightsize_pct, "%) are underutilized and recommended for rightsizing.\n\n",
    "The recommended instance type is the cheapest available type that satisfies all compatibility requirements ",
    "based on p95 CPU and memory utilization with a safety factor of ", param_stats_safety_factor.toString(), "x. ",
    "Disk throughput and IOPS requirements are derived from peak 15-minute disk metrics and are also applied as compatibility gates. ",
    "Metrics were analyzed over the last ", param_stats_lookback.toString(), " days ",
    "at a 15-minute granularity.\n\n"
  ]

  if (rightsize_no_memory_count > 0) {
    rightsize_message_parts.push(
      "**Note:** ", rightsize_no_memory_count.toString(), " of these recommendations were produced without memory utilization data. ",
      "For these instances, the recommended type is required to have at least as much memory as the current instance, ",
      "but actual memory usage is unknown. Install the Azure Monitor Agent with memory metrics enabled for more precise recommendations.\n\n"
    )
  }

  rightsize_message_parts.push(disclaimer)
  var rightsize_message = rightsize_message_parts.join('')

  if (idle_list.length > 0) {
    idle_list[0]['idle_message'] = idle_message
    idle_list[0]['idle_total_savings'] = idle_total_savings_str
  }

  if (rightsize_list.length > 0) {
    rightsize_list[0]['rightsize_message'] = rightsize_message
    rightsize_list[0]['rightsize_total_savings'] = rightsize_total_savings_str
  }

  result = {
    rightsize_list: rightsize_list,
    idle_list: idle_list
  }
EOS
end

datasource "ds_rightsize_instances" do
  run_script $js_rightsize_instances, $ds_idle_and_rightsize_instances
end

script "js_rightsize_instances", type: "javascript" do
  parameters "ds_idle_and_rightsize_instances"
  result "result"
  code <<-'EOS'
  result = [{
    recommendedAction: "",
    resourceID: "",
    savings: "",
    savingsCurrency: "",
    tags: "",
    cpuP95: "",
    memP95: "",
    diskPeakMbps: "",
    diskPeakIops: "",
    networkAvgMbPerDay: "",
    chartUrlField: "",
    rightsize_message: "",
    rightsize_total_savings: ""
  }]

  result = ds_idle_and_rightsize_instances['rightsize_list'].concat(result)
EOS
end

datasource "ds_idle_instances" do
  run_script $js_idle_instances, $ds_idle_and_rightsize_instances
end

script "js_idle_instances", type: "javascript" do
  parameters "ds_idle_and_rightsize_instances"
  result "result"
  code <<-'EOS'
  result = [{
    recommendedAction: "",
    resourceID: "",
    savings: "",
    savingsCurrency: "",
    tags: "",
    cpuAverage: "",
    cpuP95: "",
    networkAvgMbPerDay: "",
    chartUrlField: "",
    idle_message: "",
    idle_total_savings: ""
  }]

  result = ds_idle_and_rightsize_instances['idle_list'].concat(result)
EOS
end

###############################################################################
# Policy
###############################################################################

policy "pol_utilization" do
  validate_each $ds_rightsize_instances do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} Azure Underutilized Virtual Machines Found"
    detail_template <<-'EOS'
    **Potential Monthly Savings:** {{ with index data 0 }}{{ .rightsize_total_savings }}{{ end }}

    {{ with index data 0 }}{{ .rightsize_message }}{{ end }}
    EOS
    # Policy check fails and incident is created only if data is not empty and the Parent Policy has not been terminated
    check logic_or($ds_parent_policy_terminated, ne(val(item, "recommendedAction"), "resize"))
    escalate $esc_email
    escalate $esc_downsize_instances
    hash_exclude "tags", "savings", "savingsCurrency", "cpuP95", "memP95", "diskPeakMbps", "diskPeakIops", "networkAvgMbPerDay", "chartUrlField", "requiredVcpus", "requiredMemGB", "currentListPrice", "recommendedListPrice"
    export do
      resource_level true
      field "accountID" do
        label "Subscription ID"
      end
      field "accountName" do
        label "Subscription Name"
      end
      field "resourceGroup" do
        label "Resource Group"
      end
      field "resourceID" do
        label "Resource ID"
      end
      field "resourceName" do
        label "Resource Name"
      end
      field "tags" do
        label "Resource Tags"
      end
      field "recommendationDetails" do
        label "Recommendation"
      end
      field "region" do
        label "Region"
      end
      field "resourceType" do
        label "Instance Size"
      end
      field "newResourceType" do
        label "Recommended Instance Size"
      end
      field "osType" do
        label "Operating System"
      end
      field "dataDiskCount" do
        label "Attached Disks (#)"
      end
      field "nicCount" do
        label "Attached NICs (#)"
      end
      field "currentLocalDisk" do
        label "Current Instance Local Disk"
      end
      field "recommendedLocalDisk" do
        label "Recommended Instance Local Disk"
      end
      field "hasMemoryData" do
        label "Memory Data Available"
      end
      field "state" do
        label "Power State"
      end
      field "savings" do
        label "Estimated Monthly Savings"
      end
      field "savingsCurrency" do
        label "Savings Currency"
      end
      field "lookbackPeriod" do
        label "Look Back Period (Days)"
      end
      field "cpuP95" do
        label "CPU p95 %"
      end
      field "memP95" do
        label "Memory p95 %"
      end
      field "diskPeakMbps" do
        label "Disk Peak Throughput (MiB/s)"
      end
      field "diskPeakIops" do
        label "Disk Peak IOPS"
      end
      field "networkAvgMbPerDay" do
        label "Network Average (MiB/day)"
      end
      field "requiredVcpus" do
        label "Required vCPUs"
      end
      field "requiredMemGB" do
        label "Required Memory (GiB)"
      end
      field "currentVcpus" do
        label "Current vCPUs"
      end
      field "currentMemGB" do
        label "Current Memory (GiB)"
      end
      field "currentListPrice" do
        label "Current List Price (Monthly)"
      end
      field "recommendedListPrice" do
        label "Recommended List Price (Monthly)"
      end
      field "imagePublisher" do
        label "Image Publisher"
      end
      field "imageOffer" do
        label "Image Offer"
      end
      field "imageSKU" do
        label "Image SKU"
      end
      field "service" do
        label "Service"
      end
      field "chartUrlField" do
        label "Utilization Chart External Link"
        format "link-external"
      end
      field "id" do
        label "ID"
        path "resourceID"
      end
    end
  end
  validate_each $ds_idle_instances do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} Azure Idle Virtual Machines Found"
    detail_template <<-'EOS'
    **Potential Monthly Savings:** {{ with index data 0 }}{{ .idle_total_savings }}{{ end }}

    {{ with index data 0 }}{{ .idle_message }}{{ end }}
    EOS
    # Policy check fails and incident is created only if data is not empty and the Parent Policy has not been terminated
    check logic_or($ds_parent_policy_terminated, ne(val(item, "recommendedAction"), "idle"))
    escalate $esc_email
    escalate $esc_poweroff_instances
    escalate $esc_delete_instances
    hash_exclude "tags", "savings", "savingsCurrency", "cpuAverage", "cpuP95", "networkAvgMbPerDay", "chartUrlField"
    export do
      resource_level true
      field "accountID" do
        label "Subscription ID"
      end
      field "accountName" do
        label "Subscription Name"
      end
      field "resourceGroup" do
        label "Resource Group"
      end
      field "resourceID" do
        label "Resource ID"
      end
      field "resourceName" do
        label "Resource Name"
      end
      field "tags" do
        label "Resource Tags"
      end
      field "recommendationDetails" do
        label "Recommendation"
      end
      field "region" do
        label "Region"
      end
      field "resourceType" do
        label "Instance Size"
      end
      field "newResourceType" do
        label "Recommended Instance Size"
      end
      field "osType" do
        label "Operating System"
      end
      field "dataDiskCount" do
        label "Attached Disks (#)"
      end
      field "state" do
        label "Power State"
      end
      field "savings" do
        label "Estimated Monthly Savings"
      end
      field "savingsCurrency" do
        label "Savings Currency"
      end
      field "lookbackPeriod" do
        label "Look Back Period (Days)"
      end
      field "cpuAverage" do
        label "CPU Average %"
      end
      field "cpuP95" do
        label "CPU p95 %"
      end
      field "networkAvgMbPerDay" do
        label "Network Average (MiB/day)"
      end
      field "imagePublisher" do
        label "Image Publisher"
      end
      field "imageOffer" do
        label "Image Offer"
      end
      field "imageSKU" do
        label "Image SKU"
      end
      field "service" do
        label "Service"
      end
      field "chartUrlField" do
        label "Utilization Chart External Link"
        format "link-external"
      end
      field "id" do
        label "ID"
        path "resourceID"
      end
    end
  end
  validate $ds_no_subscriptions_error do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} Errors Identified"
    detail_template <<-'EOS'
    The policy was unable to access any Azure Subscriptions.

    **Error Details:**
    {{ range data -}}
      - {{ .error }}
    {{ end -}}

    **Recommended Actions:**
    1. Verify that the Azure credential has the required permissions to list subscriptions.
    2. Ensure the credential has not expired or been revoked.
    EOS
    check eq(size(data), 0)
    escalate $esc_email_errors_identified
  end
end

###############################################################################
# Escalations
###############################################################################

escalation "esc_email_errors_identified" do
  automatic true
  label "Send Email"
  description "Send incident email"
  email $param_email
end

escalation "esc_email" do
  automatic true
  label "Send Email"
  description "Send incident email"
  email $param_email do
    attach_export_table $param_incident_csv
    body_table_max_rows $param_incident_table_size
  end
end

escalation "esc_downsize_instances" do
  automatic contains($param_automatic_action, "Downsize Underutilized Instances")
  label "Downsize Underutilized Instances"
  description "Approval to downsize all selected instances"
  run "downsize_instances", data, $param_azure_endpoint
end

escalation "esc_poweroff_instances" do
  automatic contains($param_automatic_action, "Power Off Idle Instances")
  label "Power Off Idle Instances"
  description "Approval to power off all selected instances"
  run "poweroff_instances", data, $param_azure_endpoint, $param_skipshutdown
end

escalation "esc_delete_instances" do
  automatic contains($param_automatic_action, "Delete Idle Instances")
  label "Delete Idle Instances"
  description "Approval to delete all selected instances"
  run "delete_instances", data, $param_azure_endpoint
end

###############################################################################
# Cloud Workflow
###############################################################################

define downsize_instances($data, $param_azure_endpoint) return $all_responses do
  $$all_responses = []

  foreach $instance in $data do
    sub on_error: handle_error() do
      if $instance["newResourceType"] != "Delete Virtual Machine"
        call downsize_instance($instance, $param_azure_endpoint) retrieve $downsize_response
      end
    end
  end

  if inspect($$errors) != "null"
    raise join($$errors, "\n")
  end
end

define downsize_instance($instance, $param_azure_endpoint) return $response do
  $host = $param_azure_endpoint
  $href = $instance["id"]
  $params = "?api-version=2023-07-01"
  $url = $host + $href + $params
  task_label("PATCH " + $url)

  $response = http_request(
    auth: $$auth_azure,
    https: true,
    verb: "patch",
    host: $host,
    href: $href,
    query_strings: { "api-version": "2023-07-01" },
    body: {
      "properties":{
        "hardwareProfile": {
          "vmSize": $instance["newResourceType"]
        }
      }
    }
  )

  task_label("Patch Azure VM instance response: " + $instance["id"] + " " + to_json($response))
  $$all_responses << to_json({"req": "DELETE " + $url, "resp": $response})

  if $response["code"] != 204 && $response["code"] != 202 && $response["code"] != 200
    raise "Unexpected response patching Azure VM instance: "+ $instance["id"] + " " + to_json($response)
  else
    task_label("Patch Azure VM instance successful: " + $instance["id"])
  end
end

define poweroff_instances($data, $param_azure_endpoint, $param_skipshutdown) return $all_responses do
  $$all_responses = []

  foreach $instance in $data do
    sub on_error: handle_error() do
      call poweroff_instance($instance, $param_azure_endpoint, $param_skipshutdown) retrieve $poweroff_response
    end
  end

  if inspect($$errors) != "null"
    raise join($$errors, "\n")
  end
end

define poweroff_instance($instance, $param_azure_endpoint, $param_skipshutdown) return $response do
  $host = $param_azure_endpoint
  $href = $instance["id"] + "/powerOff"
  $params = "?api-version=2023-07-01"
  $url = $host + $href + $params
  task_label("POST " + $url)

  $query_strings = { "api-version": "2023-07-01" }

  if $param_skipshutdown == "Forced"
    $query_strings["skipShutdown"] = "true"
    $params = $params + "&skipShutdown=true"
  end

  $response = http_request(
    auth: $$auth_azure,
    https: true,
    verb: "post",
    host: $host,
    href: $href,
    query_strings: $query_strings
  )

  task_label("Power off Azure VM instance response: " + $instance["id"] + " " + to_json($response))
  $$all_responses << to_json({"req": "POST " + $url, "resp": $response})

  if $response["code"] != 204 && $response["code"] != 202 && $response["code"] != 200
    raise "Unexpected response powering off Azure VM instance: "+ $instance["id"] + " " + to_json($response)
  else
    task_label("Power off Azure VM instance successful: " + $instance["id"])
  end
end

define delete_instances($data, $param_azure_endpoint) return $all_responses do
  $$all_responses = []

  foreach $instance in $data do
    sub on_error: handle_error() do
      call delete_instance($instance, $param_azure_endpoint) retrieve $delete_response
    end
  end

  if inspect($$errors) != "null"
    raise join($$errors, "\n")
  end
end

define delete_instance($instance, $param_azure_endpoint) return $response do
  $host = $param_azure_endpoint
  $href = $instance["id"]
  $params = "?api-version=2023-07-01"
  $url = $host + $href + $params
  task_label("DELETE " + $url)

  $response = http_request(
    auth: $$auth_azure,
    https: true,
    verb: "delete",
    host: $host,
    href: $href,
    query_strings: { "api-version": "2023-07-01" }
  )

  task_label("Delete Azure VM instance response: " + $instance["id"] + " " + to_json($response))
  $$all_responses << to_json({"req": "DELETE " + $url, "resp": $response})

  if $response["code"] != 204 && $response["code"] != 202 && $response["code"] != 200
    raise "Unexpected response deleting Azure VM instance: "+ $instance["id"] + " " + to_json($response)
  else
    task_label("Delete Azure VM instance successful: " + $instance["id"])
  end
end

define handle_error() do
  if !$$errors
    $$errors = []
  end
  $$errors << $_error["type"] + ": " + $_error["message"]
  # We check for errors at the end, and raise them all together
  # Skip errors handled by this definition
  $_error_behavior = "skip"
end

###############################################################################
# Meta Policy [alpha]
# Not intended to be modified or used by policy developers
###############################################################################

# If the meta_parent_policy_id is not set it will evaluate to an empty string and we will look for the policy itself,
# if it is set we will look for the parent policy.
datasource "ds_get_parent_policy" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies/", switch(ne(meta_parent_policy_id, ""), meta_parent_policy_id, policy_id) ])
	  ignore_status [404]
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
  end
end

# If the policy was applied by a meta_parent_policy we confirm it exists if it doesn't we confirm we are deleting
# This information is used in two places:
# - determining whether or not we make a delete call
# - determining if we should create an incident (we don't want to create an incident on the run where we terminate)
datasource "ds_parent_policy_terminated" do
  run_script $js_parent_policy_terminated, $ds_get_parent_policy, meta_parent_policy_id
end

script "js_parent_policy_terminated", type: "javascript" do
  parameters "ds_get_parent_policy", "meta_parent_policy_id"
  result "result"
  code <<-'EOS'
  result = meta_parent_policy_id != "" && ds_get_parent_policy["id"] == undefined
EOS
end

# Two potentials ways to set this up:
# - this way and make a unneeded 'get' request when not deleting
# - make the delete request an interate and have it iterate over an empty array when not deleting and an array with one item when deleting
datasource "ds_terminate_self" do
  request do
    run_script $js_make_terminate_request, $ds_parent_policy_terminated, $ds_flexera_api_hosts, policy_id, rs_org_id, rs_project_id
  end
end

script "js_make_terminate_request", type: "javascript" do
  parameters "ds_parent_policy_terminated", "ds_flexera_api_hosts", "policy_id", "rs_org_id", "rs_project_id"
  result "request"
  code <<-'EOS'
  var request = {
    auth: "auth_flexera",
    host: ds_flexera_api_hosts["flexera"],
    path: [ "/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies", policy_id ? "/"+policy_id : "" ].join(''),
    verb: ds_parent_policy_terminated ? "DELETE" : "GET"
  }
EOS
end

# This is just a way to have the check delete request connect to the farthest leaf from policy.
# We want the delete check to the first thing the policy does to avoid the policy erroring before it can decide whether or not it needs to self terminate
# Example a customer deletes a credential and then terminates the parent policy. We still want the children to self terminate
# The only way I could see this not happening is if the user who applied the parent_meta_policy was offboarded or lost policy access, the policies who are impersonating the user
# would not have access to self-terminate
# It may be useful for the backend to enable a mass terminate at some point for all meta_child_policies associated with an id.
datasource "ds_is_deleted" do
  run_script $js_is_deleted, $ds_terminate_self
end

script "js_is_deleted", type: "javascript" do
  parameters "ds_terminate_self"
  result "result"
  code 'result = { path: "/"}'
end
