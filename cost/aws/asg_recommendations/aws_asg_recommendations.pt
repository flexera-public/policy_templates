  validate_each $ds_finding_overprovisioned do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} Auto Scaling Group(s) With Over-provisioned Floor (Review)"
    detail_template <<-'EOS'
    **Total Theoretical-Maximum Monthly Spend (Pre-Commitment):** {{ with index data 0 }}{{ .total_spend }}{{ end }}

    {{ with index data 0 }}{{ .message }}{{ end }}
    EOS
    check logic_or($ds_parent_policy_terminated, eq(val(item, "resourceID"), ""))
    escalate $esc_email
    hash_exclude "tags", "monthlySpendOnDemandEquiv", "spendCurrency", "cpuAverage", "cpuP95", "cpuMaximum", "peakInService", "headroomRatio", "ageDays", "recommendationDetails", "confidence"
    export do
      resource_level true
      field "accountID" do
        label "Account ID"
      end
      field "accountName" do
        label "Account Name"
      end
      field "resourceID" do
        label "Resource ID"
      end
      field "resourceName" do
        label "ASG Name"
      end
      field "region" do
        label "Region"
      end
      field "finding" do
        label "Finding"
      end
      field "confidence" do
        label "Confidence"
      end
      field "minSize" do
        label "Min Size"
      end
      field "maxSize" do
        label "Max Size"
      end
      field "desired" do
        label "Desired Capacity"
      end
      field "resourceType" do
        label "Instance Type"
      end
      field "azCount" do
        label "AZ Count"
      end
      field "ageDays" do
        label "Age (Days)"
      end
      field "hasScalingPolicies" do
        label "Has Scaling Policies"
      end
      field "scalingPolicyTypes" do
        label "Scaling Policy Types"
      end
      field "groupMetricsEnabled" do
        label "Group Metrics Enabled"
      end
      field "peakInService" do
        label "Peak In-Service"
      end
      field "headroomRatio" do
        label "Headroom Ratio (peak / Min)"
      end
      field "cpuAverage" do
        label "CPU Average %"
      end
      field "cpuP95" do
        label "CPU p95"
      end
      field "cpuMaximum" do
        label "CPU Maximum %"
      end
      field "lookbackPeriod" do
        label "Look Back Period (Days)"
      end
      field "tags" do
        label "Resource Tags"
      end
      field "monthlySpendOnDemandEquiv" do
        label "Theoretical Maximum Monthly Spend (Pre-Commitment)"
      end
      field "spendCurrency" do
        label "Spend Currency"
      end
      field "spendLabel" do
        label "Spend Label"
      end
      field "recommendationDetails" do
        label "What to Check"
      end
      field "service" do
        label "Service"
      end
      field "resourceARN" do
        label "Resource ARN"
      end
      field "id" do
        label "ID"
        path "resourceID"
      end
    end
  end

  validate_each $ds_finding_metrics_disabled do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} Auto Scaling Group(s) Missing Group Metrics Collection"
    detail_template <<-'EOS'
    {{ with index data 0 }}{{ .message }}{{ end }}
    EOS
    check logic_or($ds_parent_policy_terminated, eq(val(item, "resourceID"), ""))
    escalate $esc_email
    hash_exclude "tags", "ageDays"
    export do
      resource_level true
      field "accountID" do
        label "Account ID"
      end
      field "accountName" do
        label "Account Name"
      end
      field "resourceID" do
        label "Resource ID"
      end
      field "resourceName" do
        label "ASG Name"
      end
      field "region" do
        label "Region"
      end
      field "finding" do
        label "Finding"
      end
      field "confidence" do
        label "Confidence"
      end
      field "minSize" do
        label "Min Size"
      end
      field "maxSize" do
        label "Max Size"
      end
      field "desired" do
        label "Desired Capacity"
      end
      field "resourceType" do
        label "Instance Type"
      end
      field "azCount" do
        label "AZ Count"
      end
      field "ageDays" do
        label "Age (Days)"
      end
      field "missingGroupMetrics" do
        label "Missing Group Metrics"
      end
      field "enabledMetrics" do
        label "Enabled Group Metrics"
      end
      field "tags" do
        label "Resource Tags"
      end
      field "recommendationDetails" do
        label "What to Check"
      end
      field "service" do
        label "Service"
      end
      field "resourceARN" do
        label "Resource ARN"
      end
      field "id" do
        label "ID"
        path "resourceID"
      end
    end
  end

  validate $ds_identify_errors do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} Errors Identified"
    detail_template <<-'EOS'
    The policy was unable to retrieve Auto Scaling Group data from one or more AWS regions due to permission or configuration errors.

    **Error Details:**
    {{ range data -}}
      - {{ .error }}
    {{ end -}}

    **Recommended Actions:**
    1. Verify that the AWS credential has the `autoscaling:DescribeAutoScalingGroups`, `autoscaling:DescribePolicies`, and `autoscaling:DescribeScalingActivities` permissions for all regions where the policy should execute.
    1. Ensure that the required AWS regions are opted-in in your AWS account.
    1. Consider updating the **Allow/Deny Regions List** parameter to exclude regions that are not accessible or not relevant to your use case.
    EOS
    check eq(size(data), 0)
    escalate $esc_email_errors_identified
  end
end

###############################################################################
# Escalations
###############################################################################

escalation "esc_email" do
  automatic true
  label "Send Email"
  description "Send incident email"
  email $param_email do
    attach_export_table $param_incident_csv
    body_table_max_rows $param_incident_table_size
  end
end

escalation "esc_email_errors_identified" do
  automatic true
  label "Send Email"
  description "Send incident email"
  email $param_email
end

###############################################################################
# Meta Policy [alpha]
# Not intended to be modified or used by policy developers
###############################################################################

# If the meta_parent_policy_id is not set it will evaluate to an empty string and we will look for the policy itself,
# if it is set we will look for the parent policy.
datasource "ds_get_parent_policy" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies/", switch(ne(meta_parent_policy_id, ""), meta_parent_policy_id, policy_id) ])
    ignore_status [404]
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
  end
end

# If the policy was applied by a meta_parent_policy we confirm it exists if it doesn't we confirm we are deleting
# This information is used in two places:
# - determining whether or not we make a delete call
# - determining if we should create an incident (we don't want to create an incident on the run where we terminate)
datasource "ds_parent_policy_terminated" do
  run_script $js_parent_policy_terminated, $ds_get_parent_policy, meta_parent_policy_id
end

script "js_parent_policy_terminated", type: "javascript" do
  parameters "ds_get_parent_policy", "meta_parent_policy_id"
  result "result"
  code <<-'EOS'
  result = meta_parent_policy_id != "" && ds_get_parent_policy["id"] == undefined
EOS
end

# Two potentials ways to set this up:
# - this way and make a unneeded 'get' request when not deleting
# - make the delete request an interate and have it iterate over an empty array when not deleting and an array with one item when deleting
datasource "ds_terminate_self" do
  request do
    run_script $js_make_terminate_request, $ds_parent_policy_terminated, $ds_flexera_api_hosts, policy_id, rs_org_id, rs_project_id
  end
end

script "js_make_terminate_request", type: "javascript" do
  parameters "ds_parent_policy_terminated", "ds_flexera_api_hosts", "policy_id", "rs_org_id", "rs_project_id"
  result "request"
  code <<-'EOS'
  var request = {
    auth: "auth_flexera",
    host: ds_flexera_api_hosts["flexera"],
    path: [ "/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies", policy_id ? "/"+policy_id : "" ].join(''),
    verb: ds_parent_policy_terminated ? "DELETE" : "GET"
  }
EOS
end

# This is just a way to have the check delete request connect to the farthest leaf from policy.
# We want the delete check to the first thing the policy does to avoid the policy erroring before it can decide whether or not it needs to self terminate
datasource "ds_is_deleted" do
  run_script $js_is_deleted, $ds_terminate_self
end

script "js_is_deleted", type: "javascript" do
  parameters "ds_terminate_self"
  result "result"
  code 'result = { path: "/"}'
end
