# Policy
###############################################################################

policy "pol_asg_recommendations" do
  validate_each $ds_finding_fixed_size do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} Fixed-Size Auto Scaling Group(s) Found"
    detail_template <<-'EOS'
    **Total On-Demand-Equivalent Monthly Spend (Pre-Commitment):** {{ with index data 0 }}{{ .total_spend }}{{ end }}

    {{ with index data 0 }}{{ .message }}{{ end }}
    EOS
    check logic_or($ds_parent_policy_terminated, eq(val(item, "resourceID"), ""))
    escalate $esc_email
    hash_exclude "tags", "monthlySpendOnDemandEquiv", "spendCurrency", "cpuAverage", "cpuP95", "cpuMaximum", "peakInService", "ageDays", "recommendationDetails"
    export do
      resource_level true
