name "AWS Auto Scaling Group Recommendations"
rs_pt_ver 20180301
type "policy"
short_description "Detects non-elastic and over-provisioned EC2 Auto Scaling Groups (ASGs) and surfaces them as advisory incidents with supporting evidence for a human owner to review. The policy raises four distinct findings: fixed-size ASGs (Min=Max=Desired), ASGs that never moved off their floor, Over-provisioned Floors, and ASGs missing group metrics collection. Dollar figures are reported as on-demand-equivalent spend (pre-commitment), not as savings. See the [README](https://github.com/flexera-public/policy_templates/tree/master/cost/aws/asg_recommendations) and [docs.flexera.com/flexera/EN/Automation](https://docs.flexera.com/flexera-one/automation/) to learn more."
long_description ""
doc_link "https://github.com/flexera-public/policy_templates/tree/master/cost/aws/asg_recommendations"
category "Cost"
severity "low"
default_frequency "weekly"
info(
  version: "0.1.0",
  provider: "AWS",
  service: "Compute",
  policy_set: "Auto Scaling Recommendations",
  hide_skip_approvals: "true"
)

###############################################################################
# Parameters
###############################################################################

parameter "param_email" do
  type "list"
  category "Policy Settings"
  label "Email Addresses"
  description "A list of email addresses to notify."
  default []
end

parameter "param_aws_account_number" do
  type "string"
  category "Policy Settings"
  label "Account Number"
  description "Leave blank; this is for automated use with Meta Policies. See README for more details."
  default ""
end

parameter "param_regions_allow_or_deny" do
  type "string"
  category "Filters"
  label "Allow/Deny Regions"
  description "Allow or Deny entered regions. See the README for more details."
  allowed_values "Allow", "Deny"
  default "Allow"
end

parameter "param_regions_list" do
  type "list"
  category "Filters"
  label "Allow/Deny Regions List"
  description "A list of allowed or denied regions. See the README for more details."
  allowed_pattern /^([a-zA-Z-_]+-[a-zA-Z0-9-_]+-[0-9-_]+,*|)+$/
  default []
end

parameter "param_stats_lookback" do
  type "number"
  category "Statistics"
  label "Statistic Lookback Period"
  description "How many days back to look at CloudWatch and scaling-activity data when assessing each Auto Scaling Group. This value cannot be set higher than 90 because AWS does not retain metrics for longer than 90 days."
  min_value 1
  max_value 90
  default 30
end

parameter "param_stats_period" do
  type "number"
  category "Statistics"
  label "Metric Aggregation Period (Seconds)"
  description "CloudWatch GetMetricData aggregation period in seconds. 3600 (hourly) is the recommended default. Higher values reduce datapoint volume; lower values give finer resolution but may exceed GetMetricData limits over long lookbacks."
  allowed_values 300, 900, 3600, 21600, 86400
  default 3600
end

parameter "param_floor_headroom_ratio" do
  type "number"
  category "Policy Settings"
  label "Floor Headroom Ratio Threshold"
  description "Trigger the Over-provisioned Floor finding when peak in-service instance count divided by MinSize is at or below this ratio. 0.5 means peak in-service was at most half of MinSize. Set higher (closer to 1.0) to flag more groups; lower to flag fewer."
  min_value 0
  max_value 1
  default 0.5
end

parameter "param_floor_cpu_threshold" do
  type "number"
  category "Policy Settings"
  label "Floor CPU Threshold (%)"
  description "Trigger the Over-provisioned Floor finding when the aggregate p95 CPU utilization across the ASG is at or below this percentage."
  min_value 0
  max_value 100
  default 20
end

parameter "param_min_age_days" do
  type "number"
  category "Policy Settings"
  label "Minimum ASG Age (Days)"
  description "Skip ASGs younger than this many days because their history is too short to assess. Set to 0 to disable the age filter (every ASG is evaluated regardless of how recently it was created). Defaults to 30 to match the default lookback window."
  min_value 0
  max_value 365
  default 30
end

parameter "param_findings" do
  type "list"
  category "Policy Settings"
  label "Findings To Raise"
  description "Which finding types this policy should evaluate and raise as incidents. Deselect a finding to suppress it. All four are selected by default. See the README for details on each finding."
  allowed_values "Fixed-size ASG", "Never Moved Off Floor", "Over-provisioned Floor", "Group Metrics Collection Disabled"
  default ["Fixed-size ASG", "Never Moved Off Floor", "Over-provisioned Floor", "Group Metrics Collection Disabled"]
end

parameter "param_exclusion_tags" do
  type "list"
  category "Filters"
  label "Exclusion Tags"
  description "Cloud native tags to skip ASGs from the cost/over-provisioning findings (Fixed-size, Never-moved-off-floor, Over-provisioned Floor). The 'Group metrics disabled' hygiene finding is still raised for tagged groups. Enter a Key name to filter ASGs with that key regardless of value, or 'Key==Value' for exact matching. Other operators (!=, =~, !~) and regex are supported; please see the README for more details. Example: 'finops:ignore-elasticity'."
  default []
end

parameter "param_exclusion_tags_boolean" do
  type "string"
  category "Filters"
  label "Exclusion Tags: Any / All"
  description "Whether to skip ASGs containing any of the specified tags or only those that contain all of them."
  allowed_values "Any", "All"
  default "Any"
end

parameter "param_incident_csv" do
  type "string"
  category "Incident Settings"
  label "Attach CSV To Incident Email"
  description "Whether or not to attach the results as a CSV file to the incident email."
  allowed_values "true", "false"
  default "false"
end

parameter "param_incident_table_size" do
  type "number"
  category "Incident Settings"
  label "Incident Table Rows for Email Body (#)"
  description "The number of results to include in the incident table in the incident email. Set to '0' to not show an incident table at all, and '100000' to include all results. Does not impact attached CSV files or the incident as presented in Flexera One."
  allowed_values 0, 10, 50, 100, 200, 500, 1000, 10000, 100000
  default 100000
end

###############################################################################
# Authentication
###############################################################################

credentials "auth_aws" do
  schemes "aws", "aws_sts"
  label "AWS"
  description "Select the AWS Credential from the list"
  tags "provider=aws"
  aws_account_number $param_aws_account_number
end

credentials "auth_flexera" do
  schemes "oauth2"
  label "Flexera"
  description "Select Flexera One OAuth2 credentials"
  tags "provider=flexera"
end

###############################################################################
# Pagination
###############################################################################

pagination "pagination_aws_asg_xml" do
  get_page_marker do
    body_path "//DescribeAutoScalingGroupsResponse/DescribeAutoScalingGroupsResult/NextToken"
  end
  set_page_marker do
    query "NextToken"
  end
end

pagination "pagination_aws_policies_xml" do
  get_page_marker do
    body_path "//DescribePoliciesResponse/DescribePoliciesResult/NextToken"
  end
  set_page_marker do
    query "NextToken"
  end
end

pagination "pagination_aws_activities_xml" do
  get_page_marker do
    body_path "//DescribeScalingActivitiesResponse/DescribeScalingActivitiesResult/NextToken"
  end
  set_page_marker do
    query "NextToken"
  end
end

###############################################################################
# Datasources & Scripts
###############################################################################

# Get region-specific Flexera API endpoints
datasource "ds_flexera_api_hosts" do
  run_script $js_flexera_api_hosts, rs_optima_host
end

script "js_flexera_api_hosts", type: "javascript" do
  parameters "rs_optima_host"
  result "result"
  code <<-'EOS'
  host_table = {
    "api.optima.flexeraeng.com": {
      flexera: "api.flexera.com",
      optima: "api.optima.flexeraeng.com"
    },
    "api.optima-eu.flexeraeng.com": {
      flexera: "api.flexera.eu",
      optima: "api.optima-eu.flexeraeng.com"
    },
    "api.optima-apac.flexeraeng.com": {
      flexera: "api.flexera.au",
      optima: "api.optima-apac.flexeraeng.com"
    }
  }
  result = host_table[rs_optima_host]
EOS
end

datasource "ds_applied_policy" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies/", policy_id])
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
    field "name", jmes_path(response, "name")
  end
end

datasource "ds_cloud_vendor_accounts" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/finops-analytics/v1/orgs/", rs_org_id, "/cloud-vendor-accounts"])
    header "Api-Version", "1.0"
  end
  result do
    encoding "json"
    collect jmes_path(response, "values[*]") do
      field "id", jmes_path(col_item, "aws.accountId")
      field "name", jmes_path(col_item, "name")
      field "tags", jmes_path(col_item, "tags")
    end
  end
end

datasource "ds_billing_centers" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/analytics/orgs/", rs_org_id, "/billing_centers"])
    query "view", "allocation_table"
    header "Api-Version", "1.0"
    header "User-Agent", "RS Policies"
    ignore_status [403]
  end
  result do
    encoding "json"
    collect jmes_path(response, "[*]") do
      field "href", jmes_path(col_item, "href")
      field "id", jmes_path(col_item, "id")
      field "name", jmes_path(col_item, "name")
      field "parent_id", jmes_path(col_item, "parent_id")
    end
  end
end

datasource "ds_top_level_bcs" do
  run_script $js_top_level_bcs, $ds_billing_centers
end

script "js_top_level_bcs", type: "javascript" do
  parameters "ds_billing_centers"
  result "result"
  code <<-'EOS'
  filtered_bcs = _.filter(ds_billing_centers, function(bc) {
    return bc['parent_id'] == null || bc['parent_id'] == undefined
  })
  result = _.compact(_.pluck(filtered_bcs, 'id'))
EOS
end

datasource "ds_get_caller_identity" do
  request do
    auth $auth_aws
    host "sts.amazonaws.com"
    path "/"
    query "Action", "GetCallerIdentity"
    query "Version", "2011-06-15"
    header "User-Agent", "RS Policies"
  end
  result do
    encoding "xml"
    collect xpath(response, "//GetCallerIdentityResponse/GetCallerIdentityResult") do
      field "account", xpath(col_item, "Account")
    end
  end
end

datasource "ds_aws_account" do
  run_script $js_aws_account, $ds_cloud_vendor_accounts, $ds_get_caller_identity
end

script "js_aws_account", type: "javascript" do
  parameters "ds_cloud_vendor_accounts", "ds_get_caller_identity"
  result "result"
  code <<-'EOS'
  result = _.find(ds_cloud_vendor_accounts, function(account) {
    return account['id'] == ds_get_caller_identity[0]['account']
  })
  if (result == undefined) {
    result = {
      id: ds_get_caller_identity[0]['account'],
      name: "",
      tags: {}
    }
  }
EOS
end

datasource "ds_currency_reference" do
  request do
    host "raw.githubusercontent.com"
    path "/flexera-public/policy_templates/master/data/currency/currency_reference.json"
    header "User-Agent", "RS Policies"
  end
end

datasource "ds_currency_code" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/bill-analysis/orgs/", rs_org_id, "/settings/currency_code"])
    header "Api-Version", "0.1"
    header "User-Agent", "RS Policies"
    ignore_status [403]
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
    field "value", jmes_path(response, "value")
  end
end

datasource "ds_currency" do
  run_script $js_currency, $ds_currency_reference, $ds_currency_code
end

script "js_currency", type: "javascript" do
  parameters "ds_currency_reference", "ds_currency_code"
  result "result"
  code <<-'EOS'
  symbol = "$"
  separator = ","
  if (ds_currency_code['value'] != undefined) {
    if (ds_currency_reference[ds_currency_code['value']] != undefined) {
      symbol = ds_currency_reference[ds_currency_code['value']]['symbol']
      if (ds_currency_reference[ds_currency_code['value']]['t_separator'] != undefined) {
        separator = ds_currency_reference[ds_currency_code['value']]['t_separator']
      } else {
        separator = ""
      }
    }
  }
  result = { symbol: symbol, separator: separator }
EOS
end

datasource "ds_describe_regions" do
  request do
    auth $auth_aws
    host "ec2.amazonaws.com"
    path "/"
    query "Action", "DescribeRegions"
    query "Version", "2016-11-15"
    query "Filter.1.Name", "opt-in-status"
    query "Filter.1.Value.1", "opt-in-not-required"
    query "Filter.1.Value.2", "opted-in"
    header "Meta-Flexera", val($ds_is_deleted, "path")
  end
  result do
    encoding "xml"
    collect xpath(response, "//DescribeRegionsResponse/regionInfo/item", "array") do
      field "region", xpath(col_item, "regionName")
    end
  end
end

datasource "ds_regions" do
  run_script $js_regions, $ds_describe_regions, $param_regions_list, $param_regions_allow_or_deny
end

script "js_regions", type: "javascript" do
  parameters "ds_describe_regions", "param_regions_list", "param_regions_allow_or_deny"
  result "result"
  code <<-'EOS'
  allow_deny_test = { "Allow": true, "Deny": false }
  if (param_regions_list.length > 0) {
    result = _.filter(ds_describe_regions, function(item) {
      return _.contains(param_regions_list, item['region']) == allow_deny_test[param_regions_allow_or_deny]
    })
  } else {
    result = ds_describe_regions
  }
EOS
end

# Probe each region for accessibility (lightweight EC2 call; ASGs and EC2 share the same regional opt-in)
datasource "ds_region_check" do
  iterate $ds_regions
  request do
    auth $auth_aws
    host join(["autoscaling.", val(iter_item, "region"), ".amazonaws.com"])
    path "/"
    query "Action", "DescribeAutoScalingGroups"
    query "Version", "2011-01-01"
    query "MaxRecords", "1"
    header "User-Agent", "RS Policies"
    header "Content-Type", "text/xml"
    ignore_status [403, 401]
  end
  result do
    encoding "xml"
    field "region", val(iter_item, "region")
    field "status", "OK"
  end
end

datasource "ds_aws_asgs_raw" do
  iterate $ds_regions
  request do
    auth $auth_aws
    pagination $pagination_aws_asg_xml
    host join(["autoscaling.", val(iter_item, "region"), ".amazonaws.com"])
    path "/"
    query "Action", "DescribeAutoScalingGroups"
    query "Version", "2011-01-01"
    header "User-Agent", "RS Policies"
    header "Content-Type", "text/xml"
    ignore_status [403, 401, 404]
  end
  result do
    encoding "xml"
    collect xpath(response, "//DescribeAutoScalingGroupsResponse/DescribeAutoScalingGroupsResult/AutoScalingGroups/member", "array") do
      field "region", val(iter_item, "region")
      field "name", xpath(col_item, "AutoScalingGroupName")
      field "arn", xpath(col_item, "AutoScalingGroupARN")
      field "minSize", xpath(col_item, "MinSize")
      field "maxSize", xpath(col_item, "MaxSize")
      field "desiredCapacity", xpath(col_item, "DesiredCapacity")
      field "createdTime", xpath(col_item, "CreatedTime")
      field "launchConfigurationName", xpath(col_item, "LaunchConfigurationName")
      field "launchTemplateId", xpath(col_item, "LaunchTemplate/LaunchTemplateId")
      field "launchTemplateName", xpath(col_item, "LaunchTemplate/LaunchTemplateName")
      field "launchTemplateVersion", xpath(col_item, "LaunchTemplate/Version")
      field "mixedInstanceType", xpath(col_item, "MixedInstancesPolicy/LaunchTemplate/Overrides/member/InstanceType")
      field "availabilityZones" do
        collect xpath(col_item, "AvailabilityZones/member", "array") do
          field "az", xpath(col_item, ".")
        end
      end
      field "instances" do
        collect xpath(col_item, "Instances/member", "array") do
          field "instanceId", xpath(col_item, "InstanceId")
          field "lifecycleState", xpath(col_item, "LifecycleState")
          field "healthStatus", xpath(col_item, "HealthStatus")
          field "availabilityZone", xpath(col_item, "AvailabilityZone")
          field "instanceType", xpath(col_item, "InstanceType")
        end
      end
      field "tags" do
        collect xpath(col_item, "Tags/member", "array") do
          field "key", xpath(col_item, "Key")
          field "value", xpath(col_item, "Value")
        end
      end
      field "enabledMetrics" do
        collect xpath(col_item, "EnabledMetrics/member", "array") do
          field "metric", xpath(col_item, "Metric")
          field "granularity", xpath(col_item, "Granularity")
        end
      end
    end
  end
end

# Fetch all scaling policies per region (one call per region rather than per ASG)
datasource "ds_aws_scaling_policies" do
  iterate $ds_regions
  request do
    auth $auth_aws
    pagination $pagination_aws_policies_xml
    host join(["autoscaling.", val(iter_item, "region"), ".amazonaws.com"])
    path "/"
    query "Action", "DescribePolicies"
    query "Version", "2011-01-01"
    header "User-Agent", "RS Policies"
    header "Content-Type", "text/xml"
    ignore_status [403, 401, 404]
  end
  result do
    encoding "xml"
    collect xpath(response, "//DescribePoliciesResponse/DescribePoliciesResult/ScalingPolicies/member", "array") do
      field "region", val(iter_item, "region")
      field "asgName", xpath(col_item, "AutoScalingGroupName")
      field "policyName", xpath(col_item, "PolicyName")
      field "policyType", xpath(col_item, "PolicyType")
    end
  end
end

# Filter ASGs early so per-ASG API calls (scaling activities, CloudWatch metrics) are
# only issued for ASGs that could possibly produce findings #1/#2/#3. Tag-excluded and
# too-young ASGs are dropped here. Findings #4 (group metrics disabled) still iterates
# the unfiltered ds_aws_asgs_raw because hygiene findings ignore the exclusion-tag filter
# and only need EnabledMetrics from the raw ASG response.
datasource "ds_aws_asgs_filtered" do
  run_script $js_aws_asgs_filtered, $ds_aws_asgs_raw, $param_stats_lookback, $param_min_age_days, $param_exclusion_tags, $param_exclusion_tags_boolean, $param_findings
end

script "js_aws_asgs_filtered", type: "javascript" do
  parameters "ds_aws_asgs_raw", "param_stats_lookback", "param_min_age_days", "param_exclusion_tags", "param_exclusion_tags_boolean", "param_findings"
  result "result"
  code <<-'EOS'
  // If only finding #4 (group metrics disabled) is selected, no per-ASG metric/activity
  // data is needed. Skip the downstream API calls entirely.
  needs_metrics = _.contains(param_findings, "Fixed-size ASG") || _.contains(param_findings, "Never Moved Off Floor") || _.contains(param_findings, "Over-provisioned Floor")

  if (!needs_metrics) {
    result = []
  } else {
    comparators = _.map(param_exclusion_tags, function(item) {
      if (item.indexOf('==') != -1) { return { comparison: '==', key: item.split('==')[0], value: item.split('==')[1], string: item } }
      if (item.indexOf('!=') != -1) { return { comparison: '!=', key: item.split('!=')[0], value: item.split('!=')[1], string: item } }
      if (item.indexOf('=~') != -1) {
        v = item.split('=~')[1]
        return { comparison: '=~', key: item.split('=~')[0], value: new RegExp(v.slice(1, v.length - 1)), string: item }
      }
      if (item.indexOf('!~') != -1) {
        v = item.split('!~')[1]
        return { comparison: '!~', key: item.split('!~')[0], value: new RegExp(v.slice(1, v.length - 1)), string: item }
      }
      if (item.indexOf('=') != -1) { return { comparison: '==', key: item.split('=')[0], value: item.split('=')[1], string: item } }
      return { comparison: 'key', key: item, value: null, string: item }
    })

    // 0 disables the filter; any positive value is the floor.
    effective_min_age = param_min_age_days
    now_ts = new Date().getTime()

    result = _.filter(ds_aws_asgs_raw, function(asg) {
      // Age filter (only when effective_min_age > 0)
      if (effective_min_age > 0 && asg['createdTime']) {
        var age_days = Math.floor((now_ts - new Date(asg['createdTime']).getTime()) / 86400000)
        if (age_days < effective_min_age) { return false }
      }

      // Tag-exclusion filter
      if (comparators.length > 0) {
        tag_map = {}
        if (asg['tags'] && asg['tags'].length > 0) {
          _.each(asg['tags'], function(t) { tag_map[t['key']] = t['value'] })
        }
        found = []
        _.each(comparators, function(c) {
          rt = tag_map[c['key']]
          if (c['comparison'] == 'key' && rt != undefined) { found.push(c['string']) }
          if (c['comparison'] == '==' && rt == c['value']) { found.push(c['string']) }
          if (c['comparison'] == '!=' && rt != c['value']) { found.push(c['string']) }
          if (c['comparison'] == '=~' && rt != undefined && c['value'].test(rt)) { found.push(c['string']) }
          if (c['comparison'] == '!~' && (rt == undefined || !c['value'].test(rt))) { found.push(c['string']) }
        })
        excluded = (param_exclusion_tags_boolean == 'All') ? (found.length == comparators.length) : (found.length > 0)
        if (excluded) { return false }
      }

      return true
    })
  }
EOS
end

# Subset of filtered ASGs that actually need scaling-activity history. ASGs whose group metrics
# include both GroupInServiceInstances and GroupDesiredCapacity can derive desired-moved-off-floor
# from CloudWatch alone, so the per-ASG DescribeScalingActivities call is unnecessary for them.
datasource "ds_aws_asgs_needs_activities" do
  run_script $js_aws_asgs_needs_activities, $ds_aws_asgs_filtered
end

script "js_aws_asgs_needs_activities", type: "javascript" do
  parameters "ds_aws_asgs_filtered"
  result "result"
  code <<-'EOS'
  result = _.filter(ds_aws_asgs_filtered, function(asg) {
    var enabled = []
    if (asg['enabledMetrics'] && asg['enabledMetrics'].length > 0) {
      enabled = _.pluck(asg['enabledMetrics'], 'metric')
    }
    // Need activities only when CloudWatch can't tell us whether desired moved
    return !(_.contains(enabled, 'GroupInServiceInstances') && _.contains(enabled, 'GroupDesiredCapacity'))
  })
EOS
end

# Fetch scaling activities per ASG (cannot batch; one call per ASG)
datasource "ds_aws_scaling_activities" do
  iterate $ds_aws_asgs_needs_activities
  request do
    auth $auth_aws
    pagination $pagination_aws_activities_xml
    host join(["autoscaling.", val(iter_item, "region"), ".amazonaws.com"])
    path "/"
    query "Action", "DescribeScalingActivities"
    query "Version", "2011-01-01"
    query "AutoScalingGroupName", val(iter_item, "name")
    query "MaxRecords", "100"
    header "User-Agent", "RS Policies"
    header "Content-Type", "text/xml"
    ignore_status [403, 401, 404]
  end
  result do
    encoding "xml"
    collect xpath(response, "//DescribeScalingActivitiesResponse/DescribeScalingActivitiesResult/Activities/member", "array") do
      field "region", val(iter_item, "region")
      field "asgName", val(iter_item, "name")
      field "activityId", xpath(col_item, "ActivityId")
      field "statusCode", xpath(col_item, "StatusCode")
      field "startTime", xpath(col_item, "StartTime")
      field "description", xpath(col_item, "Description")
      field "cause", xpath(col_item, "Cause")
    end
  end
end

# Build CloudWatch GetMetricData queries: per ASG, group metrics (if enabled) + aggregate CPU
datasource "ds_cloudwatch_queries" do
  run_script $js_cloudwatch_queries, $ds_aws_asgs_filtered, $param_stats_period
end

script "js_cloudwatch_queries", type: "javascript" do
  parameters "ds_aws_asgs_filtered", "param_stats_period"
  result "result"
  code <<-'EOS'
  // Build queries grouped by region. CloudWatch metric IDs must match [a-zA-Z][a-zA-Z0-9_]*
  result = {}

  _.each(ds_aws_asgs_filtered, function(asg) {
    if (result[asg['region']] == undefined) { result[asg['region']] = [] }

    // Sanitize ASG name to a valid CloudWatch query Id; ensure leading letter
    // CloudWatch GetMetricData requires Id to match ^[a-z][a-zA-Z0-9_]*$.
    // Always prefix with a lowercase letter to satisfy the leading-char rule
    // regardless of whether the ASG name starts with a digit or an uppercase letter.
    cw_id = 'a_' + asg['name'].replace(/[^a-zA-Z0-9]/g, '_')
    if (cw_id.length > 240) { cw_id = cw_id.substring(0, 240) }

    // Determine whether group metrics are enabled at all; only request them if so to avoid wasted queries
    enabled = []
    if (asg['enabledMetrics'] && asg['enabledMetrics'].length > 0) {
      enabled = _.pluck(asg['enabledMetrics'], 'metric')
    }

    group_metrics = [
      { metric: 'GroupInServiceInstances', stat: 'Maximum', suffix: 'gisMax' },
      { metric: 'GroupInServiceInstances', stat: 'Minimum', suffix: 'gisMin' },
      { metric: 'GroupDesiredCapacity', stat: 'Maximum', suffix: 'gdcMax' },
      { metric: 'GroupDesiredCapacity', stat: 'Minimum', suffix: 'gdcMin' },
      { metric: 'GroupTotalInstances', stat: 'Maximum', suffix: 'gtiMax' }
    ]

    _.each(group_metrics, function(gm) {
      if (_.contains(enabled, gm.metric)) {
        result[asg['region']].push({
          "Id": cw_id + "_" + gm.suffix,
          "MetricStat": {
            "Metric": {
              "Namespace": "AWS/AutoScaling",
              "MetricName": gm.metric,
              "Dimensions": [{ "Name": "AutoScalingGroupName", "Value": asg['name'] }]
            },
            "Period": param_stats_period,
            "Stat": gm.stat
          },
          "ReturnData": true
        })
      }
    })

    // Aggregate CPU is always available via AWS/EC2 namespace dimensioned by AutoScalingGroupName
    cpu_stats = [
      { stat: 'Average', suffix: 'cpuAvg' },
      { stat: 'Maximum', suffix: 'cpuMax' },
      { stat: 'p95', suffix: 'cpuP95' }
    ]

    _.each(cpu_stats, function(s) {
      result[asg['region']].push({
        "Id": cw_id + "_" + s.suffix,
        "MetricStat": {
          "Metric": {
            "Namespace": "AWS/EC2",
            "MetricName": "CPUUtilization",
            "Dimensions": [{ "Name": "AutoScalingGroupName", "Value": asg['name'] }]
          },
          "Period": param_stats_period,
          "Stat": s.stat
        },
        "ReturnData": true
      })
    })
  })
EOS
end

# Combine queries into chunks for bulk GetMetricData calls. Chunk size is computed from the
# lookback period and aggregation period so the per-call datapoint cap (100,800) is not exceeded.
datasource "ds_cloudwatch_requests" do
  run_script $js_cloudwatch_requests, $ds_cloudwatch_queries, $param_stats_lookback, $param_stats_period
end

script "js_cloudwatch_requests", type: "javascript" do
  parameters "ds_cloudwatch_queries", "param_stats_lookback", "param_stats_period"
  result "result"
  code <<-'EOS'
  result = []

  // GetMetricData caps each call at 500 metric specs OR 100,800 datapoints, whichever is smaller.
  // datapoints_per_query = lookback_seconds / period.
  datapoints_per_query = Math.ceil((param_stats_lookback * 86400) / param_stats_period)
  query_block_size = Math.min(500, Math.floor(100800 / Math.max(datapoints_per_query, 1)))
  if (query_block_size < 1) { query_block_size = 1 }

  end_date = new Date()
  end_date.setMinutes(0, 0, 0)
  end_date = parseInt(end_date.getTime() / 1000)

  start_date = new Date()
  start_date.setDate(start_date.getDate() - param_stats_lookback)
  start_date.setMinutes(0, 0, 0)
  start_date = parseInt(start_date.getTime() / 1000)

  _.each(_.keys(ds_cloudwatch_queries), function(region) {
    for (var i = 0; i < ds_cloudwatch_queries[region].length; i += query_block_size) {
      chunk = ds_cloudwatch_queries[region].slice(i, i + query_block_size)
      result.push({
        body: {
          "StartTime": start_date,
          "EndTime": end_date,
          "MetricDataQueries": chunk
        },
        region: region
      })
    }
  })
EOS
end

datasource "ds_cloudwatch_data" do
  iterate $ds_cloudwatch_requests
  request do
    run_script $js_cloudwatch_data, val(iter_item, "region"), val(iter_item, "body")
  end
  result do
    encoding "json"
    collect jmes_path(response, "MetricDataResults[*]") do
      field "region", val(iter_item, "region")
      field "id", jmes_path(col_item, "Id")
      field "values", jmes_path(col_item, "Values")
    end
  end
end

script "js_cloudwatch_data", type: "javascript" do
  parameters "region", "body"
  result "request"
  code <<-'EOS'
  // Pace requests to avoid CloudWatch throttling
  api_wait = 5
  var now = new Date().getTime()
  while (new Date().getTime() < now + (api_wait * 1000)) { /* spin */ }

  var request = {
    auth: "auth_aws",
    host: "monitoring." + region + ".amazonaws.com",
    verb: "POST",
    path: "/",
    query_params: { "Version": "2010-08-01" },
    headers: {
      "User-Agent": "RS Policies",
      "Content-Type": "application/json",
      "x-amz-target": "GraniteServiceVersion20100801.GetMetricData",
      "Accept": "application/json",
      "Content-Encoding": "amz-1.0"
    },
    body: JSON.stringify(body)
  }
EOS
end

datasource "ds_cloudwatch_data_sorted" do
  run_script $js_cloudwatch_data_sorted, $ds_cloudwatch_data
end

script "js_cloudwatch_data_sorted", type: "javascript" do
  parameters "ds_cloudwatch_data"
  result "result"
  code <<-'EOS'
  // Reduce metric arrays into a single representative value: max for peak/aggregate-max metrics,
  // min for *Min metrics, and average for cpuAvg.
  function reduce_max(values) {
    if (!values || values.length == 0) { return null }
    var m = values[0]
    for (var i = 1; i < values.length; i++) { if (values[i] > m) { m = values[i] } }
    return m
  }
  function reduce_min(values) {
    if (!values || values.length == 0) { return null }
    var m = values[0]
    for (var i = 1; i < values.length; i++) { if (values[i] < m) { m = values[i] } }
    return m
  }
  function reduce_avg(values) {
    if (!values || values.length == 0) { return null }
    var s = 0
    for (var i = 0; i < values.length; i++) { s += values[i] }
    return s / values.length
  }

  result = {}

  _.each(ds_cloudwatch_data, function(item) {
    region = item['region']
    if (result[region] == undefined) { result[region] = {} }

    // ID format is "<sanitized_asg_name>_<suffix>" -- recover the sanitized name and suffix
    parts = item['id'].split('_')
    suffix = parts[parts.length - 1]
    asg_id = item['id'].substring(0, item['id'].length - suffix.length - 1)

    if (result[region][asg_id] == undefined) { result[region][asg_id] = {} }

    if (suffix == 'gisMax' || suffix == 'gdcMax' || suffix == 'gtiMax' || suffix == 'cpuMax' || suffix == 'cpuP95') {
      result[region][asg_id][suffix] = reduce_max(item['values'])
    } else if (suffix == 'gisMin' || suffix == 'gdcMin') {
      result[region][asg_id][suffix] = reduce_min(item['values'])
    } else if (suffix == 'cpuAvg') {
      result[region][asg_id][suffix] = reduce_avg(item['values'])
    }
  })
EOS
end

# Pull on-demand-equivalent (list-price) and amortized cost per EC2 Compute Instance resource_id
datasource "ds_instance_costs" do
  request do
    run_script $js_instance_costs, $ds_aws_account, $ds_top_level_bcs, rs_org_id, rs_optima_host
  end
  result do
    encoding "json"
    collect jmes_path(response, "rows[*]") do
      field "resourceId", jmes_path(col_item, "dimensions.resource_id")
      field "listCost", jmes_path(col_item, "metrics.cost_list_price")
      field "amortizedCost", jmes_path(col_item, "metrics.cost_amortized_unblended_adj")
    end
  end
end

script "js_instance_costs", type: "javascript" do
  parameters "ds_aws_account", "ds_top_level_bcs", "rs_org_id", "rs_optima_host"
  result "request"
  code <<-'EOS'
  end_date = new Date()
  end_date.setDate(end_date.getDate() - 2)
  end_date = end_date.toISOString().split('T')[0]

  start_date = new Date()
  start_date.setDate(start_date.getDate() - 3)
  start_date = start_date.toISOString().split('T')[0]

  var request = {
    auth: "auth_flexera",
    host: rs_optima_host,
    verb: "POST",
    path: "/bill-analysis/orgs/" + rs_org_id + "/costs/select",
    body_fields: {
      dimensions: ["resource_id"],
      granularity: "day",
      start_at: start_date,
      end_at: end_date,
      metrics: ["cost_list_price", "cost_amortized_unblended_adj"],
      billing_center_ids: ds_top_level_bcs,
      limit: 100000,
      filter: {
        type: "and",
        expressions: [
          { dimension: "service", type: "equal", value: "AmazonEC2" },
          { dimension: "resource_type", type: "equal", value: "Compute Instance" },
          { dimension: "vendor_account", type: "equal", value: ds_aws_account['id'] }
        ]
      }
    },
    headers: {
      "User-Agent": "RS Policies",
      "Api-Version": "1.0"
    },
    ignore_status: [400]
  }
EOS
end

datasource "ds_instance_costs_grouped" do
  run_script $js_instance_costs_grouped, $ds_instance_costs
end

script "js_instance_costs_grouped", type: "javascript" do
  parameters "ds_instance_costs"
  result "result"
  code <<-'EOS'
  // Map instance_id (lowercase) -> { listDaily, amortizedDaily }. Costs in the bill are for one day each.
  result = {}

  _.each(ds_instance_costs, function(item) {
    if (!item['resourceId']) { return }
    id = item['resourceId'].toLowerCase()
    if (result[id] == undefined) { result[id] = { listDaily: 0.0, amortizedDaily: 0.0 } }
    if (item['listCost']) { result[id]['listDaily'] += item['listCost'] }
    if (item['amortizedCost']) { result[id]['amortizedDaily'] += item['amortizedCost'] }
  })
EOS
end

# Combine ASG list with policies, activities, metrics, costs, and apply tag/age exclusions
datasource "ds_asg_processed" do
  run_script $js_asg_processed, $ds_aws_asgs_raw, $ds_aws_scaling_policies, $ds_aws_scaling_activities, $ds_cloudwatch_data_sorted, $ds_instance_costs_grouped, $param_stats_lookback, $param_min_age_days, $param_exclusion_tags, $param_exclusion_tags_boolean
end

script "js_asg_processed", type: "javascript" do
  parameters "ds_aws_asgs_raw", "ds_aws_scaling_policies", "ds_aws_scaling_activities", "ds_cloudwatch_data_sorted", "ds_instance_costs_grouped", "param_stats_lookback", "param_min_age_days", "param_exclusion_tags", "param_exclusion_tags_boolean"
  result "result"
  code <<-'EOS'
  // Build tag-exclusion comparators (standard catalog pattern)
  comparators = _.map(param_exclusion_tags, function(item) {
    if (item.indexOf('==') != -1) { return { comparison: '==', key: item.split('==')[0], value: item.split('==')[1], string: item } }
    if (item.indexOf('!=') != -1) { return { comparison: '!=', key: item.split('!=')[0], value: item.split('!=')[1], string: item } }
    if (item.indexOf('=~') != -1) {
      v = item.split('=~')[1]
      return { comparison: '=~', key: item.split('=~')[0], value: new RegExp(v.slice(1, v.length - 1)), string: item }
    }
    if (item.indexOf('!~') != -1) {
      v = item.split('!~')[1]
      return { comparison: '!~', key: item.split('!~')[0], value: new RegExp(v.slice(1, v.length - 1)), string: item }
    }
    if (item.indexOf('=') != -1) { return { comparison: '==', key: item.split('=')[0], value: item.split('=')[1], string: item } }
    return { comparison: 'key', key: item, value: null, string: item }
  })

  // Effective minimum age: 0 disables the filter; any positive value is the floor.
  effective_min_age = param_min_age_days

  // Group scaling-policy and scaling-activity data by ASG name (region-qualified key)
  policies_by_asg = {}
  _.each(ds_aws_scaling_policies, function(p) {
    key = p['region'] + '|' + p['asgName']
    if (policies_by_asg[key] == undefined) { policies_by_asg[key] = [] }
    policies_by_asg[key].push(p['policyType'] || 'Unknown')
  })

  activities_by_asg = {}
  _.each(ds_aws_scaling_activities, function(a) {
    key = a['region'] + '|' + a['asgName']
    if (activities_by_asg[key] == undefined) { activities_by_asg[key] = [] }
    activities_by_asg[key].push(a)
  })

  now_ts = new Date().getTime()
  lookback_ms = param_stats_lookback * 86400 * 1000

  result = []

  _.each(ds_aws_asgs_raw, function(asg) {
    // CloudWatch GetMetricData requires Id to match ^[a-z][a-zA-Z0-9_]*$.
    // Always prefix with a lowercase letter to satisfy the leading-char rule
    // regardless of whether the ASG name starts with a digit or an uppercase letter.
    cw_id = 'a_' + asg['name'].replace(/[^a-zA-Z0-9]/g, '_')
    if (cw_id.length > 240) { cw_id = cw_id.substring(0, 240) }

    metrics = (ds_cloudwatch_data_sorted[asg['region']] && ds_cloudwatch_data_sorted[asg['region']][cw_id]) || {}

    // Tag map and exclusion check
    tag_map = {}
    if (asg['tags'] && asg['tags'].length > 0) {
      _.each(asg['tags'], function(t) { tag_map[t['key']] = t['value'] })
    }

    excluded_by_tag = false
    if (comparators.length > 0) {
      found = []
      _.each(comparators, function(c) {
        rt = tag_map[c['key']]
        if (c['comparison'] == 'key' && rt != undefined) { found.push(c['string']) }
        if (c['comparison'] == '==' && rt == c['value']) { found.push(c['string']) }
        if (c['comparison'] == '!=' && rt != c['value']) { found.push(c['string']) }
        if (c['comparison'] == '=~' && rt != undefined && c['value'].test(rt)) { found.push(c['string']) }
        if (c['comparison'] == '!~' && (rt == undefined || !c['value'].test(rt))) { found.push(c['string']) }
      })
      excluded_by_tag = (param_exclusion_tags_boolean == 'All') ? (found.length == comparators.length) : (found.length > 0)
    }

    // Age in days
    age_days = null
    if (asg['createdTime']) {
      try {
        age_days = Math.floor((now_ts - new Date(asg['createdTime']).getTime()) / 86400000)
      } catch (e) { age_days = null }
    }
    too_young = (effective_min_age > 0 && age_days != null && age_days < effective_min_age)

    // Group-metrics enabled detection
    enabled_metrics = []
    if (asg['enabledMetrics'] && asg['enabledMetrics'].length > 0) {
      enabled_metrics = _.pluck(asg['enabledMetrics'], 'metric')
    }
    needed_group_metrics = ['GroupInServiceInstances', 'GroupDesiredCapacity', 'GroupTotalInstances']
    missing_group_metrics = _.difference(needed_group_metrics, enabled_metrics)
    group_metrics_enabled = missing_group_metrics.length == 0

    peak_in_service = metrics['gisMax']
    min_in_service = metrics['gisMin']
    peak_desired = metrics['gdcMax']
    min_desired = metrics['gdcMin']
    avg_cpu = metrics['cpuAvg']
    max_cpu = metrics['cpuMax']
    p95_cpu = metrics['cpuP95']

    minSize = parseInt(asg['minSize'])
    maxSize = parseInt(asg['maxSize'])
    desired = parseInt(asg['desiredCapacity'])

    // headroom_ratio meaningful only if group metrics are on AND minSize > 0
    headroom_ratio = null
    if (peak_in_service != null && minSize > 0) {
      headroom_ratio = peak_in_service / minSize
    }

    // Activity-based capacity-change count over the lookback (count successful activities only)
    asg_key = asg['region'] + '|' + asg['name']
    activities = activities_by_asg[asg_key] || []
    capacity_change_count = 0
    _.each(activities, function(a) {
      if (a['startTime']) {
        var st = new Date(a['startTime']).getTime()
        if (st >= (now_ts - lookback_ms)) {
          // Capacity-changing activities have descriptions like "Launching a new EC2 instance" or "Terminating EC2 instance".
          // Count any successful activity in the window as a capacity change; ASG only logs scaling events.
          if (a['statusCode'] == 'Successful' || a['statusCode'] == 'PreInService' || a['statusCode'] == 'InProgress') {
            var d = (a['description'] || '').toLowerCase()
            if (d.indexOf('launching') != -1 || d.indexOf('terminating') != -1 || d.indexOf('replacing') != -1) {
              capacity_change_count += 1
            }
          }
        }
      }
    })

    // desired_moved_off_floor: prefer group metrics (gdcMin != gdcMax) when on; otherwise infer from activities
    desired_moved_off_floor = null
    if (group_metrics_enabled && peak_desired != null && min_desired != null) {
      desired_moved_off_floor = (peak_desired != min_desired) || (peak_desired != minSize)
    } else if (capacity_change_count > 0) {
      desired_moved_off_floor = true
    } else if (capacity_change_count == 0 && activities.length > 0) {
      desired_moved_off_floor = false
    }

    // Resolve a representative instance type
    instance_type = null
    if (asg['instances'] && asg['instances'].length > 0) {
      instance_type = asg['instances'][0]['instanceType']
    }
    if (!instance_type && asg['mixedInstanceType']) { instance_type = asg['mixedInstanceType'] }

    // On-demand-equivalent per-instance daily cost from CCO list-price
    list_daily_per_instance = null
    amortized_daily_per_instance = null
    matched_instance_count = 0
    list_total = 0.0
    amort_total = 0.0
    if (asg['instances'] && asg['instances'].length > 0) {
      _.each(asg['instances'], function(inst) {
        if (inst['instanceId']) {
          c = ds_instance_costs_grouped[inst['instanceId'].toLowerCase()]
          if (c) {
            list_total += c['listDaily'] || 0
            amort_total += c['amortizedDaily'] || 0
            matched_instance_count += 1
          }
        }
      })
      if (matched_instance_count > 0) {
        list_daily_per_instance = list_total / matched_instance_count
        amortized_daily_per_instance = amort_total / matched_instance_count
      }
    }

    days_per_month = 30.44
    floor_monthly_on_demand_equiv = (list_daily_per_instance != null && minSize > 0) ? minSize * list_daily_per_instance * days_per_month : null
    unused_floor_monthly_max = null
    if (list_daily_per_instance != null && peak_in_service != null && minSize > peak_in_service) {
      unused_floor_monthly_max = (minSize - peak_in_service) * list_daily_per_instance * days_per_month
    }

    // Tag display string (Key=Value pairs joined)
    tag_str = []
    _.each(Object.keys(tag_map), function(k) { tag_str.push(k + '=' + tag_map[k]) })

    asg_policy_types = policies_by_asg[asg_key] || []

    result.push({
      region: asg['region'],
      name: asg['name'],
      arn: asg['arn'],
      minSize: minSize,
      maxSize: maxSize,
      desired: desired,
      createdTime: asg['createdTime'],
      ageDays: age_days,
      tooYoung: too_young,
      excludedByTag: excluded_by_tag,
      tagDisplay: tag_str.join(', '),
      tagMap: tag_map,
      resourceType: instance_type || '',
      azCount: (asg['availabilityZones'] || []).length,
      enabledMetrics: enabled_metrics,
      missingGroupMetrics: missing_group_metrics,
      groupMetricsEnabled: group_metrics_enabled,
      peakInService: peak_in_service,
      minInService: min_in_service,
      peakDesired: peak_desired,
      minDesired: min_desired,
      cpuAverage: avg_cpu,
      cpuMaximum: max_cpu,
      cpuP95: p95_cpu,
      headroomRatio: headroom_ratio,
      capacityChangeCount: capacity_change_count,
      desiredMovedOffFloor: desired_moved_off_floor,
      hasScalingPolicies: asg_policy_types.length > 0,
      scalingPolicyTypes: _.uniq(asg_policy_types).join(', '),
      listDailyPerInstance: list_daily_per_instance,
      amortizedDailyPerInstance: amortized_daily_per_instance,
      floorMonthlyOnDemandEquiv: floor_monthly_on_demand_equiv,
      unusedFloorMonthlyMax: unused_floor_monthly_max
    })
  })
EOS
end

###############################################################################
# Finding Datasources
###############################################################################

datasource "ds_finding_fixed_size" do
  run_script $js_finding_fixed_size, $ds_asg_processed, $ds_aws_account, $ds_currency, $ds_applied_policy, $param_stats_lookback, $param_findings, $param_incident_csv
end

script "js_finding_fixed_size", type: "javascript" do
  parameters "ds_asg_processed", "ds_aws_account", "ds_currency", "ds_applied_policy", "param_stats_lookback", "param_findings", "param_incident_csv"
  result "result"
  code <<-'EOS'
  function fmt(n) {
    if (n == null || n == undefined || isNaN(n)) { return 'n/a' }
    return (Math.round(n * 100) / 100).toString()
  }

  csv_message = param_incident_csv == "false" ? "" : "Incident table CSV file has been attached to emails for this incident."
  result = []
  total_spend = 0.0

  if (!_.contains(param_findings, "Fixed-size ASG")) { ds_asg_processed = [] }

  _.each(ds_asg_processed, function(asg) {
    if (asg['tooYoung']) { return }
    if (asg['excludedByTag']) { return }
    if (asg['minSize'] != asg['maxSize']) { return }
    if (asg['minSize'] != asg['desired']) { return }

    spend = asg['floorMonthlyOnDemandEquiv'] || 0
    total_spend += spend

    static_note = asg['hasScalingPolicies']
      ? "Scaling policies of type [" + asg['scalingPolicyTypes'] + "] exist but cannot fire because Min == Max."
      : "No scaling policies are configured; the group is definitively static."

    recDetails = "Auto Scaling Group '" + asg['name'] + "' has Min == Max == Desired (" + asg['minSize'] + "). " + static_note +
      " Review whether this group should be elastic at all. If intentionally static, treat as a candidate for Savings Plan / Reserved Instance commitment coverage, or evaluate moving the workload off Auto Scaling. Instance-type rightsizing is a separate analysis."

    result.push({
      accountID: ds_aws_account['id'],
      accountName: ds_aws_account['name'],
      resourceID: asg['name'],
      resourceName: asg['name'],
      region: asg['region'],
      finding: "Fixed-size ASG (Min = Max = Desired)",
      confidence: "High",
      minSize: asg['minSize'],
      maxSize: asg['maxSize'],
      desired: asg['desired'],
      resourceType: asg['resourceType'],
      azCount: asg['azCount'],
      ageDays: asg['ageDays'],
      hasScalingPolicies: asg['hasScalingPolicies'] ? "true" : "false",
      scalingPolicyTypes: asg['scalingPolicyTypes'],
      groupMetricsEnabled: asg['groupMetricsEnabled'] ? "true" : "false",
      peakInService: asg['peakInService'] == null ? '' : asg['peakInService'],
      cpuAverage: asg['cpuAverage'] == null ? '' : fmt(asg['cpuAverage']),
      cpuP95: asg['cpuP95'] == null ? '' : fmt(asg['cpuP95']),
      cpuMaximum: asg['cpuMaximum'] == null ? '' : fmt(asg['cpuMaximum']),
      lookbackPeriod: param_stats_lookback,
      tags: asg['tagDisplay'],
      monthlySpendOnDemandEquiv: spend > 0 ? Math.round(spend * 100) / 100 : '',
      spendCurrency: ds_currency['symbol'],
      spendLabel: "On-demand-equivalent (pre-commitment)",
      recommendationDetails: recDetails,
      service: "AmazonEC2",
      resourceARN: asg['arn'] || '',
      policy_name: ds_applied_policy['name'],
      message: '',
      total_spend: ''
    })
  })

  result = _.sortBy(result, function(r) { return -1 * (r['monthlySpendOnDemandEquiv'] || 0) })

  // Sentinel row so the policy's check evaluates even when there are no findings
  result.push({
    accountID: "", accountName: "", resourceID: "", resourceName: "", region: "",
    finding: "", confidence: "", minSize: "", maxSize: "", desired: "", resourceType: "",
    azCount: "", ageDays: "", hasScalingPolicies: "", scalingPolicyTypes: "",
    groupMetricsEnabled: "", peakInService: "", cpuAverage: "", cpuP95: "", cpuMaximum: "",
    lookbackPeriod: "", tags: "", monthlySpendOnDemandEquiv: "", spendCurrency: "",
    spendLabel: "", recommendationDetails: "", service: "", resourceARN: "", policy_name: "",
    message: "", total_spend: ""
  })

  total_count = result.length - 1
  formatted_total = ds_currency['symbol'] + (Math.round(total_spend * 100) / 100).toString()

  caveat = "Spend figures are on-demand-equivalent (cost_list_price from Flexera CCO) and do not net out existing Savings Plan / Reserved Instance coverage. Removing committed-rate baseline usage inside an active commitment window often yields no actual savings until the commitment expires. These numbers characterize spend; they are not savings claims."

  result[0]['message'] = total_count + " Auto Scaling Group(s) detected with Min == Max == Desired over the last " + param_stats_lookback + " day(s).\n\n" + caveat + "\n\n" + csv_message
  result[0]['total_spend'] = formatted_total
EOS
end

datasource "ds_finding_never_moved" do
  run_script $js_finding_never_moved, $ds_asg_processed, $ds_aws_account, $ds_currency, $ds_applied_policy, $param_stats_lookback, $param_findings, $param_incident_csv
end

script "js_finding_never_moved", type: "javascript" do
  parameters "ds_asg_processed", "ds_aws_account", "ds_currency", "ds_applied_policy", "param_stats_lookback", "param_findings", "param_incident_csv"
  result "result"
  code <<-'EOS'
  function fmt(n) {
    if (n == null || n == undefined || isNaN(n)) { return 'n/a' }
    return (Math.round(n * 100) / 100).toString()
  }

  csv_message = param_incident_csv == "false" ? "" : "Incident table CSV file has been attached to emails for this incident."
  result = []
  total_spend = 0.0

  if (!_.contains(param_findings, "Never Moved Off Floor")) { ds_asg_processed = [] }

  _.each(ds_asg_processed, function(asg) {
    if (asg['tooYoung']) { return }
    if (asg['excludedByTag']) { return }
    // Excluded if same as fixed-size finding
    if (asg['minSize'] == asg['maxSize']) { return }
    // Skip only when we have positive evidence the ASG DID move off the floor.
    // null (no signal at all) still surfaces — at very-reduced confidence per spec — so the
    // user can cross-reference the 'Group Metrics Collection Disabled' hygiene finding.
    if (asg['desiredMovedOffFloor'] == true) { return }

    spend = asg['floorMonthlyOnDemandEquiv'] || 0
    total_spend += spend

    if (asg['desiredMovedOffFloor'] == null) {
      confidence = "Very Reduced (group metrics disabled and scaling-activity history unavailable; see the 'Group Metrics Collection Disabled' finding)"
    } else if (asg['groupMetricsEnabled']) {
      confidence = "High"
    } else {
      confidence = "Reduced (group metrics disabled; relying on scaling-activity history only)"
    }

    if (asg['hasScalingPolicies']) {
      review_text = "Scaling policies exist (" + asg['scalingPolicyTypes'] + ") but never fired. Investigate the scaling-policy thresholds — they may be set such that the policy never trips."
    } else {
      review_text = "No scaling policies are configured; this group is effectively static even though MinSize < MaxSize. Consider whether the floor is the real steady state (commitment candidate) or whether scaling policies should be added."
    }

    recDetails = "Auto Scaling Group '" + asg['name'] + "' has MinSize=" + asg['minSize'] + " < MaxSize=" + asg['maxSize'] + " but Desired never moved off the floor over the last " + param_stats_lookback + " day(s) (capacity-changing activities observed: " + asg['capacityChangeCount'] + "). " + review_text

    result.push({
      accountID: ds_aws_account['id'],
      accountName: ds_aws_account['name'],
      resourceID: asg['name'],
      resourceName: asg['name'],
      region: asg['region'],
      finding: "Never Moved Off Floor",
      confidence: confidence,
      minSize: asg['minSize'],
      maxSize: asg['maxSize'],
      desired: asg['desired'],
      resourceType: asg['resourceType'],
      azCount: asg['azCount'],
      ageDays: asg['ageDays'],
      hasScalingPolicies: asg['hasScalingPolicies'] ? "true" : "false",
      scalingPolicyTypes: asg['scalingPolicyTypes'],
      groupMetricsEnabled: asg['groupMetricsEnabled'] ? "true" : "false",
      peakInService: asg['peakInService'] == null ? '' : asg['peakInService'],
      peakDesired: asg['peakDesired'] == null ? '' : asg['peakDesired'],
      capacityChangeCount: asg['capacityChangeCount'],
      cpuAverage: asg['cpuAverage'] == null ? '' : fmt(asg['cpuAverage']),
      cpuP95: asg['cpuP95'] == null ? '' : fmt(asg['cpuP95']),
      cpuMaximum: asg['cpuMaximum'] == null ? '' : fmt(asg['cpuMaximum']),
      lookbackPeriod: param_stats_lookback,
      tags: asg['tagDisplay'],
      monthlySpendOnDemandEquiv: spend > 0 ? Math.round(spend * 100) / 100 : '',
      spendCurrency: ds_currency['symbol'],
      spendLabel: "On-demand-equivalent (pre-commitment)",
      recommendationDetails: recDetails,
      service: "AmazonEC2",
      resourceARN: asg['arn'] || '',
      policy_name: ds_applied_policy['name'],
      message: '',
      total_spend: ''
    })
  })

  result = _.sortBy(result, function(r) { return -1 * (r['monthlySpendOnDemandEquiv'] || 0) })

  result.push({
    accountID: "", accountName: "", resourceID: "", resourceName: "", region: "",
    finding: "", confidence: "", minSize: "", maxSize: "", desired: "", resourceType: "",
    azCount: "", ageDays: "", hasScalingPolicies: "", scalingPolicyTypes: "",
    groupMetricsEnabled: "", peakInService: "", peakDesired: "", capacityChangeCount: "",
    cpuAverage: "", cpuP95: "", cpuMaximum: "", lookbackPeriod: "", tags: "",
    monthlySpendOnDemandEquiv: "", spendCurrency: "", spendLabel: "",
    recommendationDetails: "", service: "", resourceARN: "", policy_name: "",
    message: "", total_spend: ""
  })

  total_count = result.length - 1
  formatted_total = ds_currency['symbol'] + (Math.round(total_spend * 100) / 100).toString()

  caveat = "Spend figures are on-demand-equivalent (cost_list_price from Flexera CCO) and do not net out existing Savings Plan / Reserved Instance coverage. Removing committed-rate baseline usage inside an active commitment window often yields no actual savings until the commitment expires. These numbers characterize spend; they are not savings claims."

  result[0]['message'] = total_count + " elastic Auto Scaling Group(s) detected whose Desired capacity never moved off the floor over the last " + param_stats_lookback + " day(s).\n\n" + caveat + "\n\nIf group metrics are disabled for any of these groups, confidence is reduced — see the 'Group Metrics Collection Disabled' incident.\n\n" + csv_message
  result[0]['total_spend'] = formatted_total
EOS
end

datasource "ds_finding_overprovisioned" do
  run_script $js_finding_overprovisioned, $ds_asg_processed, $ds_aws_account, $ds_currency, $ds_applied_policy, $param_stats_lookback, $param_floor_headroom_ratio, $param_floor_cpu_threshold, $param_findings, $param_incident_csv
end

script "js_finding_overprovisioned", type: "javascript" do
  parameters "ds_asg_processed", "ds_aws_account", "ds_currency", "ds_applied_policy", "param_stats_lookback", "param_floor_headroom_ratio", "param_floor_cpu_threshold", "param_findings", "param_incident_csv"
  result "result"
  code <<-'EOS'
  function fmt(n) {
    if (n == null || n == undefined || isNaN(n)) { return 'n/a' }
    return (Math.round(n * 100) / 100).toString()
  }

  csv_message = param_incident_csv == "false" ? "" : "Incident table CSV file has been attached to emails for this incident."
  result = []
  total_spend = 0.0

  if (!_.contains(param_findings, "Over-provisioned Floor")) { ds_asg_processed = [] }

  _.each(ds_asg_processed, function(asg) {
    if (asg['tooYoung']) { return }
    if (asg['excludedByTag']) { return }
    if (asg['minSize'] <= 1) { return }
    // Skip if already a fixed-size group (covered by finding #1)
    if (asg['minSize'] == asg['maxSize']) { return }

    headroom_trigger = (asg['headroomRatio'] != null && asg['headroomRatio'] <= param_floor_headroom_ratio)
    cpu_trigger = (asg['cpuP95'] != null && asg['cpuP95'] <= param_floor_cpu_threshold)
    if (!headroom_trigger && !cpu_trigger) { return }

    spend = asg['unusedFloorMonthlyMax'] || 0
    total_spend += spend

    // Confidence: needs group metrics for headroom; degrade if only CPU evidence
    confidence = "Medium (review)"
    if (!asg['groupMetricsEnabled']) {
      confidence = "Reduced — group metrics disabled; relying on CPU only"
    }

    triggers = []
    if (headroom_trigger) {
      triggers.push("peak in-service / MinSize = " + fmt(asg['headroomRatio']) + " <= " + param_floor_headroom_ratio + " (peak in-service " + asg['peakInService'] + " of MinSize " + asg['minSize'] + ")")
    }
    if (cpu_trigger) {
      triggers.push("aggregate p95 CPU = " + fmt(asg['cpuP95']) + "% <= " + param_floor_cpu_threshold + "%")
    }

    recDetails = "Auto Scaling Group '" + asg['name'] + "' has MinSize=" + asg['minSize'] + " and exhibits low utilization at the floor over the last " + param_stats_lookback + " day(s). Triggers: " + triggers.join('; ') + ". The floor may exceed real need, but it may also be deliberate (AZ spread across " + asg['azCount'] + " AZ(s), burst headroom, latency targets). Review whether the floor can be lowered. The min is a resilience floor; do not reduce it without weighing intent."

    result.push({
      accountID: ds_aws_account['id'],
      accountName: ds_aws_account['name'],
      resourceID: asg['name'],
      resourceName: asg['name'],
      region: asg['region'],
      finding: "Over-provisioned Floor",
      confidence: confidence,
      minSize: asg['minSize'],
      maxSize: asg['maxSize'],
      desired: asg['desired'],
      resourceType: asg['resourceType'],
      azCount: asg['azCount'],
      ageDays: asg['ageDays'],
      hasScalingPolicies: asg['hasScalingPolicies'] ? "true" : "false",
      scalingPolicyTypes: asg['scalingPolicyTypes'],
      groupMetricsEnabled: asg['groupMetricsEnabled'] ? "true" : "false",
      peakInService: asg['peakInService'] == null ? '' : asg['peakInService'],
      headroomRatio: asg['headroomRatio'] == null ? '' : fmt(asg['headroomRatio']),
      cpuAverage: asg['cpuAverage'] == null ? '' : fmt(asg['cpuAverage']),
      cpuP95: asg['cpuP95'] == null ? '' : fmt(asg['cpuP95']),
      cpuMaximum: asg['cpuMaximum'] == null ? '' : fmt(asg['cpuMaximum']),
      lookbackPeriod: param_stats_lookback,
      tags: asg['tagDisplay'],
      monthlySpendOnDemandEquiv: spend > 0 ? Math.round(spend * 100) / 100 : '',
      spendCurrency: ds_currency['symbol'],
      spendLabel: "Theoretical maximum (assumes full elimination of unused floor; pre-commitment)",
      recommendationDetails: recDetails,
      service: "AmazonEC2",
      resourceARN: asg['arn'] || '',
      policy_name: ds_applied_policy['name'],
      message: '',
      total_spend: ''
    })
  })

  result = _.sortBy(result, function(r) { return -1 * (r['monthlySpendOnDemandEquiv'] || 0) })

  result.push({
    accountID: "", accountName: "", resourceID: "", resourceName: "", region: "",
    finding: "", confidence: "", minSize: "", maxSize: "", desired: "", resourceType: "",
    azCount: "", ageDays: "", hasScalingPolicies: "", scalingPolicyTypes: "",
    groupMetricsEnabled: "", peakInService: "", headroomRatio: "",
    cpuAverage: "", cpuP95: "", cpuMaximum: "", lookbackPeriod: "", tags: "",
    monthlySpendOnDemandEquiv: "", spendCurrency: "", spendLabel: "",
    recommendationDetails: "", service: "", resourceARN: "", policy_name: "",
    message: "", total_spend: ""
  })

  total_count = result.length - 1
  formatted_total = ds_currency['symbol'] + (Math.round(total_spend * 100) / 100).toString()

  caveat = "Spend figures are theoretical maxima — they assume the unused floor capacity is fully eliminated and ignore future scale-up needs. They are on-demand-equivalent (pre-commitment) and do not net out existing Savings Plan / Reserved Instance coverage. These are advisory; this is the most false-positive-prone of the four findings. The floor may be deliberately sized for AZ redundancy or burst headroom that the metrics do not capture."

  result[0]['message'] = total_count + " Auto Scaling Group(s) flagged for floor review (Min > 1 with low utilization).\n\n" + caveat + "\n\n" + csv_message
  result[0]['total_spend'] = formatted_total
EOS
end

datasource "ds_finding_metrics_disabled" do
  run_script $js_finding_metrics_disabled, $ds_asg_processed, $ds_aws_account, $ds_applied_policy, $param_findings, $param_incident_csv
end

script "js_finding_metrics_disabled", type: "javascript" do
  parameters "ds_asg_processed", "ds_aws_account", "ds_applied_policy", "param_findings", "param_incident_csv"
  result "result"
  code <<-'EOS'
  csv_message = param_incident_csv == "false" ? "" : "Incident table CSV file has been attached to emails for this incident."
  result = []

  if (!_.contains(param_findings, "Group Metrics Collection Disabled")) { ds_asg_processed = [] }

  _.each(ds_asg_processed, function(asg) {
    // Hygiene finding: ds_asg_processed iterates the unfiltered ds_aws_asgs_raw, so this
    // finding is raised even for tag-excluded or too-young ASGs by design.
    if (asg['groupMetricsEnabled']) { return }

    missing_str = (asg['missingGroupMetrics'] || []).join(', ')

    recDetails = "Auto Scaling Group '" + asg['name'] + "' is missing one or more group metrics (" + missing_str + "). Enable ASG group metrics collection (no additional cost; metrics are emitted to CloudWatch). This unblocks the 'Never Moved Off Floor' and 'Over-provisioned Floor' findings on the next policy run. Enable via the AWS console (ASG -> Monitoring -> Auto Scaling group metrics collection -> Enable) or via 'aws autoscaling enable-metrics-collection --auto-scaling-group-name " + asg['name'] + " --granularity 1Minute'."

    result.push({
      accountID: ds_aws_account['id'],
      accountName: ds_aws_account['name'],
      resourceID: asg['name'],
      resourceName: asg['name'],
      region: asg['region'],
      finding: "Group Metrics Collection Disabled",
      confidence: "Hygiene",
      minSize: asg['minSize'],
      maxSize: asg['maxSize'],
      desired: asg['desired'],
      resourceType: asg['resourceType'],
      azCount: asg['azCount'],
      ageDays: asg['ageDays'],
      missingGroupMetrics: missing_str,
      enabledMetrics: (asg['enabledMetrics'] || []).join(', '),
      tags: asg['tagDisplay'],
      recommendationDetails: recDetails,
      service: "AmazonEC2",
      resourceARN: asg['arn'] || '',
      policy_name: ds_applied_policy['name'],
      message: ''
    })
  })

  result = _.sortBy(result, 'resourceName')

  result.push({
    accountID: "", accountName: "", resourceID: "", resourceName: "", region: "",
    finding: "", confidence: "", minSize: "", maxSize: "", desired: "", resourceType: "",
    azCount: "", ageDays: "", missingGroupMetrics: "", enabledMetrics: "", tags: "",
    recommendationDetails: "", service: "", resourceARN: "", policy_name: "",
    message: ""
  })

  total_count = result.length - 1
  result[0]['message'] = total_count + " Auto Scaling Group(s) found with Group Metrics Collection Disabled. Enabling group metrics is free and unblocks elasticity analysis on the next run.\n\n" + csv_message
EOS
end

datasource "ds_identify_errors" do
  run_script $js_identify_errors, $ds_regions, $ds_region_check, $ds_applied_policy, $param_regions_allow_or_deny, $param_regions_list
end

script "js_identify_errors", type: "javascript" do
  parameters "ds_regions", "ds_region_check", "ds_applied_policy", "param_regions_allow_or_deny", "param_regions_list"
  result "errors"
  code <<-'EOS'
  var errors = []

  var region_responses = {}
  _.each(ds_region_check, function(item) {
    if (item.region) { region_responses[item.region] = "OK" }
  })

  var allowed_regions = _.keys(region_responses)
  var forbidden_regions = []

  _.each(ds_regions, function(region_obj) {
    if (!_.contains(allowed_regions, region_obj.region)) {
      forbidden_regions.push(region_obj.region)
    }
  })

  if (forbidden_regions.length > 0) {
    var regions_string = forbidden_regions.sort().join(", ")
    var successful_regions = allowed_regions.sort().join(", ")
    var filter_guidance = ""

    if (param_regions_list.length > 0) {
      filter_guidance = " You are currently using the 'Allow/Deny Regions List' parameter. You can update this list to exclude the inaccessible regions if appropriate."
    } else {
      filter_guidance = " You can use the 'Allow/Deny Regions List' parameter to exclude these regions from the policy scope."
    }

    errors.push(
      "HTTP error received when attempting to list Auto Scaling Groups in some AWS region(s).\n" +
      "\n - Failed Regions: " + regions_string +
      "\n - Successful Regions: " + successful_regions +
      "\n\nThis typically indicates that the AWS credential does not have the required 'autoscaling:DescribeAutoScalingGroups' permission " +
      "for these regions, or these regions may not be enabled in your AWS account. " +
      "To resolve this issue: " +
      "(1) Verify the AWS credential has the required Auto Scaling read permissions for these regions, " +
      "(2) Ensure these regions are opted-in in your AWS account, or " +
      "(3) Exclude these regions from policy evaluation using the region filter parameters." +
      filter_guidance
    )
  }

  errors = _.uniq(errors)
  errors = _.map(errors, function(err) { return { "error": err } })

  if (errors.length > 0) {
    var policy_name = "AWS Auto Scaling Group Recommendations"
    if (ds_applied_policy && ds_applied_policy.name) { policy_name = ds_applied_policy.name }
    errors[0].policy_name = policy_name
  }
EOS
end

