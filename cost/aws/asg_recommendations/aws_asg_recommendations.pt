    check logic_or($ds_parent_policy_terminated, eq(val(item, "resourceID"), ""))
    escalate $esc_email
    hash_exclude "tags", "monthlySpendOnDemandEquiv", "spendCurrency", "cpuAverage", "cpuP95", "cpuMaximum", "peakInService", "peakDesired", "capacityChangeCount", "ageDays", "recommendationDetails", "confidence"
    export do
      resource_level true
      field "accountID" do
        label "Account ID"
      end
