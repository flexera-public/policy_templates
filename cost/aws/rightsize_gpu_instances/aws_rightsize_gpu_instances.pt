name "AWS Rightsize GPU EC2 Instances"
rs_pt_ver 20180301
type "policy"
short_description "Reports on GPU EC2 instances that are idle or underutilized and recommends termination or downsizing. See the [README](https://github.com/flexera-public/policy_templates/tree/master/cost/aws/rightsize_gpu_instances) and [docs.flexera.com/flexera/EN/Automation](https://docs.flexera.com/flexera-one/automation/) to learn more."
long_description ""
doc_link "https://github.com/flexera-public/policy_templates/tree/master/cost/aws/rightsize_gpu_instances"
category "Cost"
severity "low"
default_frequency "weekly"
info(
  version: "0.1.0",
  provider: "AWS",
  service: "Compute",
  policy_set: "Rightsize Compute Instances",
  recommendation_type: "Usage Reduction",
  hide_skip_approvals: "true"
)

###############################################################################
# Parameters
###############################################################################

parameter "param_email" do
  type "list"
  category "Policy Settings"
  label "Email Addresses"
  description "Email addresses of the recipients you wish to notify when new incidents are created"
  default []
end

parameter "param_aws_account_number" do
  type "string"
  category "Policy Settings"
  label "Account Number"
  description "Leave blank; this is for automated use with Meta Policies. See README for more details."
  default ""
end

parameter "param_min_savings" do
  type "number"
  category "Policy Settings"
  label "Minimum Savings Threshold"
  description "Minimum potential savings required to generate a recommendation"
  min_value 0
  default 0
end

parameter "param_stats_threshold" do
  type "string"
  category "Statistics"
  label "Threshold Statistic"
  description "Statistic to use when determining if an instance is idle/underutilized"
  allowed_values "Average", "Maximum", "p99", "p95", "p90"
  default "Average"
end

parameter "param_stats_lookback" do
  type "number"
  category "Statistics"
  label "Statistic Lookback Period"
  description "How many days back to look at CPU and/or GPU data for instances. This value cannot be set higher than 90 because AWS does not retain metrics for longer than 90 days."
  min_value 1
  max_value 90
  default 30
end

parameter "param_stats_safety_factor" do
  type "number"
  category "Statistics"
  label "Rightsizing Safety Factor"
  description "A multiplier applied to the peak utilization when computing the required resources for a rightsized instance. For example, a value of 1.5 means the recommended instance type must be able to handle 1.5 times the observed peak utilization. Set a higher value for more headroom."
  min_value 1
  default 1.5
end

parameter "param_stats_cpu_idle" do
  type "number"
  category "Statistics"
  label "Idle Instance CPU Threshold (%)"
  description "The CPU utilization threshold at or below which an instance is considered idle and recommended for termination. Set to -1 to disable idle detection based on CPU utilization."
  min_value -1
  max_value 100
  default 5
end

parameter "param_stats_mem_idle" do
  type "number"
  category "Statistics"
  label "Idle Instance Memory Threshold (%)"
  description "The memory utilization threshold at or below which an instance is considered idle and recommended for termination. Set to -1 to disable idle detection based on memory utilization. Note: If memory metrics are unavailable, this check is skipped automatically."
  min_value -1
  max_value 100
  default 5
end

parameter "param_stats_gpu_idle" do
  type "number"
  category "Statistics"
  label "Idle Instance GPU Utilization Threshold (%)"
  description "The GPU compute utilization threshold at or below which an instance is considered idle. Set to -1 to disable idle detection based on GPU compute utilization. Note: An instance is only flagged as idle when all enabled metric checks pass."
  min_value -1
  max_value 100
  default 5
end

parameter "param_stats_gpu_mem_idle" do
  type "number"
  category "Statistics"
  label "Idle Instance GPU Memory Threshold (%)"
  description "The GPU memory utilization threshold at or below which an instance is considered idle. Set to -1 to disable idle detection based on GPU memory utilization. Note: If GPU memory metrics are unavailable, this check is skipped automatically."
  min_value -1
  max_value 100
  default 5
end

parameter "param_regions_allow_or_deny" do
  type "string"
  category "Filters"
  label "Allow/Deny Regions"
  description "Allow or Deny entered regions. See the README for more details"
  allowed_values "Allow", "Deny"
  default "Allow"
end

parameter "param_regions_list" do
  type "list"
  category "Filters"
  label "Allow/Deny Regions List"
  description "A list of allowed or denied regions. See the README for more details"
  allowed_pattern /^([a-zA-Z-_]+-[a-zA-Z0-9-_]+-[0-9-_]+,*|)+$/
  default []
end

parameter "param_min_age" do
  type "number"
  category "Filters"
  label "Minimum Instance Age (Days)"
  description "The minimum age in days that an instance must be before it is considered for rightsizing or termination recommendations. This helps avoid false positives for recently launched instances that may not yet have established typical utilization patterns. Set to 0 to evaluate instances of any age."
  min_value 0
  default 7
end

parameter "param_exclusion_tags" do
  type "list"
  category "Filters"
  label "Exclusion Tags"
  description "Cloud native tags to ignore resources that you don't want to produce recommendations for. Enter the Key name to filter resources with a specific Key, regardless of Value, and enter Key==Value to filter resources with a specific Key:Value pair. Other operators and regex are supported; please see the README for more details."
  default []
end

parameter "param_exclusion_tags_boolean" do
  type "string"
  category "Filters"
  label "Exclusion Tags: Any / All"
  description "Whether to filter instances containing any of the specified tags or only those that contain all of them. Only applicable if more than one value is entered in the 'Exclusion Tags' field."
  allowed_values "Any", "All"
  default "Any"
end

parameter "param_automatic_action" do
  type "list"
  category "Actions"
  label "Automatic Actions"
  description "When this value is set, this policy will automatically take the selected action(s)"
  allowed_values ["Downsize Instances", "Stop Instances", "Terminate Instances"]
  default []
end

parameter "param_incident_csv" do
  type "string"
  category "Policy Settings"
  label "Attach Incident CSV"
  description "Whether or not to attach the results as a CSV file to the incident email."
  allowed_values "true", "false"
  default "false"
end

parameter "param_incident_table_size" do
  type "number"
  category "Policy Settings"
  label "Incident Table Size"
  description "The number of results to include in the incident table in the incident email. Set to '0' to not show an incident table at all, and '100000' to include all results. Does not impact attached CSV files or the incident as presented in Flexera One."
  allowed_values 0, 10, 50, 100, 200, 500, 1000, 10000, 100000
  default 100000
end

###############################################################################
# Authentication
###############################################################################

credentials "auth_aws" do
  schemes "aws", "aws_sts"
  label "AWS"
  description "Select the AWS Credential from the list"
  tags "provider=aws"
  aws_account_number $param_aws_account_number
end

credentials "auth_flexera" do
  schemes "oauth2"
  label "Flexera"
  description "Select Flexera One OAuth2 credentials"
  tags "provider=flexera"
end

###############################################################################
# Pagination
###############################################################################

pagination "pagination_aws_getmetricdata" do
  get_page_marker do
    body_path "NextToken"
  end
  set_page_marker do
    body_field "NextToken"
  end
end

###############################################################################
# Datasources & Scripts
###############################################################################

# Get region-specific Flexera API endpoints
datasource "ds_flexera_api_hosts" do
  run_script $js_flexera_api_hosts, rs_optima_host
end

script "js_flexera_api_hosts", type: "javascript" do
  parameters "rs_optima_host"
  result "result"
  code <<-'EOS'
  host_table = {
    "api.optima.flexeraeng.com": {
      api: "api.flexera.com",
      flexera: "api.flexera.com",
      fsm: "api.fsm.flexeraeng.com",
      grs: "grs-front.iam-us-east-1.flexeraeng.com",
      ui: "app.flexera.com",
      tld: "flexera.com"
    },
    "api.optima-eu.flexeraeng.com": {
      api: "api.flexera.eu",
      flexera: "api.flexera.eu",
      fsm: "api.fsm-eu.flexeraeng.com",
      grs: "grs-front.eu-central-1.iam-eu.flexeraeng.com",
      ui: "app.flexera.eu",
      tld: "flexera.eu"
    },
    "api.optima-apac.flexeraeng.com": {
      api: "api.flexera.au",
      flexera: "api.flexera.au",
      fsm: "api.fsm-apac.flexeraeng.com",
      grs: "grs-front.ap-southeast-2.iam-apac.flexeraeng.com",
      ui: "app.flexera.au",
      tld: "flexera.au"
    }
  }

  result = host_table[rs_optima_host]
EOS
end

# Get applied policy metadata for use later
datasource "ds_applied_policy" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies", switch(policy_id, join(["/", policy_id]), "")])
  end
end

# Get AWS account info
datasource "ds_cloud_vendor_accounts" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "api")
    path join(["/finops-analytics/v1/orgs/", rs_org_id, "/cloud-vendor-accounts"])
    header "Api-Version", "1.0"
  end
  result do
    encoding "json"
    collect jmes_path(response, "values[*]") do
      field "id", jmes_path(col_item, "aws.accountId")
      field "name", jmes_path(col_item, "name")
      field "tags", jmes_path(col_item, "tags")
    end
  end
end

# Get AWS account info fallback
datasource "ds_billing_centers_aws_acc" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/analytics/orgs/", rs_org_id, "/billing_centers"])
    query "view", "allocation_table"
    header "Api-Version", "1.0"
    header "User-Agent", "RS Policies"
    ignore_status [403]
  end
  result do
    encoding "json"
    collect jmes_path(response, "[*]") do
      field "href", jmes_path(col_item, "href")
      field "id", jmes_path(col_item, "id")
      field "name", jmes_path(col_item, "name")
      field "parent_id", jmes_path(col_item, "parent_id")
    end
  end
end

# Gather top level billing center IDs for when we pull cost data
datasource "ds_top_level_bcs_aws_acc" do
  run_script $js_top_level_bcs_aws_acc, $ds_billing_centers_aws_acc
end

script "js_top_level_bcs_aws_acc", type: "javascript" do
  parameters "ds_billing_centers_aws_acc"
  result "result"
  code <<-'EOS'
  filtered_bcs = _.filter(ds_billing_centers_aws_acc, function(bc) {
    return bc['parent_id'] == null || bc['parent_id'] == undefined
  })

  result = _.compact(_.pluck(filtered_bcs, 'id'))
EOS
end

datasource "ds_cloud_vendor_accounts_fallback" do
  request do
    run_script $js_cloud_vendor_accounts_fallback, $ds_top_level_bcs_aws_acc, rs_org_id, rs_optima_host
  end
  result do
    encoding "json"
    collect jmes_path(response, "rows[*]") do
      field "id", jmes_path(col_item, "dimensions.vendor_account")
      field "name", jmes_path(col_item, "dimensions.vendor_account_name")
    end
  end
end

script "js_cloud_vendor_accounts_fallback", type: "javascript" do
  parameters "ds_top_level_bcs_aws_acc", "rs_org_id", "rs_optima_host"
  result "request"
  code <<-'EOS'
  end_date = new Date()
  end_date.setDate(end_date.getDate() - 2)
  end_date = end_date.toISOString().split('T')[0]

  start_date = new Date()
  start_date.setDate(start_date.getDate() - 3)
  start_date = start_date.toISOString().split('T')[0]

  var request = {
    auth: "auth_flexera",
    host: rs_optima_host,
    verb: "POST",
    path: "/bill-analysis/orgs/" + rs_org_id + "/costs/aggregated",
    body_fields: {
      dimensions: ["vendor_account", "vendor_account_name"],
      granularity: "day",
      start_at: start_date,
      end_at: end_date,
      metrics: ["cost_amortized_unblended_adj"],
      billing_center_ids: ds_top_level_bcs_aws_acc
    },
    headers: {
      'User-Agent': "RS Policies",
      'Api-Version': "1.0"
    },
    ignore_status: [400]
  }
EOS
end

datasource "ds_get_caller_identity" do
  request do
    auth $auth_aws
    host "sts.amazonaws.com"
    path "/"
    query "Action", "GetCallerIdentity"
    query "Version", "2011-06-15"
    header "User-Agent", "RS Policies"
  end
  result do
    encoding "xml"
    collect xpath(response, "//GetCallerIdentityResponse/GetCallerIdentityResult") do
      field "account", xpath(col_item, "Account")
    end
  end
end

datasource "ds_aws_account" do
  run_script $js_aws_account, $ds_cloud_vendor_accounts, $ds_cloud_vendor_accounts_fallback, $ds_get_caller_identity
end

script "js_aws_account", type: "javascript" do
  parameters "ds_cloud_vendor_accounts", "ds_cloud_vendor_accounts_fallback", "ds_get_caller_identity"
  result "result"
  code <<-'EOS'
  result = _.find(ds_cloud_vendor_accounts, function(account) {
    return account['id'] == ds_get_caller_identity[0]['account']
  })

  if (result == undefined) {
    result = _.find(ds_cloud_vendor_accounts_fallback, function(account) {
      return account['id'] == ds_get_caller_identity[0]['account']
    })

    if (result) {
      result["tags"] = {}
    }
  }

  if (result == undefined) {
    result = {
      id: ds_get_caller_identity[0]['account'],
      name: "",
      tags: {}
    }
  }
EOS
end

datasource "ds_billing_centers" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/analytics/orgs/", rs_org_id, "/billing_centers"])
    query "view", "allocation_table"
    header "Api-Version", "1.0"
    header "User-Agent", "RS Policies"
    ignore_status [403]
  end
  result do
    encoding "json"
    collect jmes_path(response, "[*]") do
      field "href", jmes_path(col_item, "href")
      field "id", jmes_path(col_item, "id")
      field "name", jmes_path(col_item, "name")
      field "parent_id", jmes_path(col_item, "parent_id")
    end
  end
end

# Gather top level billing center IDs for when we pull cost data
datasource "ds_top_level_bcs" do
  run_script $js_top_level_bcs, $ds_billing_centers
end

script "js_top_level_bcs", type: "javascript" do
  parameters "ds_billing_centers"
  result "result"
  code <<-'EOS'
  filtered_bcs = _.filter(ds_billing_centers, function(bc) {
    return bc['parent_id'] == null || bc['parent_id'] == undefined
  })

  result = _.compact(_.pluck(filtered_bcs, 'id'))
EOS
end

datasource "ds_currency_reference" do
  request do
    host "raw.githubusercontent.com"
    path "/flexera-public/policy_templates/master/data/currency/currency_reference.json"
    header "User-Agent", "RS Policies"
  end
end

datasource "ds_currency_code" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/bill-analysis/orgs/", rs_org_id, "/settings/currency_code"])
    header "Api-Version", "0.1"
    header "User-Agent", "RS Policies"
    ignore_status [403]
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
    field "value", jmes_path(response, "value")
  end
end

datasource "ds_currency" do
  run_script $js_currency, $ds_currency_reference, $ds_currency_code
end

script "js_currency", type: "javascript" do
  parameters "ds_currency_reference", "ds_currency_code"
  result "result"
  code <<-'EOS'
  symbol = "$"
  separator = ","

  if (ds_currency_code['value'] != undefined) {
    if (ds_currency_reference[ds_currency_code['value']] != undefined) {
      symbol = ds_currency_reference[ds_currency_code['value']]['symbol']

      if (ds_currency_reference[ds_currency_code['value']]['t_separator'] != undefined) {
        separator = ds_currency_reference[ds_currency_code['value']]['t_separator']
      } else {
        separator = ""
      }
    }
  }

  result = {
    symbol: symbol,
    separator: separator
  }
EOS
end

datasource "ds_aws_instance_types" do
  request do
    host "raw.githubusercontent.com"
    path "/flexera-public/policy_templates/master/data/aws/aws_ec2_instance_types.json"
    header "User-Agent", "RS Policies"
  end
  result do
    encoding "json"
    collect jmes_path(response, "[*]") do
      field "name", jmes_path(col_item, "name")
      field "family", jmes_path(col_item, "family")
      field "cpu", jmes_path(col_item, "cpu")
      field "memory", jmes_path(col_item, "memory")
      field "gpu", jmes_path(col_item, "gpu")
    end
  end
end

datasource "ds_gpu_instance_types" do
  run_script $js_gpu_instance_types, $ds_aws_instance_types
end

script "js_gpu_instance_types", type: "javascript" do
  parameters "ds_aws_instance_types"
  result "result"
  code <<-'EOS'
  result = _.filter(ds_aws_instance_types, function(inst) {
    return inst['gpu'] && inst['gpu']['count'] && inst['gpu']['count'] > 0
  })
EOS
end

datasource "ds_aws_instance_prices" do
  request do
    host "raw.githubusercontent.com"
    path "/flexera-public/policy_templates/master/data/aws/aws_ec2_pricing.json"
    header "User-Agent", "RS Policies"
  end
end

datasource "ds_describe_regions" do
  request do
    auth $auth_aws
    host "ec2.amazonaws.com"
    path "/"
    query "Action", "DescribeRegions"
    query "Version", "2016-11-15"
    query "Filter.1.Name", "opt-in-status"
    query "Filter.1.Value.1", "opt-in-not-required"
    query "Filter.1.Value.2", "opted-in"
    # Header X-Meta-Flexera has no affect on datasource query, but is required for Meta Policies
    # Forces `ds_is_deleted` datasource to run first during policy execution
    header "Meta-Flexera", val($ds_is_deleted, "path")
  end
  result do
    encoding "xml"
    collect xpath(response, "//DescribeRegionsResponse/regionInfo/item", "array") do
      field "region", xpath(col_item, "regionName")
    end
  end
end

datasource "ds_regions" do
  run_script $js_regions, $ds_describe_regions, $param_regions_list, $param_regions_allow_or_deny
end

script "js_regions", type: "javascript" do
  parameters "ds_describe_regions", "param_regions_list", "param_regions_allow_or_deny"
  result "result"
  code <<-'EOS'
  allow_deny_test = { "Allow": true, "Deny": false }

  if (param_regions_list.length > 0) {
    result = _.filter(ds_describe_regions, function(item) {
      return _.contains(param_regions_list, item['region']) == allow_deny_test[param_regions_allow_or_deny]
    })
  } else {
    result = ds_describe_regions
  }
EOS
end

# List CloudWatch metric names to discover instances reporting metrics
datasource "ds_cloudwatch_metric_names" do
  run_script $js_cloudwatch_metric_names, $ds_regions
end

script "js_cloudwatch_metric_names", type: "javascript" do
  parameters "ds_regions"
  result "result"
  code <<-'EOS'
  result = []

  _.each(ds_regions, function(reg) {
    // Memory Utilization Metric Name for Linux instances
    result.push({
      "metricName": "mem_used_percent",
      "region": reg["region"]
    })

    // Memory Utilization Metric Name for Windows instances
    result.push({
      "metricName": "Memory % Committed Bytes In Use",
      "region": reg["region"]
    })

    // GPU compute utilization via CloudWatch Agent NVIDIA plugin
    result.push({
      "metricName": "nvidia_smi_utilization_gpu",
      "region": reg["region"]
    })

    // GPU memory used in MiB via CloudWatch Agent NVIDIA plugin
    result.push({
      "metricName": "nvidia_smi_fb_memory_usage_used",
      "region": reg["region"]
    })
  })
EOS
end

datasource "ds_cloudwatch_metrics" do
  iterate $ds_cloudwatch_metric_names
  request do
    run_script $js_cloudwatch_metrics, val(iter_item, "metricName"), val(iter_item, "region")
  end
  result do
    encoding "xml"
    collect xpath(response, "//ListMetricsResult/Metrics/member", "array") do
      field "namespace", xpath(col_item, "Namespace")
      field "metricName", xpath(col_item, "MetricName")
      field "dimensions" do
        collect xpath(col_item, "Dimensions/member", "array") do
          field "name", xpath(col_item, "Name")
          field "value", xpath(col_item, "Value")
        end
      end
      field "region", val(iter_item, "region")
    end
  end
end

script "js_cloudwatch_metrics", type: "javascript" do
  parameters "metric_name", "region"
  result "request"
  code <<-'EOS'
  query_params = {
    "Action": "ListMetrics",
    "Version": "2010-08-01",
    "Namespace": "CWAgent",
    "MetricName": metric_name
  }

  var request = {
    auth: "auth_aws",
    host: "monitoring." + region + ".amazonaws.com",
    path: "/",
    headers: {
      "User-Agent": "RS Policies"
    },
    query_params: query_params,
    ignore_status: [403, 401]
  }
EOS
end

datasource "ds_cloudwatch_metrics_by_instance" do
  run_script $js_cloudwatch_metrics_by_instance, $ds_cloudwatch_metrics
end

script "js_cloudwatch_metrics_by_instance", type: "javascript" do
  parameters "ds_cloudwatch_metrics"
  result "result"
  code <<-'EOS'
  result = {}

  _.each(ds_cloudwatch_metrics, function(metric) {
    dims = metric.dimensions || []
    inst = _.find(dims, function(dim) { return dim.name == "InstanceId" })
    if (!inst || !inst.value) return

    inst_id = inst.value

    if (!result[inst_id]) {
      result[inst_id] = { mem: null, gpuDimensions: [], gpuMemDimensions: [] }
    }

    if (metric.metricName == 'mem_used_percent' || metric.metricName == 'Memory % Committed Bytes In Use') {
      result[inst_id]['mem'] = {
        namespace: metric.namespace,
        metricName: metric.metricName,
        dimensions: metric.dimensions
      }
    } else if (metric.metricName == 'nvidia_smi_utilization_gpu') {
      var gpu_index = '0'
      _.each(dims, function(dim) {
        if (dim.name == 'index') { gpu_index = dim.value }
      })
      var existing = _.find(result[inst_id]['gpuDimensions'], function(g) { return g.index == gpu_index })
      if (!existing) {
        result[inst_id]['gpuDimensions'].push({ index: gpu_index, dimensions: metric.dimensions })
      }
    } else if (metric.metricName == 'nvidia_smi_fb_memory_usage_used') {
      var gpu_index = '0'
      _.each(dims, function(dim) {
        if (dim.name == 'index') { gpu_index = dim.value }
      })
      if (!result[inst_id]['gpuMemDimensions']) {
        result[inst_id]['gpuMemDimensions'] = []
      }
      var existing_mem = _.find(result[inst_id]['gpuMemDimensions'], function(g) { return g.index == gpu_index })
      if (!existing_mem) {
        result[inst_id]['gpuMemDimensions'].push({ index: gpu_index, dimensions: metric.dimensions })
      }
    }
  })
EOS
end

datasource "ds_region_check" do
  iterate $ds_regions
  request do
    auth $auth_aws
    host join(['ec2.', val(iter_item, 'region'), '.amazonaws.com'])
    path '/'
    query 'Action', 'DescribeInstances'
    query 'Version', '2016-11-15'
    query 'MaxResults', '5'
    header 'User-Agent', 'RS Policies'
    header 'Content-Type', 'text/xml'
    ignore_status [403, 401]
  end
  result do
    encoding "xml"
    field "region", val(iter_item, "region")
    field "status", "OK"
  end
end

datasource "ds_instance_sets" do
  iterate $ds_regions
  request do
    auth $auth_aws
    host join(['ec2.', val(iter_item, 'region'), '.amazonaws.com'])
    path '/'
    query 'Action', 'DescribeInstances'
    query 'Version', '2016-11-15'
    query 'Filter.1.Name', 'instance-state-name'
    query 'Filter.1.Value.1', 'running'
    header 'User-Agent', 'RS Policies'
    header 'Content-Type', 'text/xml'
    ignore_status [403, 401]
  end
  result do
    encoding "xml"
    collect xpath(response, "//DescribeInstancesResponse/reservationSet/item", "array") do
      field "instances_set" do
        collect xpath(col_item, "instancesSet/item", "array") do
          field "region", val(iter_item, "region")
          field "instanceId", xpath(col_item, "instanceId")
          field "imageId", xpath(col_item, "imageId")
          field "resourceType", xpath(col_item, "instanceType")
          field "platform", xpath(col_item, "platformDetails")
          field "privateDnsName", xpath(col_item, "privateDnsName")
          field "launchTime", xpath(col_item, "launchTime")
          field "tags" do
            collect xpath(col_item, "tagSet/item", "array") do
              field "key", xpath(col_item, "key")
              field "value", xpath(col_item, "value")
            end
          end
        end
      end
    end
  end
end

datasource "ds_instance_costs" do
  request do
    run_script $js_instance_costs, $ds_aws_account, $ds_top_level_bcs, rs_org_id, rs_optima_host
  end
  result do
    encoding "json"
    collect jmes_path(response, "rows[*]") do
      field "resourceId", jmes_path(col_item, "dimensions.resource_id")
      field "resourceType", jmes_path(col_item, "dimensions.resource_type")
      field "vendorAccountName", jmes_path(col_item, "dimensions.vendor_account_name")
      field "adjustmentName", jmes_path(col_item, "dimensions.adjustment_name")
      field "cost", jmes_path(col_item, "metrics.cost_amortized_unblended_adj")
    end
  end
end

script "js_instance_costs", type: "javascript" do
  parameters "ds_aws_account", "ds_top_level_bcs", "rs_org_id", "rs_optima_host"
  result "request"
  code <<-'EOS'
  end_date = new Date()
  end_date.setDate(end_date.getDate() - 2)
  end_date = end_date.toISOString().split('T')[0]

  start_date = new Date()
  start_date.setDate(start_date.getDate() - 3)
  start_date = start_date.toISOString().split('T')[0]

  var request = {
    auth: "auth_flexera",
    host: rs_optima_host,
    verb: "POST",
    path: "/bill-analysis/orgs/" + rs_org_id + "/costs/select",
    body_fields: {
      dimensions: ["resource_id", "vendor_account_name", "resource_type", "adjustment_name"],
      granularity: "day",
      start_at: start_date,
      end_at: end_date,
      metrics: ["cost_amortized_unblended_adj"],
      billing_center_ids: ds_top_level_bcs,
      limit: 100000,
      filter: {
        type: "and",
        expressions: [
          {
            dimension: "service",
            type: "equal",
            value: "AmazonEC2"
          },
          {
            dimension: "resource_type",
            type: "equal",
            value: "Compute Instance"
          },
          {
            dimension: "vendor_account",
            type: "equal",
            value: ds_aws_account['id']
          },
          {
            type: "not",
            expression: {
              dimension: "adjustment_name",
              type: "substring",
              substring: "Shared"
            }
          }
        ]
      }
    },
    headers: {
      'User-Agent': "RS Policies",
      'Api-Version': "1.0"
    },
    ignore_status: [400]
  }
EOS
end

datasource "ds_instance_costs_grouped" do
  run_script $js_instance_costs_grouped, $ds_instance_costs
end

script "js_instance_costs_grouped", type: "javascript" do
  parameters "ds_instance_costs"
  result "result"
  code <<-'EOS'
  // Multiple a single day's cost by the average number of days in a month.
  // The 0.25 is to account for leap years for extra precision.
  cost_multiplier = 365.25 / 12

  // Group cost data by resourceId for later use
  result = {}

  _.each(ds_instance_costs, function(item) {
    id = item['resourceId'].toLowerCase()

    if (result[id] == undefined) { result[id] = 0.0 }
    result[id] += item['cost'] * cost_multiplier
  })
EOS
end

# Filter to GPU instances only and apply tag exclusions
datasource "ds_instances" do
  run_script $js_instances, $ds_instance_sets, $ds_gpu_instance_types, $param_exclusion_tags, $param_exclusion_tags_boolean, $param_min_age
end

script "js_instances", type: "javascript" do
  parameters "ds_instance_sets", "ds_gpu_instance_types", "param_exclusion_tags", "param_exclusion_tags_boolean", "param_min_age"
  result "result"
  code <<-'EOS'
  comparators = _.map(param_exclusion_tags, function(item) {
    if (item.indexOf('==') != -1) {
      return { comparison: '==', key: item.split('==')[0], value: item.split('==')[1], string: item }
    }

    if (item.indexOf('!=') != -1) {
      return { comparison: '!=', key: item.split('!=')[0], value: item.split('!=')[1], string: item }
    }

    if (item.indexOf('=~') != -1) {
      value = item.split('=~')[1]
      regex = new RegExp(value.slice(1, value.length - 1))
      return { comparison: '=~', key: item.split('=~')[0], value: regex, string: item }
    }

    if (item.indexOf('!~') != -1) {
      value = item.split('!~')[1]
      regex = new RegExp(value.slice(1, value.length - 1))
      return { comparison: '!~', key: item.split('!~')[0], value: regex, string: item }
    }

    // If = is present but none of the above are, assume user error and that the user intended ==
    if (item.indexOf('=') != -1) {
      return { comparison: '==', key: item.split('=')[0], value: item.split('=')[1], string: item }
    }

    // Assume we're just testing for a key if none of the comparators are found
    return { comparison: 'key', key: item, value: null, string: item }
  })

  result = []

  _.each(ds_instance_sets, function(item) {
    if (param_exclusion_tags.length > 0) {
      filtered_instances = _.reject(item['instances_set'], function(resource) {
        resource_tags = {}

        if (typeof(resource['tags']) == 'object') {
          _.each(resource['tags'], function(tag) {
            resource_tags[tag['key']] = tag['value']
          })
        }

        found_tags = []

        _.each(comparators, function(comparator) {
          comparison = comparator['comparison']
          value = comparator['value']
          string = comparator['string']
          resource_tag = resource_tags[comparator['key']]

          if (comparison == 'key' && resource_tag != undefined) { found_tags.push(string) }
          if (comparison == '==' && resource_tag == value) { found_tags.push(string) }
          if (comparison == '!=' && resource_tag != value) { found_tags.push(string) }

          if (comparison == '=~') {
            if (resource_tag != undefined && value.test(resource_tag)) { found_tags.push(string) }
          }

          if (comparison == '!~') {
            if (resource_tag == undefined) { found_tags.push(string) }
            if (resource_tag != undefined && value.test(resource_tag)) { found_tags.push(string) }
          }
        })

        all_tags_found = found_tags.length == comparators.length
        any_tags_found = found_tags.length > 0 && param_exclusion_tags_boolean == 'Any'

        return all_tags_found || any_tags_found
      })

      result = result.concat(filtered_instances)
    } else {
      result = result.concat(item['instances_set'])
    }
  })

  // Filter to GPU instances only
  var gpu_instance_type_names = _.pluck(ds_gpu_instance_types, 'name')
  result = _.filter(result, function(instance) {
    return _.contains(gpu_instance_type_names, instance['resourceType'])
  })

  // Filter out instances younger than param_min_age days
  if (param_min_age > 0) {
    var now = new Date()
    var min_age_ms = param_min_age * 86400 * 1000
    result = _.filter(result, function(instance) {
      if (!instance['launchTime']) { return true }
      var launch = new Date(instance['launchTime'])
      return (now - launch) >= min_age_ms
    })
  }
EOS
end

datasource "ds_identify_errors" do
  run_script $js_identify_errors, $ds_regions, $ds_region_check, $ds_applied_policy, $param_regions_allow_or_deny, $param_regions_list
end

script "js_identify_errors", type: "javascript" do
  parameters "ds_regions", "ds_region_check", "ds_applied_policy", "param_regions_allow_or_deny", "param_regions_list"
  result "errors"
  code <<-'EOS'
  var errors = []

  var region_responses = {}
  _.each(ds_region_check, function(item) {
    if (item.region) {
      region_responses[item.region] = "OK"
    }
  })

  var allowed_regions = _.keys(region_responses)

  var forbidden_regions = []
  _.each(ds_regions, function(region_obj) {
    if (!_.contains(allowed_regions, region_obj.region)) {
      forbidden_regions.push(region_obj.region)
    }
  })

  if (forbidden_regions.length > 0) {
    var regions_string = forbidden_regions.sort().join(", ")
    var successful_regions = allowed_regions.sort().join(", ")
    var filter_guidance = ""

    if (param_regions_list.length > 0) {
      filter_guidance = " You are currently using the 'Allow/Deny Regions List' parameter. "
      filter_guidance += "You can update this list to exclude the inaccessible regions if appropriate."
    } else {
      filter_guidance = " You can use the 'Allow/Deny Regions List' parameter to exclude these regions from the policy scope."
    }

    errors.push(
      "HTTP error received when attempting to describe GPU EC2 instances in some AWS region(s).\n" +
      "\n - Failed Regions: " + regions_string +
      "\n - Successful Regions: " + successful_regions +
      "\n\nThis typically indicates that the AWS credential does not have the required 'ec2:DescribeInstances' permission " +
      "for these regions, or these regions may not be enabled in your AWS account. " +
      "To resolve this issue: " +
      "(1) Verify the AWS credential has 'ec2:DescribeInstances' permission for these regions, " +
      "(2) Ensure these regions are enabled in your AWS account (some regions like opt-in regions require explicit enablement), or " +
      "(3) Exclude these regions from policy evaluation using the region filter parameters." +
      filter_guidance
    )
  }

  errors = _.uniq(errors)

  errors = _.map(errors, function(err) {
    return { "error": err }
  })

  if (errors.length > 0) {
    policy_name = "AWS Rightsize GPU EC2 Instances"
    if (ds_applied_policy && ds_applied_policy.policy_template && ds_applied_policy.policy_template.name) {
      policy_name = ds_applied_policy.policy_template.name
    }
    errors[0].policy_name = policy_name
  }
EOS
end

datasource "ds_cloudwatch_queries" do
  run_script $js_cloudwatch_queries, $ds_instances, $ds_cloudwatch_metrics_by_instance, $param_stats_lookback
end

script "js_cloudwatch_queries", type: "javascript" do
  parameters "ds_instances", "ds_cloudwatch_metrics_by_instance", "param_stats_lookback"
  result "result"
  code <<-'EOS'
  result = {}

  _.each(ds_instances, function(instance) {
    if (result[instance['region']] == undefined || result[instance['region']] == null) {
      result[instance['region']] = []
    }

    var stats = ["Average", "Minimum", "Maximum", "p99", "p95", "p90"]
    var lookback = param_stats_lookback * 86400
    var lookback_1d = 86400

    // Always query CPU usage
    _.each(stats, function(stat) {
      var query = {
        "Id": instance['instanceId'].replace('-', '_') + "_cpu" + stat,
        "MetricStat": {
          "Metric": {
            "Namespace": "AWS/EC2",
            "MetricName": "CPUUtilization",
            "Dimensions": [
              { "Name": "InstanceId", "Value": instance['instanceId'] }
            ]
          },
          "Period": lookback,
          "Stat": stat
        },
        "ReturnData": true
      }

      result[instance['region']].push(query)

      var query_timeseries = _.clone(query)
      query_timeseries.Id = query.Id + "_timeseries"
      query_timeseries.MetricStat = _.clone(query.MetricStat)
      query_timeseries.MetricStat.Period = lookback_1d
      result[instance['region']].push(query_timeseries)
    })

    var metric_details = ds_cloudwatch_metrics_by_instance[instance['instanceId']]

    // Query system memory from CloudWatch Agent (if available)
    if (metric_details != null && metric_details['mem'] != null) {
      var mem_dims = []
      _.each(metric_details['mem']['dimensions'], function(dim) {
        mem_dims.push({ "Name": dim["name"], "Value": dim["value"] })
      })

      _.each(stats, function(stat) {
        var query = {
          "Id": instance['instanceId'].replace('-', '_') + "_mem" + stat,
          "MetricStat": {
            "Metric": {
              "Namespace": "CWAgent",
              "MetricName": metric_details['mem']['metricName'],
              "Dimensions": mem_dims
            },
            "Period": lookback,
            "Stat": stat
          },
          "ReturnData": true
        }

        result[instance['region']].push(query)

        var query_timeseries = _.clone(query)
        query_timeseries.Id = query.Id + "_timeseries"
        query_timeseries.MetricStat = _.clone(query.MetricStat)
        query_timeseries.MetricStat.Period = lookback_1d
        result[instance['region']].push(query_timeseries)
      })
    }

    // Query GPU utilization (if CloudWatch Agent NVIDIA plugin is available)
    if (metric_details != null && metric_details['gpuDimensions'] && metric_details['gpuDimensions'].length > 0) {
      _.each(metric_details['gpuDimensions'], function(gpu_entry) {
        var dimensions = []
        _.each(gpu_entry['dimensions'], function(dim) {
          dimensions.push({ "Name": dim["name"], "Value": dim["value"] })
        })

        _.each(stats, function(stat) {
          var query = {
            "Id": instance['instanceId'].replace('-', '_') + "_gpuutil" + gpu_entry.index + stat,
            "MetricStat": {
              "Metric": {
                "Namespace": "CWAgent",
                "MetricName": "nvidia_smi_utilization_gpu",
                "Dimensions": dimensions
              },
              "Period": lookback,
              "Stat": stat
            },
            "ReturnData": true
          }

          result[instance['region']].push(query)

          // Add daily timeseries for GPU index 0 only (used in chart)
          if (gpu_entry.index == '0') {
            var query_timeseries = _.clone(query)
            query_timeseries.Id = query.Id + "_timeseries"
            query_timeseries.MetricStat = _.clone(query.MetricStat)
            query_timeseries.MetricStat.Period = lookback_1d
            result[instance['region']].push(query_timeseries)
          }
        })
      })
    }

    // Query GPU memory used (if CloudWatch Agent NVIDIA plugin is available)
    if (metric_details != null && metric_details['gpuMemDimensions'] && metric_details['gpuMemDimensions'].length > 0) {
      _.each(metric_details['gpuMemDimensions'], function(gpu_entry) {
        var dimensions = []
        _.each(gpu_entry['dimensions'], function(dim) {
          dimensions.push({ "Name": dim["name"], "Value": dim["value"] })
        })

        _.each(stats, function(stat) {
          var query = {
            "Id": instance['instanceId'].replace('-', '_') + "_gpumem" + gpu_entry.index + stat,
            "MetricStat": {
              "Metric": {
                "Namespace": "CWAgent",
                "MetricName": "nvidia_smi_fb_memory_usage_used",
                "Dimensions": dimensions
              },
              "Period": lookback,
              "Stat": stat
            },
            "ReturnData": true
          }

          result[instance['region']].push(query)
        })
      })
    }
  })
EOS
end

# Combine queries into 500 item blocks so we can make bulk requests to CloudWatch
datasource "ds_instances_requests" do
  run_script $js_instances_requests, $ds_cloudwatch_queries, $param_stats_lookback
end

script "js_instances_requests", type: "javascript" do
  parameters "queries", "param_stats_lookback"
  result "result"
  code <<-'EOS'
  result = []
  query_block_size = 500

  end_date = new Date()
  end_date.setMinutes(0, 0, 0)
  end_date = parseInt(end_date.getTime() / 1000)

  start_date = new Date()
  start_date.setDate(start_date.getDate() - param_stats_lookback)
  start_date.setMinutes(0, 0, 0)
  start_date = parseInt(start_date.getTime() / 1000)

  _.each(Object.keys(queries), function(region) {
    for (i = 0; i < queries[region].length; i += query_block_size) {
      chunk = queries[region].slice(i, i + query_block_size)

      result.push({
        body: {
          "StartTime": start_date,
          "EndTime": end_date,
          "MetricDataQueries": chunk
        },
        region: region
      })
    }
  })
EOS
end

datasource "ds_cloudwatch_data" do
  iterate $ds_instances_requests
  request do
    run_script $js_cloudwatch_data, val(iter_item, "region"), val(iter_item, "body")
  end
  result do
    encoding "json"
    collect jmes_path(response, "MetricDataResults[*]") do
      field "region", val(iter_item, "region")
      field "id", jmes_path(col_item, "Id")
      field "label", jmes_path(col_item, "Label")
      field "values", jmes_path(col_item, "Values")
      field "timestamps", jmes_path(col_item, "Timestamps")
    end
  end
end

script "js_cloudwatch_data", type: "javascript" do
  parameters "region", "body"
  result "request"
  code <<-'EOS'
  api_wait = 5
  var now = new Date().getTime()
  while (new Date().getTime() < now + (api_wait * 1000)) { /* Do nothing */ }

  var request = {
    auth: "auth_aws",
    host: 'monitoring.' + region + '.amazonaws.com',
    pagination: "pagination_aws_getmetricdata",
    verb: "POST",
    path: "/",
    headers: {
      "User-Agent": "RS Policies",
      "Content-Type": "application/json",
      "x-amz-target": "GraniteServiceVersion20100801.GetMetricData",
      "Accept": "application/json",
      "Content-Encoding": "amz-1.0"
    },
    query_params: {
      'Version': '2010-08-01'
    },
    body: JSON.stringify(body)
  }
EOS
end

# PARSE CLOUDWATCH DATA INTO JAVASCRIPT OBJECT
datasource "ds_cloudwatch_data_sorted" do
  run_script $js_cloudwatch_data_sorted, $ds_cloudwatch_data, $param_stats_threshold
end

script "js_cloudwatch_data_sorted", type: "javascript" do
  parameters "ds_cloudwatch_data", "param_stats_threshold"
  result "result"
  code <<-'EOS'
  result = {}

  _.each(ds_cloudwatch_data, function(item) {
    var region = item['region']
    var parts = item['id'].split('_')
    var instance_name = parts[0] + '-' + parts[1]
    var metric = parts[2]
    var is_timeseries = item['id'].indexOf('timeseries') != -1

    var value = item['values'][item['values'].length - 1]

    if (result[region] == undefined) { result[region] = {} }
    if (result[region][instance_name] == undefined) { result[region][instance_name] = {} }

    if (!is_timeseries) {
      if (metric.indexOf('cpu') != -1) {
        // CPU: e.g. "cpuAverage", "cpuMinimum"
        result[region][instance_name][metric] = value
      } else if (metric.indexOf('gpuutil') != -1) {
        // GPU utilization: "gpuutil0Average" -> key "gpuUtilAverage", aggregate max across indices
        var gpu_index = metric.charAt(7)
        var stat = metric.slice(8)
        var key = 'gpuUtil' + stat
        if (value != null && value != undefined) {
          if (result[region][instance_name][key] == undefined) {
            result[region][instance_name][key] = value
          } else {
            result[region][instance_name][key] = Math.max(result[region][instance_name][key], value)
          }
        }
      } else if (metric.indexOf('gpumem') != -1) {
        // GPU memory used (MiB): "gpumem0Average" -> key "gpuMemUsedAverage", aggregate sum across indices
        var gpu_index = metric.charAt(6)
        var stat = metric.slice(7)
        var key = 'gpuMemUsed' + stat
        if (value != null && value != undefined) {
          if (result[region][instance_name][key] == undefined) {
            result[region][instance_name][key] = value
          } else {
            result[region][instance_name][key] += value
          }
        }
      } else if (metric.indexOf('mem') != -1) {
        // Memory: e.g. "memAverage", "memMaximum"
        result[region][instance_name][metric] = value
      }
    } else {
      // Timeseries: only for CPU and memory charts
      if (metric.indexOf(param_stats_threshold) != -1) {
        var stat_name = param_stats_threshold.toLowerCase()
        var points = _.zip(item['timestamps'], item['values'])
        points = _.map(points, function(p) {
          var r = { timestamp: p[0] }
          r[stat_name] = p[1]
          return r
        })
        points = _.sortBy(points, function(p) { return p['timestamp'] })
        if (metric.indexOf('cpu') != -1) {
          result[region][instance_name]['cpuPoints'] = points
        } else if (metric.indexOf('gpuutil') != -1) {
          result[region][instance_name]['gpuUtilPoints'] = points
        } else if (metric.indexOf('mem') != -1) {
          result[region][instance_name]['memPoints'] = points
        }
      }
    }
  })
EOS
end

datasource "ds_merged_metrics" do
  run_script $js_merged_metrics, $ds_cloudwatch_data_sorted, $ds_instances, $ds_aws_account, $ds_currency, $param_stats_threshold, $param_stats_lookback, rs_org_id, rs_project_id
end

script "js_merged_metrics", type: "javascript" do
  parameters "ds_cloudwatch_data_sorted", "ds_instances", "ds_aws_account", "ds_currency", "param_stats_threshold", "param_stats_lookback", "rs_org_id", "rs_project_id"
  result "result"
  code <<-'EOS'
  function generateChartUrl(cpu_stats, mem_stats, gpu_stats, stat_name, resource_name, rs_org_id, rs_project_id) {
    if ((!cpu_stats || cpu_stats.length === 0) && (!mem_stats || mem_stats.length === 0) && (!gpu_stats || gpu_stats.length === 0)) {
      return null
    }

    stat_name = stat_name.toLowerCase()

    var timestamps = []
    var cpuValues = []
    var memValues = []
    var gpuValues = []

    var maxPoints = 60
    var step = 1
    if (cpu_stats && cpu_stats.length > 0) {
      step = Math.max(1, Math.floor(cpu_stats.length / maxPoints))
    } else if (mem_stats && mem_stats.length > 0) {
      step = Math.max(1, Math.floor(mem_stats.length / maxPoints))
    }

    var base_stats = (cpu_stats && cpu_stats.length > 0) ? cpu_stats : mem_stats
    for (var i = 0; i < base_stats.length; i += step) {
      if (base_stats[i] && base_stats[i].timestamp) {
        var date = new Date(base_stats[i].timestamp * 1000)
        timestamps.push(date.toISOString().split('T')[0])
        cpuValues.push((cpu_stats && cpu_stats[i] && _.isNumber(cpu_stats[i][stat_name])) ? Math.round(cpu_stats[i][stat_name] * 10) / 10 : '_')
        memValues.push((mem_stats && mem_stats[i] && _.isNumber(mem_stats[i][stat_name])) ? Math.round(mem_stats[i][stat_name] * 10) / 10 : '_')
        gpuValues.push((gpu_stats && gpu_stats[i] && _.isNumber(gpu_stats[i][stat_name])) ? Math.round(gpu_stats[i][stat_name] * 10) / 10 : '_')
      }
    }

    var timeLabels = timestamps.join('|')
    var cpuData = cpuValues.join(',')
    var memData = memValues.join(',')
    var gpuData = gpuValues.join(',')

    var stat_name_Proper = stat_name.charAt(0).toUpperCase() + stat_name.slice(1)

    var chartUrl = 'https://api.image-charts-auth.flexeraeng.com/ic-function?rs_org_id=' + rs_org_id + '&rs_project_id=' + rs_project_id
    chartUrl += '&cht=lc'
    chartUrl += '&chs=900x450'
    chartUrl += '&chco=206BB6,CF8F36,00AA44'
    chartUrl += '&chxt=x,y'
    chartUrl += '&chxs=0,000000,12,-1,lt,000000,s,min90'
    chartUrl += '&chdl=' + encodeURIComponent('CPU Usage%25|Memory Usage%25|GPU Util%25')
    chartUrl += '&chdlp=b'
    chartUrl += '&chtt=' + encodeURIComponent(stat_name_Proper + '+Resource+Utilization|' + encodeURIComponent(resource_name))
    chartUrl += '&chma=10,10,10,10'
    chartUrl += '&chxr=1,0,100'
    chartUrl += '&chls=' + encodeURIComponent('4|4|4')
    chartUrl += '&chf=bg,s,FFFFFF00'
    chartUrl += '&chg=' + encodeURIComponent('20,50,5,5,CECECE')
    chartUrl += '&chxl=' + encodeURIComponent('0:|' + encodeURIComponent(timeLabels))
    chartUrl += '&chd=' + encodeURIComponent('t:' + cpuData + '|' + memData + '|' + gpuData)

    return chartUrl
  }

  result = []

  var gpu_instances_total = 0
  var gpu_instances_with_metrics = 0

  _.each(ds_instances, function(instance) {
    var region = instance['region']
    var id = instance['instanceId']

    if (ds_cloudwatch_data_sorted[region] == undefined) { return }
    if (ds_cloudwatch_data_sorted[region][id] == undefined) { return }

    var cw = ds_cloudwatch_data_sorted[region][id]

    // Only include instances that have GPU CloudWatch data
    var has_gpu_data = (
      cw['gpuUtilAverage'] != undefined ||
      cw['gpuUtilMaximum'] != undefined ||
      cw['gpuUtilMinimum'] != undefined ||
      cw['gpuUtilp99'] != undefined ||
      cw['gpuUtilp95'] != undefined ||
      cw['gpuUtilp90'] != undefined
    )

    gpu_instances_total++

    if (!has_gpu_data) { return }

    gpu_instances_with_metrics++

    var tags = []
    var resourceName = ''

    if (instance['tags'] != undefined && instance['tags'] != null) {
      _.each(instance['tags'], function(tag) {
        tags.push([tag['key'], tag['value']].join('='))
        if (tag['key'].toLowerCase() == 'name') {
          resourceName = tag['value']
        }
      })
    }

    var resourceARN = 'arn:aws:ec2:' + region + ':' + ds_aws_account['id'] + ':instance/' + id

    var resource_identifier = resourceName ? resourceName + ' (' + id + ')' : id
    var chartUrl = generateChartUrl(cw['cpuPoints'], cw['memPoints'], cw['gpuUtilPoints'], param_stats_threshold, resource_identifier, rs_org_id, rs_project_id)

    var merged_instance = {
      cpuMinimum: cw['cpuMinimum'] != undefined ? cw['cpuMinimum'] : null,
      cpuAverage: cw['cpuAverage'] != undefined ? cw['cpuAverage'] : null,
      cpuMaximum: cw['cpuMaximum'] != undefined ? cw['cpuMaximum'] : null,
      cpuP90: cw['cpup90'] != undefined ? cw['cpup90'] : null,
      cpuP95: cw['cpup95'] != undefined ? cw['cpup95'] : null,
      cpuP99: cw['cpup99'] != undefined ? cw['cpup99'] : null,
      memMinimum: cw['memMinimum'] != undefined ? cw['memMinimum'] : null,
      memAverage: cw['memAverage'] != undefined ? cw['memAverage'] : null,
      memMaximum: cw['memMaximum'] != undefined ? cw['memMaximum'] : null,
      memP90: cw['memp90'] != undefined ? cw['memp90'] : null,
      memP95: cw['memp95'] != undefined ? cw['memp95'] : null,
      memP99: cw['memp99'] != undefined ? cw['memp99'] : null,
      gpuUtilMinimum: cw['gpuUtilMinimum'] != undefined ? cw['gpuUtilMinimum'] : null,
      gpuUtilAverage: cw['gpuUtilAverage'] != undefined ? cw['gpuUtilAverage'] : null,
      gpuUtilMaximum: cw['gpuUtilMaximum'] != undefined ? cw['gpuUtilMaximum'] : null,
      gpuUtilP90: cw['gpuUtilp90'] != undefined ? cw['gpuUtilp90'] : null,
      gpuUtilP95: cw['gpuUtilp95'] != undefined ? cw['gpuUtilp95'] : null,
      gpuUtilP99: cw['gpuUtilp99'] != undefined ? cw['gpuUtilp99'] : null,
      gpuMemUsedMinimum: cw['gpuMemUsedMinimum'] != undefined ? cw['gpuMemUsedMinimum'] : null,
      gpuMemUsedAverage: cw['gpuMemUsedAverage'] != undefined ? cw['gpuMemUsedAverage'] : null,
      gpuMemUsedMaximum: cw['gpuMemUsedMaximum'] != undefined ? cw['gpuMemUsedMaximum'] : null,
      gpuMemUsedP90: cw['gpuMemUsedp90'] != undefined ? cw['gpuMemUsedp90'] : null,
      gpuMemUsedP95: cw['gpuMemUsedp95'] != undefined ? cw['gpuMemUsedp95'] : null,
      gpuMemUsedP99: cw['gpuMemUsedp99'] != undefined ? cw['gpuMemUsedp99'] : null,
      region: region,
      id: id,
      resourceID: id,
      resourceARN: resourceARN,
      resourceType: instance['resourceType'],
      resourceName: resourceName,
      platform: instance['platform'],
      hostname: instance['privateDnsName'] ? instance['privateDnsName'].split('.')[0] : '',
      launchTime: instance['launchTime'],
      tags: tags.join(', '),
      savings: null,
      accountID: ds_aws_account['id'],
      accountName: ds_aws_account['name'],
      savingsCurrency: ds_currency['symbol'],
      thresholdType: param_stats_threshold,
      lookbackPeriod: param_stats_lookback,
      service: 'EC2',
      underutil_message: '',
      idle_message: '',
      underutil_total_savings: '',
      idle_total_savings: '',
      policy_name: ''
    }

    if (chartUrl) {
      merged_instance['chartUrl'] = chartUrl
      merged_instance['chartUrlField'] = resource_identifier + ' Utilization Chart||' + chartUrl + '&from_pt=true'
    }

    result.push(merged_instance)
  })

  // Store counts on first item for summary message
  if (result.length > 0) {
    result[0]['gpu_instances_total'] = gpu_instances_total
    result[0]['gpu_instances_with_metrics'] = gpu_instances_with_metrics
  }
EOS
end

datasource "ds_idle_and_underutil_instances" do
  run_script $js_idle_and_underutil_instances, $ds_merged_metrics, $ds_instance_costs_grouped, $ds_gpu_instance_types, $ds_aws_instance_prices, $ds_currency, $ds_applied_policy, $param_stats_threshold, $param_min_savings, $param_stats_lookback, $param_incident_csv, $param_stats_safety_factor, $param_stats_cpu_idle, $param_stats_mem_idle, $param_stats_gpu_idle, $param_stats_gpu_mem_idle, rs_org_id, rs_project_id
end

script "js_idle_and_underutil_instances", type: "javascript" do
  parameters "ds_merged_metrics", "ds_instance_costs_grouped", "ds_gpu_instance_types", "ds_aws_instance_prices", "ds_currency", "ds_applied_policy", "param_stats_threshold", "param_min_savings", "param_stats_lookback", "param_incident_csv", "param_stats_safety_factor", "param_stats_cpu_idle", "param_stats_mem_idle", "param_stats_gpu_idle", "param_stats_gpu_mem_idle", "rs_org_id", "rs_project_id"
  result "result"
  code <<-'EOS'
  function formatNumber(number, separator) {
    var formatted_number = '0'
    if (number) {
      formatted_number = (Math.round(number * 100) / 100).toString().split('.')[0]
      if (separator) {
        var withSeparator = ''
        for (var i = 0; i < formatted_number.length; i++) {
          if (i > 0 && (formatted_number.length - i) % 3 == 0) { withSeparator += separator }
          withSeparator += formatted_number[i]
        }
        formatted_number = withSeparator
      }
      var decimal = (Math.round(number * 100) / 100).toString().split('.')[1]
      if (decimal) { formatted_number += '.' + decimal }
    }
    return formatted_number
  }

  function getInstancePrice(pricing, region, instance_type, platform) {
    if (!pricing || !pricing[region]) { return null }
    if (!pricing[region][instance_type]) { return null }
    var entry = pricing[region][instance_type]
    var os_key = 'Linux'
    if (platform && platform.indexOf('Windows') != -1) { os_key = 'Windows' }
    else if (platform && platform.indexOf('Red Hat') != -1) { os_key = 'RHEL' }
    else if (platform && platform.indexOf('SUSE') != -1) { os_key = 'SUSE' }
    if (!entry[os_key]) { os_key = 'Linux' }
    if (!entry[os_key]) { return null }
    return entry[os_key]['pricePerUnit']
  }

  var SAFETY_FACTOR = param_stats_safety_factor

  var ts = param_stats_threshold.charAt(0).toUpperCase() + param_stats_threshold.slice(1)

  // Build GPU instance type lookup maps
  var gpu_types_by_name = {}

  _.each(ds_gpu_instance_types, function(inst) {
    gpu_types_by_name[inst['name']] = inst
  })

  var underutil_total_savings = 0.0
  var idle_total_savings = 0.0
  var underutil_list = []
  var idle_list = []

  var gpu_instances_total = ds_merged_metrics.length > 0 && ds_merged_metrics[0]['gpu_instances_total'] != undefined ? ds_merged_metrics[0]['gpu_instances_total'] : ds_merged_metrics.length
  var gpu_instances_with_metrics = ds_merged_metrics.length > 0 && ds_merged_metrics[0]['gpu_instances_with_metrics'] != undefined ? ds_merged_metrics[0]['gpu_instances_with_metrics'] : ds_merged_metrics.length

  _.each(ds_merged_metrics, function(instance) {
    var id = instance['resourceID']
    var region = instance['region']
    var total_cost = 0.0
    if (ds_instance_costs_grouped[id.toLowerCase()] != undefined) { total_cost = ds_instance_costs_grouped[id.toLowerCase()] }

    var current_specs = gpu_types_by_name[instance['resourceType']]
    if (!current_specs) { return }

    var cpu_pct = instance['cpu' + ts]
    var mem_pct = instance['mem' + ts]
    var gpu_util = instance['gpuUtil' + ts]
    var gpu_mem_used_mib = instance['gpuMemUsed' + ts]

    // Require CPU and GPU data (GPU is the critical metric for this policy)
    if (cpu_pct == null || cpu_pct == undefined) { return }
    if (gpu_util == null || gpu_util == undefined) { return }

    var total_gpu_mem_mib = current_specs['gpu']['totalGpuMemoryInMiB']
    var gpu_mem_pct = null
    if (gpu_mem_used_mib != null && gpu_mem_used_mib != undefined && total_gpu_mem_mib > 0) {
      gpu_mem_pct = gpu_mem_used_mib / total_gpu_mem_mib * 100
    }

    instance['gpuUtil'] = gpu_util
    instance['gpuMemPct'] = gpu_mem_pct != null ? parseFloat(gpu_mem_pct.toFixed(2)) : null
    instance['gpuMemUsedMiB'] = gpu_mem_used_mib
    instance['totalGpuMemMiB'] = total_gpu_mem_mib
    instance['gpuCount'] = current_specs['gpu']['count']

    var current_price = getInstancePrice(ds_aws_instance_prices, region, instance['resourceType'], instance['platform'])

    var recommendationDetails = ''

    // Idle check using configurable thresholds; -1 means disabled
    var passes_cpu_idle = param_stats_cpu_idle < 0 || cpu_pct < param_stats_cpu_idle
    var passes_mem_idle = param_stats_mem_idle < 0 || mem_pct == null || mem_pct < param_stats_mem_idle
    var passes_gpu_idle = param_stats_gpu_idle < 0 || gpu_util < param_stats_gpu_idle
    var passes_gpu_mem_idle = param_stats_gpu_mem_idle < 0 || gpu_mem_pct == null || gpu_mem_pct < param_stats_gpu_mem_idle

    // Must have at least one threshold enabled for idle detection to fire
    var idle_checks_enabled = param_stats_cpu_idle >= 0 || param_stats_mem_idle >= 0 || param_stats_gpu_idle >= 0 || param_stats_gpu_mem_idle >= 0
    var is_idle = idle_checks_enabled && passes_cpu_idle && passes_mem_idle && passes_gpu_idle && passes_gpu_mem_idle

    if (is_idle) {
      instance['savings'] = parseFloat(parseFloat(total_cost).toFixed(3))
      instance['recommendationType'] = 'Terminate'
      instance['newResourceType'] = null
      instance['newGpuCount'] = null

      recommendationDetails = 'Terminate AWS GPU EC2 instance ' + id + ' in AWS Account ' + instance['accountName'] + ' (' + instance['accountID'] + ')'
      if (instance['chartUrl']) {
        instance['chartUrlField'] = id + ' Utilization Chart||' + instance['chartUrl'] + '&from_pt=true'
        recommendationDetails += '\n\n![Utilization Chart](' + instance['chartUrl'] + '&from_pt=true)'
      }
      instance['recommendationDetails'] = recommendationDetails

      if (instance['savings'] >= param_min_savings) {
        idle_total_savings += total_cost
        idle_list.push(instance)
      }
    } else {
      // Rightsizing: compute required resources based on observed utilization
      var current_vcpus = current_specs['cpu']['vcpus']
      var required_vcpus = Math.ceil(current_vcpus * cpu_pct / 100 * SAFETY_FACTOR)
      var required_ram_mib = (mem_pct != null && mem_pct != undefined)
        ? Math.ceil(current_specs['memory']['sizeInMiB'] * mem_pct / 100 * SAFETY_FACTOR)
        : 0
      var required_gpu_count = Math.max(1, Math.ceil(current_specs['gpu']['count'] * gpu_util / 100 * SAFETY_FACTOR))
      var required_gpu_mem_mib = (gpu_mem_used_mib != null)
        ? Math.ceil(gpu_mem_used_mib * SAFETY_FACTOR)
        : 0

      // Search all GPU instance types for cheapest option that meets requirements
      var candidate_instances = []

      _.each(ds_gpu_instance_types, function(inst) {
        if (inst['name'] == instance['resourceType']) { return }
        var candidate_price = getInstancePrice(ds_aws_instance_prices, region, inst['name'], instance['platform'])
        if (candidate_price == null || candidate_price == 0) { return }
        if (current_price != null && candidate_price >= current_price) { return }
        if (inst['cpu']['vcpus'] < required_vcpus) { return }
        if (required_ram_mib > 0 && inst['memory']['sizeInMiB'] < required_ram_mib) { return }
        if (!inst['gpu'] || inst['gpu']['count'] < required_gpu_count) { return }
        if (required_gpu_mem_mib > 0 && (!inst['gpu'] || inst['gpu']['totalGpuMemoryInMiB'] < required_gpu_mem_mib)) { return }
        candidate_instances.push({ inst: inst, price: candidate_price })
      })

      candidate_instances = _.sortBy(candidate_instances, function(c) { return c.price })

      var best = candidate_instances.length > 0 ? candidate_instances[0] : null

      if (best) {
        var new_instance = best.inst
        instance['recommendationType'] = 'Downsize'
        instance['newResourceType'] = new_instance['name']
        instance['newGpuCount'] = new_instance['gpu']['count']

        // Calculate savings using list price ratio applied to CCO cost
        var savings = (current_price != null && current_price > 0 && best.price != null)
          ? total_cost * (1 - best.price / current_price)
          : 0
        instance['savings'] = parseFloat(savings.toFixed(3))

        var current_gpu_mem_gib = Math.round(total_gpu_mem_mib / 1024)
        var new_gpu_mem_gib = Math.round(new_instance['gpu']['totalGpuMemoryInMiB'] / 1024)

        recommendationDetails = 'Change instance type of AWS GPU EC2 instance ' + id + ' in AWS Account ' + instance['accountName'] + ' (' + instance['accountID'] + ') from ' + instance['resourceType'] + ' (' + current_specs['gpu']['count'] + ' GPU(s), ' + current_gpu_mem_gib + ' GiB GPU memory) to ' + new_instance['name'] + ' (' + new_instance['gpu']['count'] + ' GPU(s), ' + new_gpu_mem_gib + ' GiB GPU memory)'
        if (instance['chartUrl']) {
          instance['chartUrlField'] = id + ' Utilization Chart||' + instance['chartUrl'] + '&from_pt=true'
          recommendationDetails += '\n\n![Utilization Chart](' + instance['chartUrl'] + '&from_pt=true)'
        }
        instance['recommendationDetails'] = recommendationDetails

        if (instance['savings'] >= param_min_savings) {
          underutil_total_savings += savings
          underutil_list.push(instance)
        }
      }
    }
  })

  var csv_message = param_incident_csv == 'false' ? '' : 'Incident table CSV file has been attached to emails for this incident.'

  var underutil_total_savings_str = ds_currency['symbol'] + ' ' + formatNumber(parseFloat(underutil_total_savings).toFixed(2), ds_currency['separator'])
  var idle_total_savings_str = ds_currency['symbol'] + ' ' + formatNumber(parseFloat(idle_total_savings).toFixed(2), ds_currency['separator'])

  var instances_analyzed = gpu_instances_with_metrics.toString()

  var underutil_message = 'Out of ' + gpu_instances_total + ' GPU EC2 instances analyzed (' + instances_analyzed + ' had GPU CloudWatch metrics), ' + underutil_list.length + ' are underutilized and recommended for downsizing. An instance is considered underutilized when the ' + param_stats_threshold + ' statistic for CPU utilization and GPU compute utilization can be satisfied by a cheaper GPU instance type with a ' + param_stats_safety_factor + 'x safety margin. The recommended instance type is the cheapest GPU instance (across all GPU families available in the region) that meets the computed resource requirements. ' + csv_message

  var idle_message = 'Out of ' + gpu_instances_total + ' GPU EC2 instances analyzed (' + instances_analyzed + ' had GPU CloudWatch metrics), ' + idle_list.length + ' are idle and recommended for termination. An instance is considered idle when all enabled metric checks indicate idleness: CPU utilization below ' + param_stats_cpu_idle + '% (if enabled), memory utilization below ' + param_stats_mem_idle + '% (if enabled and available), GPU compute utilization below ' + param_stats_gpu_idle + '% (if enabled), and GPU memory utilization below ' + param_stats_gpu_mem_idle + '% (if enabled and available). ' + csv_message

  var policy_name = ds_applied_policy['name'] || 'AWS Rightsize GPU EC2 Instances'

  if (underutil_list.length > 0) {
    underutil_list[0]['underutil_message'] = underutil_message
    underutil_list[0]['underutil_total_savings'] = 'Total Estimated Monthly Savings: ' + underutil_total_savings_str
    underutil_list[0]['policy_name'] = policy_name
  }

  if (idle_list.length > 0) {
    idle_list[0]['idle_message'] = idle_message
    idle_list[0]['idle_total_savings'] = 'Total Estimated Monthly Savings: ' + idle_total_savings_str
    idle_list[0]['policy_name'] = policy_name
  }

  var dummy_underutil = {
    recommendationType: '',
    policy_name: policy_name,
    underutil_message: underutil_message,
    underutil_total_savings: 'Total Estimated Monthly Savings: ' + underutil_total_savings_str,
    idle_message: '',
    idle_total_savings: '',
    savings: 0,
    savingsCurrency: ds_currency['symbol'],
    tags: '',
    cpuMaximum: null, cpuMinimum: null, cpuAverage: null, cpuP99: null, cpuP95: null, cpuP90: null,
    memMaximum: null, memMinimum: null, memAverage: null, memP99: null, memP95: null, memP90: null,
    gpuUtilMaximum: null, gpuUtilMinimum: null, gpuUtilAverage: null, gpuUtilP99: null, gpuUtilP95: null, gpuUtilP90: null,
    gpuMemUsedMaximum: null, gpuMemUsedMinimum: null, gpuMemUsedAverage: null, gpuMemUsedP99: null, gpuMemUsedP95: null, gpuMemUsedP90: null,
    gpuMemPct: null, gpuMemUsedMiB: null
  }

  var dummy_idle = {
    recommendationType: '',
    policy_name: policy_name,
    idle_message: idle_message,
    idle_total_savings: 'Total Estimated Monthly Savings: ' + idle_total_savings_str,
    underutil_message: '',
    underutil_total_savings: '',
    savings: 0,
    savingsCurrency: ds_currency['symbol'],
    tags: '',
    cpuMaximum: null, cpuMinimum: null, cpuAverage: null, cpuP99: null, cpuP95: null, cpuP90: null,
    memMaximum: null, memMinimum: null, memAverage: null, memP99: null, memP95: null, memP90: null,
    gpuUtilMaximum: null, gpuUtilMinimum: null, gpuUtilAverage: null, gpuUtilP99: null, gpuUtilP95: null, gpuUtilP90: null,
    gpuMemUsedMaximum: null, gpuMemUsedMinimum: null, gpuMemUsedAverage: null, gpuMemUsedP99: null, gpuMemUsedP95: null, gpuMemUsedP90: null,
    gpuMemPct: null, gpuMemUsedMiB: null
  }

  underutil_list.unshift(dummy_underutil)
  idle_list.unshift(dummy_idle)

  result = {
    underutil_list: underutil_list,
    idle_list: idle_list
  }
EOS
end

datasource "ds_underutil_instances" do
  run_script $js_split_incidents, $ds_idle_and_underutil_instances, "underutil_list"
end

datasource "ds_idle_instances" do
  run_script $js_split_incidents, $ds_idle_and_underutil_instances, "idle_list"
end

script "js_split_incidents", type:"javascript" do
  parameters "ds_idle_and_underutil_instances", "incident"
  result "result"
  code "result = ds_idle_and_underutil_instances[incident]"
end

###############################################################################
# Policy
###############################################################################

policy "pol_utilization" do
  validate_each $ds_underutil_instances do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} AWS Underutilized GPU EC2 Instances Found"
    detail_template <<-'EOS'
    **Potential Monthly Savings:** {{ with index data 0 }}{{ .underutil_total_savings }}{{ end }}

    {{ with index data 0 }}{{ .underutil_message }}{{ end }}
    EOS
    check logic_or($ds_parent_policy_terminated, ne(val(item, "recommendationType"), "Downsize"))
    escalate $esc_email
    escalate $esc_downsize_instances
    hash_exclude "message", "total_savings", "underutil_message", "idle_message", "underutil_total_savings", "idle_total_savings", "tags", "savings", "savingsCurrency", "cpuMaximum", "cpuMinimum", "cpuAverage", "cpuP99", "cpuP95", "cpuP90", "memMaximum", "memMinimum", "memAverage", "memP99", "memP95", "memP90", "gpuUtilMaximum", "gpuUtilMinimum", "gpuUtilAverage", "gpuUtilP99", "gpuUtilP95", "gpuUtilP90", "gpuMemUsedMaximum", "gpuMemUsedMinimum", "gpuMemUsedAverage", "gpuMemUsedP99", "gpuMemUsedP95", "gpuMemUsedP90", "gpuMemPct", "gpuMemUsedMiB"
    export do
      resource_level true
      field "accountID" do
        label "Account ID"
      end
      field "accountName" do
        label "Account Name"
      end
      field "resourceID" do
        label "Resource ID"
      end
      field "resourceName" do
        label "Resource Name"
      end
      field "tags" do
        label "Resource Tags"
      end
      field "recommendationDetails" do
        label "Recommendation"
      end
      field "region" do
        label "Region"
      end
      field "platform" do
        label "Platform"
      end
      field "hostname" do
        label "Hostname"
      end
      field "resourceType" do
        label "Instance Size"
      end
      field "newResourceType" do
        label "Recommended Instance Size"
      end
      field "gpuCount" do
        label "GPU Count"
      end
      field "newGpuCount" do
        label "Recommended GPU Count"
      end
      field "savings" do
        label "Estimated Monthly Savings"
      end
      field "savingsCurrency" do
        label "Savings Currency"
      end
      field "launchTime" do
        label "Launch Time"
      end
      field "cpuMaximum" do
        label "CPU Maximum %"
      end
      field "cpuMinimum" do
        label "CPU Minimum %"
      end
      field "cpuAverage" do
        label "CPU Average %"
      end
      field "cpuP99" do
        label "CPU p99"
      end
      field "cpuP95" do
        label "CPU p95"
      end
      field "cpuP90" do
        label "CPU p90"
      end
      field "memMaximum" do
        label "Memory Maximum %"
      end
      field "memMinimum" do
        label "Memory Minimum %"
      end
      field "memAverage" do
        label "Memory Average %"
      end
      field "memP99" do
        label "Memory p99"
      end
      field "memP95" do
        label "Memory p95"
      end
      field "memP90" do
        label "Memory p90"
      end
      field "gpuUtilMaximum" do
        label "GPU Utilization Maximum %"
      end
      field "gpuUtilMinimum" do
        label "GPU Utilization Minimum %"
      end
      field "gpuUtilAverage" do
        label "GPU Utilization Average %"
      end
      field "gpuUtilP99" do
        label "GPU Utilization p99 %"
      end
      field "gpuUtilP95" do
        label "GPU Utilization p95 %"
      end
      field "gpuUtilP90" do
        label "GPU Utilization p90 %"
      end
      field "gpuMemPct" do
        label "GPU Memory Utilization %"
      end
      field "gpuMemUsedMiB" do
        label "GPU Memory Used (MiB)"
      end
      field "gpuMemUsedMaximum" do
        label "GPU Memory Used Maximum (MiB)"
      end
      field "gpuMemUsedMinimum" do
        label "GPU Memory Used Minimum (MiB)"
      end
      field "gpuMemUsedAverage" do
        label "GPU Memory Used Average (MiB)"
      end
      field "gpuMemUsedP99" do
        label "GPU Memory Used p99 (MiB)"
      end
      field "gpuMemUsedP95" do
        label "GPU Memory Used p95 (MiB)"
      end
      field "gpuMemUsedP90" do
        label "GPU Memory Used p90 (MiB)"
      end
      field "totalGpuMemMiB" do
        label "Total GPU Memory (MiB)"
      end
      field "thresholdType" do
        label "Threshold Statistic"
      end
      field "lookbackPeriod" do
        label "Look Back Period (Days)"
      end
      field "service" do
        label "Service"
      end
      field "resourceARN" do
        label "Resource ARN"
      end
      field "chartUrlField" do
        label "Utilization Chart"
        format "link-external"
      end
      field "id" do
        label "ID"
        path "resourceID"
      end
    end
  end
  validate_each $ds_idle_instances do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} AWS Idle GPU EC2 Instances Found"
    detail_template <<-'EOS'
    **Potential Monthly Savings:** {{ with index data 0 }}{{ .idle_total_savings }}{{ end }}

    {{ with index data 0 }}{{ .idle_message }}{{ end }}
    EOS
    check logic_or($ds_parent_policy_terminated, ne(val(item, "recommendationType"), "Terminate"))
    escalate $esc_email
    escalate $esc_stop_instances
    escalate $esc_terminate_instances
    hash_exclude "message", "total_savings", "underutil_message", "idle_message", "underutil_total_savings", "idle_total_savings", "tags", "savings", "savingsCurrency", "cpuMaximum", "cpuMinimum", "cpuAverage", "cpuP99", "cpuP95", "cpuP90", "memMaximum", "memMinimum", "memAverage", "memP99", "memP95", "memP90", "gpuUtilMaximum", "gpuUtilMinimum", "gpuUtilAverage", "gpuUtilP99", "gpuUtilP95", "gpuUtilP90", "gpuMemUsedMaximum", "gpuMemUsedMinimum", "gpuMemUsedAverage", "gpuMemUsedP99", "gpuMemUsedP95", "gpuMemUsedP90", "gpuMemPct", "gpuMemUsedMiB"
    export do
      resource_level true
      field "accountID" do
        label "Account ID"
      end
      field "accountName" do
        label "Account Name"
      end
      field "resourceID" do
        label "Resource ID"
      end
      field "resourceName" do
        label "Resource Name"
      end
      field "tags" do
        label "Resource Tags"
      end
      field "recommendationDetails" do
        label "Recommendation"
      end
      field "region" do
        label "Region"
      end
      field "platform" do
        label "Platform"
      end
      field "hostname" do
        label "Hostname"
      end
      field "resourceType" do
        label "Instance Size"
      end
      field "gpuCount" do
        label "GPU Count"
      end
      field "savings" do
        label "Estimated Monthly Savings"
      end
      field "savingsCurrency" do
        label "Savings Currency"
      end
      field "launchTime" do
        label "Launch Time"
      end
      field "cpuMaximum" do
        label "CPU Maximum %"
      end
      field "cpuMinimum" do
        label "CPU Minimum %"
      end
      field "cpuAverage" do
        label "CPU Average %"
      end
      field "cpuP99" do
        label "CPU p99"
      end
      field "cpuP95" do
        label "CPU p95"
      end
      field "cpuP90" do
        label "CPU p90"
      end
      field "memMaximum" do
        label "Memory Maximum %"
      end
      field "memMinimum" do
        label "Memory Minimum %"
      end
      field "memAverage" do
        label "Memory Average %"
      end
      field "memP99" do
        label "Memory p99"
      end
      field "memP95" do
        label "Memory p95"
      end
      field "memP90" do
        label "Memory p90"
      end
      field "gpuUtilMaximum" do
        label "GPU Utilization Maximum %"
      end
      field "gpuUtilMinimum" do
        label "GPU Utilization Minimum %"
      end
      field "gpuUtilAverage" do
        label "GPU Utilization Average %"
      end
      field "gpuUtilP99" do
        label "GPU Utilization p99 %"
      end
      field "gpuUtilP95" do
        label "GPU Utilization p95 %"
      end
      field "gpuUtilP90" do
        label "GPU Utilization p90 %"
      end
      field "gpuMemPct" do
        label "GPU Memory Utilization %"
      end
      field "gpuMemUsedMiB" do
        label "GPU Memory Used (MiB)"
      end
      field "gpuMemUsedMaximum" do
        label "GPU Memory Used Maximum (MiB)"
      end
      field "gpuMemUsedMinimum" do
        label "GPU Memory Used Minimum (MiB)"
      end
      field "gpuMemUsedAverage" do
        label "GPU Memory Used Average (MiB)"
      end
      field "gpuMemUsedP99" do
        label "GPU Memory Used p99 (MiB)"
      end
      field "gpuMemUsedP95" do
        label "GPU Memory Used p95 (MiB)"
      end
      field "gpuMemUsedP90" do
        label "GPU Memory Used p90 (MiB)"
      end
      field "totalGpuMemMiB" do
        label "Total GPU Memory (MiB)"
      end
      field "thresholdType" do
        label "Threshold Statistic"
      end
      field "lookbackPeriod" do
        label "Look Back Period (Days)"
      end
      field "service" do
        label "Service"
      end
      field "resourceARN" do
        label "Resource ARN"
      end
      field "chartUrlField" do
        label "Utilization Chart"
        format "link-external"
      end
      field "id" do
        label "ID"
        path "resourceID"
      end
    end
  end

  validate $ds_identify_errors do
    summary_template "{{ with index data 0 }}{{ .policy_name }}{{ end }}: {{ len data }} Errors Identified"
    detail_template <<-'EOS'
    The policy was unable to retrieve GPU EC2 instance data from one or more AWS regions due to permission or configuration errors.

    **Error Details:**

    {{ range data -}}
      - {{ .error }}
    {{ end }}

    **Recommended Actions:**

    1. Verify that the AWS credential has the 'ec2:DescribeInstances' permission for all regions where the policy should execute
    2. Ensure that the required AWS regions are enabled in your AWS account (some regions require explicit opt-in)
    3. Consider updating the 'Allow/Deny Regions List' parameter to exclude regions that are not accessible or not relevant to your use case

    **Additional Information:**

    If certain regions should be excluded from this policy's scope, you can configure the region filter parameters to prevent these errors from appearing in future policy runs.
    EOS
    check eq(size(data), 0)
    escalate $esc_email_errors_identified
  end
end

###############################################################################
# Escalations
###############################################################################

escalation "esc_email_errors_identified" do
  automatic true
  label "Send Email"
  description "Send incident email"
  email $param_email
end

escalation "esc_email" do
  automatic true
  label "Send Email"
  description "Send incident email"
  email $param_email do
    attach_export_table $param_incident_csv
    body_table_max_rows $param_incident_table_size
  end
end

escalation "esc_downsize_instances" do
  automatic contains($param_automatic_action, "Downsize Instances")
  label "Downsize Instances"
  description "Approval to downsize all selected GPU instances"
  run "downsize_instances", data
end

escalation "esc_stop_instances" do
  automatic contains($param_automatic_action, "Stop Instances")
  label "Stop Instances"
  description "Approval to stop all selected GPU instances"
  run "stop_instances", data
end

escalation "esc_terminate_instances" do
  automatic contains($param_automatic_action, "Terminate Instances")
  label "Terminate Instances"
  description "Approval to terminate all selected GPU instances"
  run "terminate_instances", data
end

###############################################################################
# Cloud Workflow
###############################################################################

define stop_instances($data) do
  $$all_responses = []
  $$errors = []

  foreach $instance in $data do
    sub on_error: handle_error() do
      call get_instance_state($instance) retrieve $initial_state

      if $initial_state != "terminated" && $initial_state != "pending"
        if $initial_state != "stopped"
          call stop_instance($instance)
        end
      end
    end
  end

  if inspect($$errors) != "null"
    raise join($$errors, "\n")
  end
end

define downsize_instances($data) do
  $$all_responses = []
  $$errors = []

  foreach $instance in $data do
    sub on_error: handle_error() do
      if $instance["newResourceType"] != null
        call get_instance_state($instance) retrieve $initial_state
        if $initial_state != "terminated" && $initial_state != "pending"
          if $initial_state != "stopped"
            call stop_instance($instance)
          end
          call resize_instance($instance)
          if $initial_state == "running"
            call start_instance($instance)
          end
        end
      end
    end
  end

  if inspect($$errors) != "null"
    raise join($$errors, "\n")
  end
end

define terminate_instances($data) do
  $$all_responses = []
  $$errors = []

  foreach $instance in $data do
    sub on_error: handle_error() do
      call get_instance_state($instance) retrieve $initial_state

      if $initial_state != "terminated" && $initial_state != "pending"
        call terminate_instance($instance)
      end
    end
  end

  if inspect($$errors) != "null"
    raise join($$errors, "\n")
  end
end

define start_instance($instance) return $response do
  $url = "https://ec2." + $instance["region"] + ".amazonaws.com/?Action=StartInstances&Version=2016-11-15&InstanceId.1=" + $instance["id"]
  task_label("POST " + $url)

  $response = http_request(
    auth: $$auth_aws,
    https: true,
    verb: "post",
    href: "/",
    host: "ec2." + $instance["region"] + ".amazonaws.com",
    query_strings: {
      "Action": "StartInstances",
      "Version": "2016-11-15",
      "InstanceId.1": $instance["id"]
    }
  )

  task_label("Start EC2 instance response: " + $instance["id"] + " " + to_json($response))
  $$all_responses << to_json({"req": "POST " + $url, "resp": $response})

  if $response["code"] != 202 && $response["code"] != 200
    raise "Unexpected response starting EC2 instance: " + $instance["id"] + " " + to_json($response)
  else
    task_label("Start EC2 instance successful: " + $instance["id"])
    call get_instance_state($instance) retrieve $instance_state
    while $instance_state != "running" do
      call get_instance_state($instance) retrieve $instance_state
      task_label("Waiting for start - instance state: " + $instance["id"] + " " + $instance_state)
      sleep(10)
    end
    task_label("Start EC2 instance completed: " + $instance["id"])
  end
end

define stop_instance($instance) return $response do
  $url = "https://ec2." + $instance["region"] + ".amazonaws.com/?Action=StopInstances&Version=2016-11-15&InstanceId.1=" + $instance["id"]
  task_label("POST " + $url)

  $response = http_request(
    auth: $$auth_aws,
    https: true,
    verb: "post",
    href: "/",
    host: "ec2." + $instance["region"] + ".amazonaws.com",
    query_strings: {
      "Action": "StopInstances",
      "Version": "2016-11-15",
      "InstanceId.1": $instance["id"]
    }
  )

  task_label("Stop EC2 instance response: " + $instance["id"] + " " + to_json($response))
  $$all_responses << to_json({"req": "POST " + $url, "resp": $response})

  if $response["code"] != 202 && $response["code"] != 200
    raise "Unexpected response stopping EC2 instance: " + $instance["id"] + " " + to_json($response)
  else
    task_label("Stop EC2 instance successful: " + $instance["id"])
    call get_instance_state($instance) retrieve $instance_state
    while $instance_state != "stopped" do
      call get_instance_state($instance) retrieve $instance_state
      task_label("Waiting for stop - instance state: " + $instance["id"] + " " + $instance_state)
      sleep(10)
    end
    task_label("Stop EC2 instance completed: " + $instance["id"])
  end
end

define resize_instance($instance) return $response do
  $url = "https://ec2." + $instance["region"] + ".amazonaws.com/?Action=ModifyInstanceAttribute&Version=2016-11-15&InstanceId=" + $instance["id"] + "&InstanceType.Value=" + $instance["newResourceType"]
  task_label("POST " + $url)

  $response = http_request(
    auth: $$auth_aws,
    https: true,
    verb: "post",
    href: "/",
    host: "ec2." + $instance["region"] + ".amazonaws.com",
    query_strings: {
      "Action": "ModifyInstanceAttribute",
      "Version": "2016-11-15",
      "InstanceId": $instance["id"],
      "InstanceType.Value": $instance["newResourceType"]
    }
  )

  task_label("Modify EC2 instance type response: " + $instance["id"] + " " + to_json($response))
  $$all_responses << to_json({"req": "POST " + $url, "resp": $response})

  if $response["code"] != 202 && $response["code"] != 200
    raise "Unexpected response modifying EC2 instance type: " + $instance["id"] + " " + to_json($response)
  else
    task_label("Modify EC2 instance type successful: " + $instance["id"])
    call get_instance_state($instance) retrieve $instance_state
    while $instance_state != "stopped" do
      call get_instance_state($instance) retrieve $instance_state
      task_label("Waiting for stopped - instance state: " + $instance["id"] + " " + $instance_state)
      sleep(10)
    end
    task_label("Modify EC2 instance type completed: " + $instance["id"])
  end
end

define terminate_instance($instance) return $response do
  $url = "https://ec2." + $instance["region"] + ".amazonaws.com/?Action=TerminateInstances&Version=2016-11-15&InstanceId.1=" + $instance["id"]
  task_label("POST " + $url)

  $response = http_request(
    auth: $$auth_aws,
    https: true,
    verb: "post",
    href: "/",
    host: "ec2." + $instance["region"] + ".amazonaws.com",
    query_strings: {
      "Action": "TerminateInstances",
      "Version": "2016-11-15",
      "InstanceId.1": $instance["id"]
    }
  )

  task_label("Terminate EC2 instance response: " + $instance["id"] + " " + to_json($response))
  $$all_responses << to_json({"req": "POST " + $url, "resp": $response})

  if $response["code"] != 202 && $response["code"] != 200
    raise "Unexpected response terminating EC2 instance: " + $instance["id"] + " " + to_json($response)
  else
    task_label("Terminate EC2 instance successful: " + $instance["id"])
    call get_instance_state($instance) retrieve $instance_state
    while $instance_state != "terminated" do
      call get_instance_state($instance) retrieve $instance_state
      task_label("Waiting for terminated - instance state: " + $instance["id"] + " " + $instance_state)
      sleep(10)
    end
    task_label("Terminate EC2 instance completed: " + $instance["id"])
  end
end

define get_instance_state($instance) return $instance_state do
  $url = "https://ec2." + $instance["region"] + ".amazonaws.com/?Action=DescribeInstanceStatus&Version=2016-11-15&IncludeAllInstances=true&InstanceId.1=" + $instance["id"]
  task_label("POST " + $url)

  $response = http_request(
    auth: $$auth_aws,
    https: true,
    verb: "post",
    href: "/",
    host: "ec2." + $instance["region"] + ".amazonaws.com",
    query_strings: {
      "Action": "DescribeInstanceStatus",
      "Version": "2016-11-15",
      "IncludeAllInstances": "true",
      "InstanceId.1": $instance["id"]
    }
  )

  task_label("Describe EC2 instance status response: " + $instance["id"] + " " + to_json($response))
  $instance_state = $response["body"]["DescribeInstanceStatusResponse"]["instanceStatusSet"]["item"]["instanceState"]["name"]
end

define handle_error() do
  if !$$errors
    $$errors = []
  end
  $$errors << $_error["type"] + ": " + $_error["message"]
  $_error_behavior = "skip"
end

###############################################################################
# Meta Policy [alpha]
# Not intended to be modified or used by policy developers
###############################################################################

# If the meta_parent_policy_id is not set it will evaluate to an empty string and we will look for the policy itself,
# if it is set we will look for the parent policy.
datasource "ds_get_parent_policy" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies/", switch(ne(meta_parent_policy_id, ""), meta_parent_policy_id, policy_id) ])
	  ignore_status [404]
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
  end
end

# If the policy was applied by a meta_parent_policy we confirm it exists if it doesn't we confirm we are deleting
# This information is used in two places:
# - determining whether or not we make a delete call
# - determining if we should create an incident (we don't want to create an incident on the run where we terminate)
datasource "ds_parent_policy_terminated" do
  run_script $js_parent_policy_terminated, $ds_get_parent_policy, meta_parent_policy_id
end

script "js_parent_policy_terminated", type: "javascript" do
  parameters "ds_get_parent_policy", "meta_parent_policy_id"
  result "result"
  code <<-'EOS'
  result = meta_parent_policy_id != "" && ds_get_parent_policy["id"] == undefined
EOS
end

# Two potentials ways to set this up:
# - this way and make a unneeded 'get' request when not deleting
# - make the delete request an interate and have it iterate over an empty array when not deleting and an array with one item when deleting
datasource "ds_terminate_self" do
  request do
    run_script $js_make_terminate_request, $ds_parent_policy_terminated, $ds_flexera_api_hosts, policy_id, rs_org_id, rs_project_id
  end
end

script "js_make_terminate_request", type: "javascript" do
  parameters "ds_parent_policy_terminated", "ds_flexera_api_hosts", "policy_id", "rs_org_id", "rs_project_id"
  result "request"
  code <<-'EOS'
  var request = {
    auth: "auth_flexera",
    host: ds_flexera_api_hosts["flexera"],
    path: [ "/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies", policy_id ? "/"+policy_id : "" ].join(''),
    verb: ds_parent_policy_terminated ? "DELETE" : "GET"
  }
EOS
end

# This is just a way to have the check delete request connect to the farthest leaf from policy.
# We want the delete check to the first thing the policy does to avoid the policy erroring before it can decide whether or not it needs to self terminate
# Example a customer deletes a credential and then terminates the parent policy. We still want the children to self terminate
# The only way I could see this not happening is if the user who applied the parent_meta_policy was offboarded or lost policy access, the policies who are impersonating the user
# would not have access to self-terminate
# It may be useful for the backend to enable a mass terminate at some point for all meta_child_policies associated with an id.
datasource "ds_is_deleted" do
  run_script $js_is_deleted, $ds_terminate_self
end

script "js_is_deleted", type: "javascript" do
  parameters "ds_terminate_self"
  result "result"
  code 'result = { path: "/"}'
end
