#   end
#   result do
#     encoding "json"
#     field "name", jmes_path(response, "name")
#     field "config", jmes_path(response, "config")
#   end
# end

datasource "ds_dashboard_json" do
  run_script $js_dashboard_json, $ds_dashboard_toggle
end

script "js_dashboard_json", type: "javascript" do
  parameters "ds_dashboard_toggle"
  result "result"
  code <<-'EOS'
  result = []

  if (ds_dashboard_toggle.length > 0) {

  var select_filter = {
    "adjustment_name": [{ "id": "Raw Cost" }],
    "bill_source": [{ "regex": "cbi-oi-ocean-" }]
  }

  var default_filters = [
    { "id": "CostTypeParam", "source": "default" },
    { "id": "DateRangeParam", "source": "default" },
    { "id": "CalendarPeriodParam", "source": "default" },
    { "id": "SelectParam", "source": "manual", "value": select_filter }
  ]

  var metric = [{ "id": "cost_amortized_unblended_adj", "name": "Amortized Cost", "type": "Cost" }]

  function barChart(id, name, description, dimension) {
    return {
      component: "bar-chart", description: description, id: id,
      isPercentageBased: "off", metrics: metric, name: name,
      filters: [
        { id: "DimensionParam", source: "manual", value: [dimension] },
        { id: "GroupByParam", source: "inline" }
      ].concat(default_filters)
    }
  }

  function costList(id, name, description, groupBy) {
    return {
      component: "cost-list", description: description, id: id,
      isPercentageBased: "off", metrics: metric, name: name,
      filters: [
        { id: "DimensionParam", source: "inline" },
        { id: "GroupByParam", source: "manual", value: groupBy }
      ].concat(default_filters)
    }
  }

  var widgets = [
    // Section 1: Platform / Tenancy — Where is container spend going?
    barChart("s1-bar-cluster", "Costs by Cluster",
      "Daily container cost trend grouped by Kubernetes cluster. Use this to identify which clusters drive the most spend and spot unexpected cost spikes. Consider setting budget alerts on high-cost clusters to catch scaling events early.",
      "tag_kubernetes_cluster"),
    costList("s1-list-cluster", "Costs by Cluster",
      "Tabular cluster cost breakdown with period-over-period change. Look for clusters with unusual growth rates — these may indicate scaling events, misconfigurations, or new workloads that need review.",
      ["tag_kubernetes_cluster"]),
    barChart("s1-bar-namespace", "Costs by Namespace",
      "Daily container cost trend grouped by namespace. Namespaces typically represent teams, environments, or services. Watch for non-production namespaces (dev, staging) with costs approaching production levels — a common sign of resource waste.",
      "tag_kubernetes_namespace"),
    costList("s1-list-namespace", "Costs by Namespace",
      "Namespace cost breakdown with trend data. Use this to identify namespaces that may need resource quotas or limits. Namespaces with rapid cost growth are good candidates for rightsizing reviews.",
      ["tag_kubernetes_namespace"]),
    costList("s1-list-ns-cluster", "Namespace by Cluster (Chargeback View)",
      "The canonical chargeback/showback view: namespace cost broken down by cluster. Use this to allocate container costs to teams or business units. This is typically the starting point for building Kubernetes cost allocation models and billing center rules.",
      ["tag_kubernetes_namespace", "tag_kubernetes_cluster"]),

    // Section 2: Application Identity — Which applications cost the most?
    barChart("s2-bar-appname", "Costs by App Name",
      "Daily cost trend by application name (app.kubernetes.io/name label). This reveals which applications consume the most resources. Applications appearing as 'None' lack this standard Kubernetes label — adding it improves cost attribution accuracy.",
      "tag_kubernetes_metadata_app_name"),
    costList("s2-list-appname", "Costs by App Name",
      "Application cost ranking with period comparison. Use this to track application-level unit economics and identify optimization candidates. Applications with high cost relative to their business value should be prioritized for rightsizing.",
      ["tag_kubernetes_metadata_app_name"]),
    costList("s2-list-app-cluster-ns", "App Name by Cluster and Namespace",
      "Cross-reference of application costs across clusters and namespaces. Identifies applications deployed redundantly across clusters, verifies multi-cluster deployments are cost-balanced, and reveals where the same app runs in multiple environments.",
      ["tag_kubernetes_metadata_app_name", "tag_kubernetes_cluster", "tag_kubernetes_namespace"]),

    // Section 3: Workload Runtime — What types of workloads drive cost?
    barChart("s3-bar-ctrlkind", "Costs by Controller Kind",
      "Cost distribution by controller type: Deployment, StatefulSet, DaemonSet, Job, and standalone Pod. High Job costs may indicate batch workloads eligible for spot instances. DaemonSet costs scale with node count. Standalone Pods (no controller) often indicate orphaned workloads that should be cleaned up.",
      "tag_kubernetes_controller_kind"),
    costList("s3-list-controller", "Top Controllers by Cost",
      "Individual controllers ranked by cost. Controllers with disproportionately high spend are prime rightsizing targets. Look for controllers that have grown significantly over time — they may have been scaled up for a peak event and never scaled back down.",
      ["tag_kubernetes_controller"]),
    costList("s3-list-workload", "Workload Detail: Kind, Controller, Namespace, Cluster",
      "Full workload topology for detailed cost investigation. Use this to trace expensive workloads from controller kind through to their owning namespace and cluster. This view helps answer: 'What exactly is costing us money and where is it running?'",
      ["tag_kubernetes_controller_kind", "tag_kubernetes_controller",
       "tag_kubernetes_namespace", "tag_kubernetes_cluster"]),

    // Section 4: Infrastructure & Packaging — Where are costs at the infra level?
    costList("s4-list-node", "Node Costs by Cluster",
      "Node-level costs grouped by cluster. With Ocean autoscaling, node counts and types change frequently — focus on cluster-level node cost totals rather than individual nodes. Large cost disparities between nodes in the same cluster may indicate bin-packing inefficiency.",
      ["tag_kubernetes_node", "tag_kubernetes_cluster"]),
    costList("s4-list-node-provider", "Node to Cloud Provider ID Mapping",
      "Maps Kubernetes nodes to cloud provider instance IDs for IaaS bill correlation. Use this to cross-reference container costs with underlying compute costs, verify Ocean is selecting cost-effective instance types, and reconcile CCV estimated costs against actual cloud billing.",
      ["tag_kubernetes_node", "tag_kubernetes_node_cloud_provider_id", "tag_kubernetes_cluster"]),
    barChart("s4-bar-helm", "Costs by Helm Chart",
      "Cost breakdown by Helm chart (helm.sh/chart label). Only Helm-deployed workloads appear here — others show as 'None'. Useful for understanding the cost of shared infrastructure (ingress controllers, monitoring, service meshes) often deployed via Helm. If most values show 'None', your workloads may not use Helm or lack the helm.sh/chart label.",
      "tag_kubernetes_metadata_helm_chart"),

    // Resource-level detail
    {
      component: "resource-list",
      description: "Granular resource-level detail for deep-dive analysis. Use filters and column sorting to investigate specific cost anomalies identified in the charts above. Export data from this view for chargeback reporting, capacity planning, or ad-hoc cost investigations.",
      id: "s5-resourcelist",
      isPercentageBased: "off",
      metrics: metric,
      name: "Detailed Resource View",
      filters: [
        { id: "DimensionParam", source: "inline" },
        { id: "GroupByParam", source: "inline" }
      ].concat(default_filters)
    }
  ]

  var md_layout = [
    { h: 6, i: "s1-bar-cluster",        minH: 6, minW: 6, moved: false, "static": false, w: 8,  x: 0, y: 0 },
    { h: 6, i: "s1-list-cluster",        minH: 6, minW: 4, moved: false, "static": false, w: 4,  x: 8, y: 0 },
    { h: 6, i: "s1-bar-namespace",       minH: 6, minW: 6, moved: false, "static": false, w: 8,  x: 0, y: 6 },
    { h: 6, i: "s1-list-namespace",      minH: 6, minW: 4, moved: false, "static": false, w: 4,  x: 8, y: 6 },
    { h: 8, i: "s1-list-ns-cluster",     minH: 6, minW: 4, moved: false, "static": false, w: 12, x: 0, y: 12 },
    { h: 6, i: "s2-bar-appname",         minH: 6, minW: 6, moved: false, "static": false, w: 8,  x: 0, y: 20 },
    { h: 6, i: "s2-list-appname",        minH: 6, minW: 4, moved: false, "static": false, w: 4,  x: 8, y: 20 },
    { h: 8, i: "s2-list-app-cluster-ns", minH: 6, minW: 4, moved: false, "static": false, w: 12, x: 0, y: 26 },
    { h: 6, i: "s3-bar-ctrlkind",        minH: 6, minW: 6, moved: false, "static": false, w: 8,  x: 0, y: 34 },
    { h: 6, i: "s3-list-controller",     minH: 6, minW: 4, moved: false, "static": false, w: 4,  x: 8, y: 34 },
    { h: 8, i: "s3-list-workload",       minH: 6, minW: 4, moved: false, "static": false, w: 12, x: 0, y: 40 },
    { h: 6, i: "s4-list-node",           minH: 6, minW: 6, moved: false, "static": false, w: 6,  x: 0, y: 48 },
    { h: 6, i: "s4-list-node-provider",  minH: 6, minW: 6, moved: false, "static": false, w: 6,  x: 6, y: 48 },
    { h: 6, i: "s4-bar-helm",            minH: 6, minW: 6, moved: false, "static": false, w: 12, x: 0, y: 54 },
    { h: 6, i: "s5-resourcelist",        minH: 6, minW: 6, moved: false, "static": false, w: 12, x: 0, y: 60 }
  ]

  var sm_y = 0
  var sm_layout = _.map(md_layout, function(item) {
    var sm_item = { h: item.h, i: item.i, minH: 6, minW: 2, moved: false, "static": false, w: 2, x: 0, y: sm_y }
    sm_y += item.h
    return sm_item
  })

  var config = {
    description: "Kubernetes container cost visibility powered by Spot Ocean data. Organized by: Platform/Tenancy (cluster, namespace, chargeback), Application Identity, Workload Runtime (controller kind/name), Infrastructure (nodes, Helm charts), and detailed resource view.",
    layouts: { md: md_layout, sm: sm_layout },
    version: 2,
    widgets: widgets
  }

  result = [{
    name: "Container Cost Visibility Dashboard",
    config: config
  }]

  } // end if ds_dashboard_toggle.length > 0
EOS
end

datasource "ds_dashboard_to_create" do
  run_script $js_dashboard_to_create, $ds_dashboard_json
end

script "js_dashboard_to_create", type: "javascript" do
  parameters "ds_dashboard_json"
  result "result"
  code <<-'EOS'
  result = _.map(ds_dashboard_json, function(dashboard) {
    if (dashboard["name"] && dashboard["config"]) {
      return {
        area: "OrgDashboard",
        id: "new-dashboard",
        config: dashboard["config"],
        name: dashboard["name"],
        visibility: "public",
        isDefault: false
      }
    }
  })

  result = _.compact(result)
EOS
end

datasource "ds_create_dashboard" do
  iterate $ds_dashboard_to_create
  request do
    auth $auth_flexera
    verb "POST"
    host rs_optima_host
    path join(["/bill-analysis/orgs/", rs_org_id, "/dashboards"])
    header "Api-Version", "0.1"
    header "User-Agent", "RS Policies"
    body_field "area", val(iter_item, "area")
    body_field "id", val(iter_item, "id")
    body_field "config", val(iter_item, "config")
    body_field "name", val(iter_item, "name")
    body_field "visibility", val(iter_item, "visibility")
    body_field "isDefault", val(iter_item, "isDefault")
    ignore_status [409]
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
    field "name", jmes_path(response, "name")
  end
end

datasource "ds_existing_dashboards" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/bill-analysis/orgs/", rs_org_id, "/dashboards"])
    header "Api-Version", "0.1"
    header "User-Agent", "RS Policies"
  end
  result do
    collect jmes_path(response, "[*]") do
      field "id", jmes_path(col_item, "id")
      field "name", jmes_path(col_item, "name")
    end
  end
end

###############################################################################
# Step 3: Tag Dimensions
###############################################################################

datasource "ds_existing_tag_dimensions" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/finops-customizations/v1/orgs/", rs_org_id, "/tag-dimensions"])
    query "view", "extended"
    header "User-Agent", "RS Policies"
  end
end

datasource "ds_tag_dimensions_to_create" do
  run_script $js_tag_dimensions_to_create, $ds_existing_tag_dimensions, $param_create_tag_dimensions
end

script "js_tag_dimensions_to_create", type: "javascript" do
  parameters "ds_existing_tag_dimensions", "param_create_tag_dimensions"
  result "result"
  code <<-'EOS'
  result = []

  if (param_create_tag_dimensions == "Yes") {
    var required_dimensions = [
      { name: "Kubernetes Namespace", tags: [{ key: "oc-namespace" }] },
      { name: "Kubernetes Cluster", tags: [{ key: "oc-cluster" }] },
      { name: "Kubernetes Node Cloud Provider Id", tags: [{ key: "oc-provider-id" }] },
      { name: "Kubernetes Controller", tags: [{ key: "oc-controller" }] },
      { name: "Kubernetes Pod Id", tags: [{ key: "oc-pod" }] },
      { name: "Kubernetes Controller Kind", tags: [{ key: "oc-controller-kind" }] },
      { name: "Kubernetes Node", tags: [{ key: "oc-node" }] },
      { name: "Kubernetes Metadata App Part Of", tags: [{ key: "app.kubernetes.io/part-of" }] },
      { name: "Kubernetes Metadata App Name", tags: [{ key: "app.kubernetes.io/name" }, { key: "app" }] },
      { name: "Kubernetes Metadata App Instance", tags: [{ key: "app.kubernetes.io/instance" }] },
      { name: "Kubernetes Metadata App Component", tags: [{ key: "app.kubernetes.io/component" }] },
      { name: "Kubernetes Metadata App Managed By", tags: [{ key: "app.kubernetes.io/managed-by" }] },
      { name: "Kubernetes Metadata Helm Chart", tags: [{ key: "helm.sh/chart" }] }
    ]

    var existing_values = []
    if (ds_existing_tag_dimensions && ds_existing_tag_dimensions["values"]) {
      existing_values = ds_existing_tag_dimensions["values"]
    }

    _.each(required_dimensions, function(dim) {
      var existing = _.find(existing_values, function(e) {
        return e["name"] == dim["name"]
      })

      if (!existing) {
        result.push({
          verb: "POST",
          name: dim["name"],
          tags: dim["tags"],
          path_suffix: ""
        })
      }
    })
  }
EOS
end

datasource "ds_create_tag_dimensions" do
  iterate $ds_tag_dimensions_to_create
  request do
    run_script $js_create_tag_dimensions, iter_item, $ds_flexera_api_hosts, rs_org_id
  end
end

script "js_create_tag_dimensions", type: "javascript" do
  parameters "iter_item", "ds_flexera_api_hosts", "rs_org_id"
  result "request"
  code <<-'EOS'
  var request = {
    auth: "auth_flexera",
    verb: "POST",
    host: ds_flexera_api_hosts["flexera"],
    path: "/finops-customizations/v1/orgs/" + rs_org_id + "/tag-dimensions",
    body_fields: {
      "name": iter_item["name"],
      "tags": iter_item["tags"]
    },
    headers: {
      "User-Agent": "RS Policies"
    },
    ignore_status: [409]
  }
EOS
end

###############################################################################
# Step 4: Adjustment Rules (Hide CCV Costs)
###############################################################################

datasource "ds_current_adjustments" do
  request do
    auth $auth_flexera
    host rs_optima_host
    path join(["/bill-analysis/orgs/", rs_org_id, "/adjustments/"])
    header "User-Agent", "RS Policies"
  end
end

datasource "ds_updated_adjustments" do
  run_script $js_updated_adjustments, $ds_current_adjustments, $ds_bill_connect, $param_hide_ccv_costs, $param_spot_ocean_org_id
end

script "js_updated_adjustments", type: "javascript" do
  parameters "ds_current_adjustments", "ds_bill_connect", "param_hide_ccv_costs", "param_spot_ocean_org_id"
  result "result"
  code <<-'EOS'
  result = []

  if (param_hide_ccv_costs == "Yes") {
  var bill_connect_id = "cbi-oi-ocean-org-" + param_spot_ocean_org_id
  var adj_name = "Hide CCV Estimated Costs - " + bill_connect_id

  var current_date_parts = new Date().toISOString().split('-')
  var current_month = [current_date_parts[0], current_date_parts[1]].join('-')

  var ccv_rule = {
    name: adj_name,
    rules: [{
      condition: {
        type: "dimension_equals",
        dimension: "bill_source",
        value: bill_connect_id
      },
      cost_multiplier: -1,
      label: adj_name
    }]
  }

  // Build new dated_adjustment_lists preserving existing rules
  var existing_lists = {}
  if (ds_current_adjustments && ds_current_adjustments["dated_adjustment_lists"]) {
    _.each(ds_current_adjustments["dated_adjustment_lists"], function(list) {
      existing_lists[list["effective_at"]] = list["adjustment_list"]
    })
  }

  // Remove our rule from existing lists and re-add it (to update)
  var new_adjustments = []

  // Process existing months
  _.each(ds_current_adjustments["dated_adjustment_lists"] || [], function(list) {
    var filtered = _.filter(list["adjustment_list"], function(adj) {
      return adj["name"] != adj_name
    })

    filtered.unshift(ccv_rule)

    new_adjustments.push({
      adjustment_list: filtered,
      effective_at: list["effective_at"]
    })
  })

  // Add current month if not already present
  var has_current = _.find(new_adjustments, function(adj) {
    return adj["effective_at"] == current_month
  })

  if (!has_current) {
    new_adjustments.push({
      adjustment_list: [ccv_rule],
      effective_at: current_month
    })
  }

  new_adjustments = _.sortBy(new_adjustments, "effective_at")

  result = [{ payload: JSON.stringify({ dated_adjustment_lists: new_adjustments }) }]
  }
EOS
end

datasource "ds_apply_adjustments" do
  iterate $ds_updated_adjustments
  request do
    auth $auth_flexera
    verb "PUT"
    host rs_optima_host
    path join(["/bill-analysis/orgs/", rs_org_id, "/adjustments/"])
    header "content-type", "application/json"
    header "User-Agent", "RS Policies"
    body val(iter_item, "payload")
  end
end

###############################################################################
# Step 5: Apply Kubernetes Rightsizing Recommendations
###############################################################################

datasource "ds_published_templates" do
  request do
    auth $auth_flexera
    pagination $pagination_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/published-templates"])
    query "limit", "5000"
    query "view", "extended"
    header "User-Agent", "RS Policies"
  end
  result do
    collect jmes_path(response, "values[*]") do
      field "id", jq(col_item, ".id")
      field "name", jq(col_item, ".name")
      field "ref", jq(col_item, ".ref")
      field "builtIn", jq(col_item, ".builtIn")
      field "credentials", jq(col_item, ".credentials")
      field "defaultFrequency", jq(col_item, ".defaultFrequency")
      field "shortDescription", jq(col_item, ".shortDescription")
    end
  end
end

datasource "ds_applied_policies" do
  request do
    auth $auth_flexera
    pagination $pagination_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/policy/v1/orgs/", rs_org_id, "/projects/", rs_project_id, "/applied-policies"])
    query "limit", "5000"
    query "view", "extended"
    header "User-Agent", "RS Policies"
  end
  result do
    collect jmes_path(response, "values[*]") do
      field "id", jq(col_item, ".id")
      field "name", jq(col_item, ".name")
      field "credentials", jq(col_item, ".credentials")
      field "publishedTemplate", jq(col_item, ".publishedTemplate")
      field "policyTemplate", jq(col_item, ".policyTemplate")
      field "status", jq(col_item, ".status")
    end
  end
end

datasource "ds_apply_rightsizing_request" do
  run_script $js_apply_rightsizing_request, $ds_published_templates, $ds_applied_policies, $ds_flexera_api_hosts, $param_apply_rightsizing, rs_org_id, rs_project_id
end

script "js_apply_rightsizing_request", type: "javascript" do
  parameters "ds_published_templates", "ds_applied_policies", "ds_flexera_api_hosts", "param_apply_rightsizing", "rs_org_id", "rs_project_id"
  result "result"
  code <<-'EOS'
  result = []

  if (param_apply_rightsizing == "Yes") {
    var template_name = "Kubernetes - Rightsizing Recommendations"

    var published_template = _.find(ds_published_templates, function(pt) {
      return pt["name"] == template_name && pt["builtIn"] == true
    })

    if (published_template) {
      var already_applied = _.find(ds_applied_policies, function(ap) {
        if (ap["name"] == template_name) { return true }
        if (ap["publishedTemplate"] && ap["publishedTemplate"]["name"] == template_name) { return true }
        if (ap["policyTemplate"] && ap["policyTemplate"]["name"] == template_name) { return true }
        return false
      })

      if (!already_applied) {
        // Reuse the same credential IDs as this running policy.
        // Find our own applied policy by template name and extract its credentials.
        var our_policy = _.find(ds_applied_policies, function(ap) {
          if (ap["policyTemplate"] && ap["policyTemplate"]["name"] == "Container Cost Visibility Setup") { return true }
          if (ap["name"] == "Container Cost Visibility Setup") { return true }
          return false
        })

        var our_creds = {}
        if (our_policy && our_policy["credentials"]) {
          our_creds = our_policy["credentials"]
        }

        // Map published template's required credentials to our credential IDs
        var cred_mapping = {}

        if (published_template["credentials"]) {
          var cred_keys = Object.keys(published_template["credentials"])

          _.each(cred_keys, function(cred_key) {
            var pt_cred = published_template["credentials"][cred_key]
            var pt_cred_name = pt_cred["name"]
            var pt_provider = ""

            if (pt_cred["tags"]) {
              _.each(pt_cred["tags"], function(tag) {
                if (tag["key"] == "provider") { pt_provider = tag["value"] }
              })
            }

            // First: match by name (e.g. both use "auth_flexera")
            if (our_creds[pt_cred_name]) {
              cred_mapping[pt_cred_name] = our_creds[pt_cred_name]
            } else {
              // Second: match by provider tag across our credentials
              _.each(Object.keys(our_creds), function(our_cred_name) {
                if (pt_provider == "flexera" && our_cred_name.indexOf("flexera") >= 0) {
                  cred_mapping[pt_cred_name] = our_creds[our_cred_name]
                } else if (pt_provider == "spotinst" && our_cred_name.indexOf("spotinst") >= 0) {
                  cred_mapping[pt_cred_name] = our_creds[our_cred_name]
                }
              })
            }
          })
        }

        var freq = "DAILY"

        if (published_template["defaultFrequency"]) {
          freq = published_template["defaultFrequency"].toUpperCase()
          if (freq == "15 MINUTES") { freq = "MINUTELY;INTERVAL=15" }
        }

        result = [{
          host: ds_flexera_api_hosts["flexera"],
          path: "/policy/v1/orgs/" + rs_org_id + "/projects/" + rs_project_id + "/applied-policies",
          name: template_name,
          description: "Applied automatically by Container Cost Visibility Setup policy template.",
          templateRef: published_template["ref"],
          schedule: { "rrule": "FREQ=" + freq },
          credentials: cred_mapping,
          options: []
        }]
      }
    }
  }
EOS
end

datasource "ds_apply_rightsizing" do
  iterate $ds_apply_rightsizing_request
  request do
    run_script $js_apply_rightsizing, iter_item
  end
end

script "js_apply_rightsizing", type: "javascript" do
  parameters "iter_item"
  result "request"
  code <<-'EOS'
  var request = {
    auth: "auth_flexera",
    verb: "POST",
    host: iter_item["host"],
    path: iter_item["path"],
    body_fields: {
      "name": iter_item["name"],
      "description": iter_item["description"],
      "templateRef": iter_item["templateRef"],
      "dryRun": false,
      "schedule": iter_item["schedule"],
      "credentials": iter_item["credentials"],
      "options": iter_item["options"]
    },
    headers: {
      "User-Agent": "RS Policies",
      "Content-Type": "application/json"
    },
    ignore_status: [409]
  }
EOS
end

###############################################################################
# Step 6: Spot CCO Export Check
###############################################################################

datasource "ds_spot_cco_integration" do
  request do
    auth $auth_spotinst
    host "api.spotinst.io"
    path "/ccoUsageExporter/flexeraIntegration"
    header "User-Agent", "RS Policies"
    ignore_status [400, 401, 403, 404]
  end
end

###############################################################################
# Compile Results
###############################################################################

datasource "ds_results" do
  run_script $js_results, $ds_bill_connect, $ds_create_dashboard, $ds_existing_dashboards, $ds_create_tag_dimensions, $ds_apply_adjustments, $ds_spot_cco_integration, $ds_apply_rightsizing, $ds_existing_bill_connects, $ds_published_templates, $ds_applied_policies, $ds_flexera_api_hosts, $param_spot_ocean_org_id, $param_create_dashboard, $param_create_tag_dimensions, $param_hide_ccv_costs, $param_apply_rightsizing, rs_org_id
end

script "js_results", type: "javascript" do
  parameters "ds_bill_connect", "ds_create_dashboard", "ds_existing_dashboards", "ds_create_tag_dimensions", "ds_apply_adjustments", "ds_spot_cco_integration", "ds_apply_rightsizing", "ds_existing_bill_connects", "ds_published_templates", "ds_applied_policies", "ds_flexera_api_hosts", "param_spot_ocean_org_id", "param_create_dashboard", "param_create_tag_dimensions", "param_hide_ccv_costs", "param_apply_rightsizing", "rs_org_id"
  result "result"
  code <<-'EOS'
  var bill_connect_id = "cbi-oi-ocean-org-" + param_spot_ocean_org_id
  var ui_host = ds_flexera_api_hosts["ui"]
  var flexera_host = ds_flexera_api_hosts["flexera"]

  result = []

  // Date helpers for dashboard links
  var now = new Date()
  var start_year = now.getUTCFullYear()
  var start_month = now.getUTCMonth() + 1
  var end_year = start_month == 12 ? start_year + 1 : start_year
  var end_month = start_month == 12 ? 1 : start_month + 1
  var start_date = start_year + "-" + (start_month < 10 ? "0" : "") + start_month + "-01"
  var end_date = end_year + "-" + (end_month < 10 ? "0" : "") + end_month + "-01"
  var dashboard_note = "\n\n**Note:** If Tag Dimensions were just created, the dashboard may not load correctly until bill data refreshes and the new Kubernetes Tag Dimensions become available (up to 24 hours)."

  function dashboardUrl(id) {
    return "https://" + ui_host + "/orgs/" + rs_org_id + "/optima/dashboards?dashboardID=" + id + "&granularity=Daily&startDate=" + start_date + "&endDate=" + end_date
  }

  // Step 1: Bill Connect
  var bc_existed = _.find(ds_existing_bill_connects, function(bc) {
    return bc.id == bill_connect_id
  })
  if (ds_bill_connect.length > 0) {
    result.push({
      step: "1. CBI Bill Connect",
      status: "Created",
      details: "Bill Connect ID: " + bill_connect_id
    })
  } else {
    result.push({
      step: "1. CBI Bill Connect",
      status: bc_existed ? "Already Exists" : "Failed",
      details: "Bill Connect ID: " + bill_connect_id
    })
  }

  // Step 2: Dashboard
  var dashboard_name = "Container Cost Visibility Dashboard"
  var dashboard_exists = _.find(ds_existing_dashboards, function(d) {
    return d["name"] == dashboard_name
  })

  if (param_create_dashboard == "Yes") {
    if (ds_create_dashboard.length > 0 && ds_create_dashboard[0]["id"]) {
      result.push({
        step: "2. CCV Dashboard",
        status: "Created",
        details: "Dashboard: " + dashboard_name + " — [View Dashboard](" + dashboardUrl(ds_create_dashboard[0]["id"]) + ")" + dashboard_note
      })
    } else if (dashboard_exists) {
      result.push({
        step: "2. CCV Dashboard",
        status: "Already Exists",
        details: "Dashboard '" + dashboard_name + "' already exists — [View Dashboard](" + dashboardUrl(dashboard_exists["id"]) + ")" + dashboard_note
      })
    } else {
      result.push({
        step: "2. CCV Dashboard",
        status: "Failed",
        details: "Dashboard creation failed. Check permissions and try again. View dashboards at https://" + ui_host + "/orgs/" + rs_org_id + "/optima/dashboards"
      })
    }
  } else {
    if (dashboard_exists) {
      result.push({
        step: "2. CCV Dashboard",
        status: "Already Exists",
        details: "Dashboard '" + dashboard_name + "' exists. Creation was skipped by parameter. [View Dashboard](" + dashboardUrl(dashboard_exists["id"]) + ")" + dashboard_note
      })
    } else {
      result.push({
        step: "2. CCV Dashboard",
        status: "Skipped",
        details: "Dashboard creation disabled by parameter."
      })
    }
  }

  // Step 3: Tag Dimensions
  if (param_create_tag_dimensions == "Yes") {
    if (ds_create_tag_dimensions.length > 0) {
      result.push({
        step: "3. Tag Dimensions",
        status: "Created " + ds_create_tag_dimensions.length + " dimension(s)",
        details: "Flexera Tag dimensions created for Kubernetes context (Cluster, Namespace, Controller, Workload, Node, Labels, etc.)."
      })
    } else {
      result.push({
        step: "3. Tag Dimensions",
        status: "Already Exist",
        details: "All required Kubernetes tag dimensions already exist."
      })
    }
  } else {
    result.push({
      step: "3. Tag Dimensions",
      status: "Skipped",
      details: "Tag dimension creation disabled by parameter."
    })
  }

  // Step 4: Adjustment Rules
  if (param_hide_ccv_costs == "Yes") {
    result.push({
      step: "4. Hide CCV Costs",
      status: "Applied",
      details: "Adjustment rule added: -100% cost multiplier on bill_source=" + bill_connect_id + ". CCV costs hidden from general CCO reports. The CCV Dashboard shows raw (pre-adjustment) costs."
    })
  } else {
    result.push({
      step: "4. Hide CCV Costs",
      status: "Skipped",
      details: "CCV cost hiding disabled by parameter. CCV estimated costs will be visible in all CCO reports."
    })
  }

  // Step 5: Rightsizing Recommendations
  if (param_apply_rightsizing == "Yes") {
    var template_name = "Kubernetes - Rightsizing Recommendations"

    var published_template = _.find(ds_published_templates, function(pt) {
      return pt["name"] == template_name && pt["builtIn"] == true
    })

    if (!published_template) {
      result.push({
        step: "5. Rightsizing Recommendations",
        status: "Template Not Found",
        details: "The '" + template_name + "' published template was not found in the catalog. It may not be available in this organization."
      })
    } else {
      var already_applied = _.find(ds_applied_policies, function(ap) {
        if (ap["name"] == template_name) { return true }
        if (ap["publishedTemplate"] && ap["publishedTemplate"]["name"] == template_name) { return true }
        if (ap["policyTemplate"] && ap["policyTemplate"]["name"] == template_name) { return true }
        return false
      })

      if (already_applied) {
        result.push({
          step: "5. Rightsizing Recommendations",
          status: "Already Applied",
          details: "The '" + template_name + "' policy template is already applied in this project."
        })
      } else if (ds_apply_rightsizing.length > 0) {
        result.push({
          step: "5. Rightsizing Recommendations",
          status: "Applied",
          details: "The '" + template_name + "' policy template has been applied. View at https://" + ui_host + "/orgs/" + rs_org_id + "/policy"
        })
      } else {
        result.push({
          step: "5. Rightsizing Recommendations",
          status: "Failed",
          details: "Failed to apply the '" + template_name + "' policy template. Please apply it manually from the Flexera catalog."
        })
      }
    }
  } else {
    result.push({
      step: "5. Rightsizing Recommendations",
      status: "Skipped",
      details: "Rightsizing recommendations policy application disabled by parameter."
    })
  }

  // Step 6: Spot CCO Export
  var spot_integration_status = "not_found"
  var spot_integration_org = ""

  if (ds_spot_cco_integration && ds_spot_cco_integration["response"]) {
    var resp = ds_spot_cco_integration["response"]

    if (resp["status"] && resp["status"]["code"] == 200 && resp["items"] && resp["items"].length > 0) {
      var integration = resp["items"][0]
      spot_integration_org = String(integration["flexeraOrganizationId"] || "")

      if (spot_integration_org == String(rs_org_id)) {
        spot_integration_status = "configured_same_org"
      } else {
        spot_integration_status = "configured_different_org"
      }
    }
  }

  if (spot_integration_status == "configured_same_org") {
    result.push({
      step: "6. Spot CCO Export",
      status: "Already Configured",
      details: "Spot CCO Export integration is configured and pointing to this Flexera organization (Org ID: " + rs_org_id + ")."
    })
  } else {
    var curl_cmd = [
      "curl -X POST 'https://api.spotinst.io/ccoUsageExporter/flexeraIntegration' \\",
      "  -H 'Authorization: Bearer <SPOT_API_TOKEN>' \\",
      "  -H 'Content-Type: application/json' \\",
      "  -d '{",
      "    \"flexeraBillConnectId\": \"" + bill_connect_id + "\",",
      "    \"flexeraOrganizationId\": \"" + rs_org_id + "\",",
      "    \"flexeraRefreshToken\": \"<FLEXERA_REFRESH_TOKEN>\",",
      "    \"flexeraZone\": \"" + ds_flexera_api_hosts["flexera"].replace("api.", "") + "\"",
      "  }'"
    ].join("\n")

    var ps_cmd = [
      "$headers = @{",
      "  'Authorization' = 'Bearer <SPOT_API_TOKEN>'",
      "  'Content-Type'  = 'application/json'",
      "}",
      "$body = @{",
      "  flexeraBillConnectId   = '" + bill_connect_id + "'",
      "  flexeraOrganizationId  = '" + rs_org_id + "'",
      "  flexeraRefreshToken    = '<FLEXERA_REFRESH_TOKEN>'",
      "  flexeraZone            = '" + ds_flexera_api_hosts["flexera"].replace("api.", "") + "'",
      "} | ConvertTo-Json",
      "Invoke-RestMethod -Uri 'https://api.spotinst.io/ccoUsageExporter/flexeraIntegration' -Method Post -Headers $headers -Body $body"
    ].join("\n")

    var details = ""

    if (spot_integration_status == "configured_different_org") {
      details += "**⚠️ WARNING:** The Spot CCO Export is currently configured to push data to **Flexera Org " + spot_integration_org + "**, which is different from this organization (" + rs_org_id + "). "
      details += "Spot only supports one Flexera integration per Spot organization. Running the POST command below will **replace** the existing configuration and **stop data flowing to Org " + spot_integration_org + "**.\n\n"
    }

    details += "The Spot CCO Export requires a Flexera refresh token which cannot be generated automatically by this policy template.\n\n"
    details += "**To complete the setup:**\n\n"
    details += "1. Generate a Flexera refresh token: [Flexera Documentation](https://docs.flexera.com/flexera-one/flexera-api/working-with-the-flexera-one-api/generating-a-refresh-token)\n"
    details += "2. Get your Spot API permanent token: [Spot Documentation](https://docs.flexera.com/spot/administration/api/create-api-token)\n"
    details += "3. Run one of the following commands, replacing the placeholder tokens:\n\n"
    details += "**curl (Linux/Mac):**\n\n"
    details += "```\n" + curl_cmd + "\n```\n\n"
    details += "**PowerShell (Windows):**\n\n"
    details += "```\n" + ps_cmd + "\n```\n\n"
    details += "**Values for your environment:**\n\n"
    details += "| Setting | Value |\n"
    details += "| --- | --- |\n"
    details += "| Bill Connect ID | `" + bill_connect_id + "` |\n"
    details += "| Flexera Org ID | `" + rs_org_id + "` |\n"
    details += "| Flexera Zone | `" + ds_flexera_api_hosts["flexera"].replace("api.", "") + "` |\n"
    details += "| Spot Org ID | `" + param_spot_ocean_org_id + "` |\n"

    result.push({
      step: "6. Spot CCO Export",
      status: spot_integration_status == "configured_different_org" ? "⚠️ Different Org Configured" : "Manual Setup Required",
      details: details
    })
  }

  // Check if all steps completed successfully
  var all_done = _.every(result, function(r) {
    var s = r["status"]
    return s == "Created" || s.indexOf("Created ") == 0 ||
           s == "Already Exists" || s == "Already Exist" ||
           s == "Already Configured" || s == "Already Applied" ||
           s == "Applied" || s == "Skipped"
  })

  if (all_done) {
    result.unshift({
      step: "✅ Setup Complete",
      status: "All Steps Successful",
      details: "**Container Cost Visibility has been fully onboarded.** This policy template is intended for one-time setup. You may now terminate this applied policy — all configured resources (bill connect, dashboard, tag dimensions, adjustment rules, and applied policies) will persist after termination.\n\n---\n\n"
    })
  }
EOS
end

###############################################################################
# Policy
###############################################################################

policy "pol_container_cost_visibility" do
  validate_each $ds_results do
    summary_template "Container Cost Visibility Setup: {{ len data }} Steps Completed"
    detail_template <<-'EOS'
  # Container Cost Visibility Setup Results

  {{range data}}
  ## {{ .step }}: {{ .status }}
  {{ .details }}

  {{end}}
  EOS
    check eq(0, 1)
    escalate $esc_email
  end
end

###############################################################################
# Escalations
###############################################################################

escalation "esc_email" do
  automatic true
  label "Send Email"
  description "Send incident email"
  email $param_email
end
