name "Container Cost Visibility Setup"
rs_pt_ver 20180301
type "policy"
short_description "Automates the setup of the Flexera One and Spot Ocean integration for Container Cost Visibility. Creates CBI bill connect, dashboard, tag dimensions, optionally hides CCV estimated costs, and applies the Kubernetes Rightsizing Recommendations policy template. See the [README](https://github.com/flexera-public/policy_templates/tree/master/automation/flexera/spot/container_cost_visibility/) and [docs.flexera.com/flexera/EN/Automation](https://docs.flexera.com/flexera-one/automation/) to learn more."
long_description ""
doc_link "https://github.com/flexera-public/policy_templates/tree/master/automation/flexera/spot/container_cost_visibility/"
category "Operational"
severity "low"
default_frequency "monthly"
info(
  version: "0.1.0",
  provider: "Flexera",
  service: "Cloud Cost Optimization",
  policy_set: "Container Cost Visibility",
  hide_skip_approvals: "true"
)

###############################################################################
# Parameters
###############################################################################

parameter "param_email" do
  type "list"
  category "Policy Settings"
  label "Email Addresses"
  description "Email addresses of the recipients you wish to notify when the setup is complete."
  default []
end

parameter "param_spot_ocean_org_id" do
  type "string"
  category "Spot Settings"
  label "Spot Organization ID"
  description "The Spot Organization ID to integrate with Flexera. This is used to create the CBI bill connect and configure the CCO export."
  # No default value, user input required
end

parameter "param_create_dashboard" do
  type "string"
  category "Policy Settings"
  label "Create Dashboard"
  description "Whether to create the Container Cost Visibility Dashboard in the Flexera One CCO UI. The dashboard provides visibility into Kubernetes costs by cluster, namespace, and pod."
  allowed_values "Yes", "No"
  default "Yes"
end

parameter "param_create_tag_dimensions" do
  type "string"
  category "Policy Settings"
  label "Create Tag Dimensions"
  description "Whether to create Kubernetes tag dimensions in Flexera One CCO. These dimensions expose Kubernetes context (cluster, namespace, pod, etc.) from CCV bill data for cost analysis."
  allowed_values "Yes", "No"
  default "Yes"
end

parameter "param_hide_ccv_costs" do
  type "string"
  category "Policy Settings"
  label "Hide CCV Costs"
  description "Whether to hide Flexera Container Cost Visibility estimated costs from general CCO reports via a -100% adjustment rule. Flexera Container Cost Visibility costs are estimated based on public market rates, not actual customer rates. Hiding them avoids confusion in chargeback and other reports. The Flexera Container Cost Visibility Dashboard still shows these costs."
  allowed_values "Yes", "No"
  default "Yes"
end

parameter "param_apply_rightsizing" do
  type "string"
  category "Policy Settings"
  label "Apply Rightsizing Recommendations"
  description "Whether to apply the 'Kubernetes - Rightsizing Recommendations' published policy template if it is not already applied in this project. This template provides container rightsizing recommendations based on Flexera Container Cost Visibility data."
  allowed_values "Yes", "No"
  default "Yes"
end

###############################################################################
# Authentication
###############################################################################

credentials "auth_flexera" do
  schemes "oauth2"
  label "Flexera"
  description "Select Flexera One OAuth2 credentials"
  tags "provider=flexera"
end

credentials "auth_spotinst" do
  schemes "api_key"
  label "SpotInst"
  description "Select the SpotInst Credential from the list."
  tags "provider=spotinst"
end

###############################################################################
# Pagination
###############################################################################

pagination "pagination_flexera" do
  get_page_marker do
    body_path jq(response, 'try(.nextPage | split("skipToken=") | .[1] | sub("%3D";"=";"g") | sub("%253D";"=";"g")) catch null') # The skipToken is url encoded, so we need to decode the %3D and %253D to = .  This is not ideal implementation this seems to be enough without a true urldecode function
  end
  set_page_marker do
    query "skipToken"
  end
end

###############################################################################
# Datasources & Scripts
###############################################################################

# Flexera API host resolution (region-aware)
datasource "ds_flexera_api_hosts" do
  run_script $js_flexera_api_hosts, rs_optima_host
end

script "js_flexera_api_hosts", type: "javascript" do
  parameters "rs_optima_host"
  result "result"
  code <<-'EOS'
  host_table = {
    "api.optima.flexeraeng.com": {
      flexera: "api.flexera.com",
      ui: "app.flexera.com",
      login: "login.flexera.com"
    },
    "api.optima-eu.flexeraeng.com": {
      flexera: "api.flexera.eu",
      ui: "app.flexera.eu",
      login: "login.flexera.eu"
    },
    "api.optima-apac.flexeraeng.com": {
      flexera: "api.flexera.au",
      ui: "app.flexera.au",
      login: "login.flexera.au"
    }
  }

  result = host_table[rs_optima_host]
EOS
end

###############################################################################
# Step 1: CBI Bill Connect
###############################################################################

datasource "ds_existing_bill_connects" do
  request do
    auth $auth_flexera
    host val($ds_flexera_api_hosts, "flexera")
    path join(["/finops-onboarding/v1/orgs/", rs_org_id, "/bill-connects"])
    header "User-Agent", "RS Policies"
  end
  result do
    encoding "json"
    collect jmes_path(response, "values[*]") do
      field "id", jmes_path(col_item, "id")
      field "kind", jmes_path(col_item, "kind")
      field "billIdentifier", jmes_path(col_item, "cbi.billIdentifier")
      field "integrationId", jmes_path(col_item, "cbi.integrationId")
      field "name", jmes_path(col_item, "cbi.name")
      field "displayName", jmes_path(col_item, "cbi.params.displayName")
      field "vendorName", jmes_path(col_item, "cbi.params.vendorName")
    end
  end
end

datasource "ds_bill_connect_request" do
  run_script $js_bill_connect_request, $ds_existing_bill_connects, $ds_flexera_api_hosts, $param_spot_ocean_org_id, rs_org_id
end

script "js_bill_connect_request", type: "javascript" do
  parameters "ds_existing_bill_connects", "ds_flexera_api_hosts", "param_spot_ocean_org_id", "rs_org_id"
  result "result"
  code <<-'EOS'
  var bill_identifier = "org-" + param_spot_ocean_org_id
  var bill_connect_id = "cbi-oi-ocean-" + bill_identifier

  var existing_bc = _.find(ds_existing_bill_connects, function(bc) {
    return bc.id == bill_connect_id
  })

  if (_.isObject(existing_bc)) {
    result = []
  } else {
    result = [{
      host: ds_flexera_api_hosts["flexera"],
      path: "/finops-onboarding/v1/orgs/" + rs_org_id + "/bill-connects/cbi",
      billIdentifier: bill_identifier,
      integrationId: "cbi-oi-ocean",
      name: bill_identifier,
      params: {
        "displayName": "Container Cost Visibility",
        "vendorName": "Container Cost Visibility"
      }
    }]
  }
EOS
end

datasource "ds_bill_connect" do
  iterate $ds_bill_connect_request
  request do
    auth $auth_flexera
    verb "POST"
    host val(iter_item, "host")
    path val(iter_item, "path")
    header "User-Agent", "RS Policies"
    body_field "billIdentifier", val(iter_item, "billIdentifier")
    body_field "integrationId", val(iter_item, "integrationId")
    body_field "name", val(iter_item, "name")
    body_field "params", val(iter_item, "params")
    ignore_status [409]
  end
  result do
    encoding "json"
    field "id", jmes_path(response, "id")
  end
end

###############################################################################
# Step 2: Dashboard
###############################################################################

# Conditional: only fetch dashboard if param says Yes
datasource "ds_dashboard_toggle" do
  run_script $js_dashboard_toggle, $param_create_dashboard
end

script "js_dashboard_toggle", type: "javascript" do
  parameters "param_create_dashboard"
  result "result"
  code <<-'EOS'
  if (param_create_dashboard == "Yes") {
    result = [{ fetch: true }]
  } else {
    result = []
  }
EOS
end

