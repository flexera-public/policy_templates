{
  "description": "Maps GCP API hostname prefixes (the part before .googleapis.com) to IAM permission service prefixes. Used by the policy API list generator to derive GCP IAM permission strings (e.g., compute.regions.list) from API call endpoints.",
  "version": "1.0",
  "host_prefix_to_iam_prefix": {
    "appengine": "appengine",
    "bigquery": "bigquery",
    "bigtable": "bigtable",
    "cloudkms": "cloudkms",
    "cloudresourcemanager": "resourcemanager",
    "cloudscheduler": "cloudscheduler",
    "cloudtasks": "cloudtasks",
    "composer": "composer",
    "compute": "compute",
    "container": "container",
    "dataflow": "dataflow",
    "datamigration": "datamigration",
    "dataproc": "dataproc",
    "dns": "dns",
    "file": "file",
    "iam": "iam",
    "logging": "logging",
    "memcache": "memcache",
    "monitoring": "monitoring",
    "pubsub": "pubsub",
    "recommender": "recommender",
    "redis": "redis",
    "run": "run",
    "secretmanager": "secretmanager",
    "spanner": "spanner",
    "sqladmin": "cloudsql",
    "storage": "storage",
    "vpcaccess": "vpcaccess"
  },
  "resource_abbreviations": {
    "b": "buckets",
    "o": "objects"
  }
}
