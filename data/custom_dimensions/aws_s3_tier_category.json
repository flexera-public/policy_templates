{
  "id": "rbd_policydim_aws_s3_tier",
  "name": "AWS S3 Tier Category",
  "rules": [
    {
      "condition": {
        "type": "and",
        "expressions": [
          {
            "type": "dimension_contains",
            "dimension": "service",
            "substring": "AmazonS3",
            "caseInsensitive": true
          },
          {
            "type": "or",
            "expressions": [
              {
                "type": "dimension_contains",
                "dimension": "usage_type",
                "substring": "DeepArchive",
                "caseInsensitive": true
              },
              {
                "type": "dimension_contains",
                "dimension": "usage_type",
                "substring": "GDA",
                "caseInsensitive": true
              }
            ]
          }
        ]
      },
      "value": {
        "text": "S3 Glacier Deep Archive"
      }
    },
